    evidence_rel = store_evidence.get("evidencePath", "") if isinstance(store_evidence, dict) else ""
    return formal_rel or "mapping_store/formal/by_page/unknown.json", evidence_rel or f"mapping_store/evidence/by_testid/unknown/{test_id}.json", evidence_ref, formal_ref


def _target_remove_formal_key(test_id):
    if not test_id:
        return
    store = MappingStore(project_root=_project_root)
    for path in sorted(store.formal_page_dir.glob("*.json")):
        data = store._read_json(path, {})
        mappings = data.get("mappings") if isinstance(data, dict) else None
        if not isinstance(mappings, dict) or test_id not in mappings:
            continue
        mappings.pop(test_id, None)
        data["mappings"] = mappings
        groups = store._empty_groups()
        for mapping_id, mapping in mappings.items():
            if isinstance(mapping, dict):
                groups.setdefault(store.classify_group(mapping), []).append(mapping_id)
        data["groups"] = groups
        data["count"] = len(mappings)
        store._write_json(path, data)


def _target_remove_evidence_ref(test_id, evidence_ref=""):
    if not test_id and not evidence_ref:
        return
    store = MappingStore(project_root=_project_root)
    for path in sorted(store.evidence_testid_dir.glob(f"*/{test_id}.json")) if test_id else []:
        try:
            path.unlink()
        except Exception:
            pass
    for path in sorted(store.evidence_page_dir.glob("*.json")):
        data = store._read_json(path, {})
        touched = False
        for section in ("items", "evidence"):
            bucket = data.get(section) if isinstance(data, dict) else None
            if isinstance(bucket, dict):
                for key in list(bucket.keys()):
                    value = _coerce_str(bucket.get(key))
                    if (evidence_ref and key == evidence_ref) or (test_id and test_id in value):
                        bucket.pop(key, None)
                        touched = True
        if touched:
            store._write_json(path, data)


