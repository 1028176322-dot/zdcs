  if(st)url+='&status='+encodeURIComponent(st);
  fetch(url).then(function(r){return r.json()}).then(function(d){
    var all=d.drafts||[];
    var items=[];
    if(t==='high'){items=all.filter(function(it){return it.confidence>=85;});}
