def api_mapping_store_current_page():
    try:
        refresh = _coerce_bool(request.args.get("refresh"), False)
        if request.method == "POST":
            payload = request.get_json(silent=True) or {}
            refresh = _coerce_bool(payload.get("refresh"), refresh)
        refresh_result = {}
        if refresh:
            ok_rt, rt = _prepare_invoke_api("post", "/api/runtime_ui/refresh")
            refresh_result = rt if isinstance(rt, dict) else {"success": ok_rt, "detail": str(rt)}
        state = _read_json_if_exists(os.path.join(_RUNTIME_METADATA_DIR, "current_runtime_state.json")) or {}
        tree = _read_json_if_exists(os.path.join(_RUNTIME_METADATA_DIR, "runtime_ui_tree_current.json")) or {}
        runtime_page = (
            _coerce_str(state.get("currentBusinessPageId"))
            or _coerce_str(state.get("pageId"))
            or _coerce_str(tree.get("currentBusinessPageId"))
            or _coerce_str(tree.get("pageId"))
            or _coerce_str(state.get("rawPageId"))
            or _coerce_str(tree.get("rawPageId"))
        )
        store = MappingStore(project_root=_project_root)
        resolved = store.resolve_existing_page_id(runtime_page)
        if not resolved.get("matched"):
            nodes = tree.get("nodes") if isinstance(tree, dict) else []
            path_blob = " ".join([
                _coerce_str(n.get("runtimePath") or n.get("path") or n.get("ownerPageId") or n.get("pageId"))
                for n in nodes[:2000]
                if isinstance(n, dict)
            ]).lower()
            page_index = _read_json_if_exists(str(store.index_dir / "page.index.json")) or {}
            pages = page_index.get("pages") if isinstance(page_index, dict) else {}
            if isinstance(pages, dict):
                heuristic_page = ""
                if "content/bag" in path_blob or "/bag/" in path_blob:
                    heuristic_page = "bag"
                elif "uishop" in _coerce_str(runtime_page).lower() and "shop" in pages:
                    heuristic_page = "shop"
                if heuristic_page and heuristic_page in pages:
                    resolved.update({
                        "matched": True,
                        "pageId": heuristic_page,
                        "source": "runtime_path_heuristic",
                        "page": pages.get(heuristic_page, {}),
                    })
        resolved.update({
            "success": True,
            "sceneId": state.get("sceneId") or tree.get("sceneId") or "",
            "capturedAt": state.get("capturedAt") or tree.get("capturedAt") or "",
            "nodeCount": state.get("nodeCount") or tree.get("nodeCount") or 0,
            "refresh": refresh_result,
        })
        return jsonify(resolved)
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

