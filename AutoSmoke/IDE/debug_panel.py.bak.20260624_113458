function targetRefreshCurrentBatch(selectId){
  var ids=(targetState.items||[]).map(function(x){return x&&x.targetId;}).filter(Boolean);
  if(!ids.length){targetLoad();return;}
  fetch('/api/target/list?limit=1000').then(function(r){return r.json();}).then(function(d){
    var byId={};
    (d.tasks||[]).forEach(function(x){if(x&&x.targetId){byId[x.targetId]=x;}});
    var next=[];
    ids.forEach(function(id){if(byId[id]){next.push(byId[id]);}});
    targetState.items=next;
    targetRenderListItems(next, next.length, next.length);
    var sid=selectId || (targetState.selected&&targetState.selected.targetId) || '';
    if(sid && next.some(function(x){return x.targetId===sid;})){
      targetSelect(sid);
    }else{
      targetState.selected=null;
      targetRender(null);
    }
  }).catch(function(e){ml('刷新当前批次失败: '+e,'e');});
}
