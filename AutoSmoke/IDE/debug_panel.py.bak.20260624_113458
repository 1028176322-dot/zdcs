def _metadata_candidate_paths(filenames):
    if isinstance(filenames, str):
        filenames = [filenames]
    checked_paths = []
    for fn in filenames:
        for p in _metadata_search_files(fn):
            if p not in checked_paths:
                checked_paths.append(p)
        extras = [
            os.path.join(_CONF_DIR, "metadata", fn),
            os.path.join(_CONF_DIR, "runtime", "ui_tree", fn),
            os.path.join(_CONF_DIR, fn),
            os.path.join(_script_dir, "..", fn),
        ]
        for p in extras:
            if p not in checked_paths:
                checked_paths.append(p)
    return checked_paths


def _read_metadata_payload(filenames, fallback=None):
    checked_paths = _metadata_candidate_paths(filenames)
    for p in checked_paths:
        data = _read_json_if_exists(p)
        if data is not None:
            return data, p
    return fallback, checked_paths[0] if checked_paths else None


def _utcnow():
    return datetime.now().strftime("%Y-%m-%dT%H:%M:%S")


def _coerce_str(value, default=""):
    if value is None:
        return default
    s = str(value).strip()
    return s if s else default


def _coerce_bool(value, default=False):
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        lv = value.strip().lower()
        if lv in ("1", "true", "yes", "on"):
            return True
        if lv in ("0", "false", "no", "off"):
            return False
    return default


