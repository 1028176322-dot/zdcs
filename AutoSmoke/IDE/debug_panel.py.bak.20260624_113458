def _target_recommendation_update_payload(task, result, recommendation_saved):
    candidates = _target_normalize_candidate_list(result.get("candidates", []) if isinstance(result, dict) else [])
    now = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    recommendation_path = recommendation_saved.get("path", "") if isinstance(recommendation_saved, dict) else ""
    recommendation_ref = "recommendation://" + hashlib.sha1(recommendation_path.replace("\\", "/").encode("utf-8")).hexdigest()[:12] if recommendation_path else ""
    payload = {
        "candidates": candidates,
        "matchSummary": {
            "totalCandidates": result.get("totalCandidates", 0) if isinstance(result, dict) else 0,
            "matchedAt": now,
            "recommendationRef": recommendation_ref,
            "riskSummary": (recommendation_saved.get("record", {}) if isinstance(recommendation_saved, dict) else {}).get("riskSummary", {}),
        },
    }
    if candidates:
        top = candidates[0]
        if isinstance(top, dict) and "runtime_path_exact" in (top.get("reasons") or []) and top.get("draftPath"):
            payload["selectedDraftPath"] = top.get("draftPath")
            payload["selectedAt"] = now
    status = _coerce_str(task.get("status")) if isinstance(task, dict) else ""
    if status in _TARGET_STABLE_STATUSES:
        payload["lastRecommendationStatus"] = "candidate_found" if candidates else "no_candidate"
        return payload
    payload["status"] = "candidate_found" if candidates else "blocked"
    payload["blockedReason"] = "" if candidates else "no_candidate"
    return payload


def _target_normalize_candidate_list(raw_candidates):
    candidates = []
    for candidate in raw_candidates or []:
        if not isinstance(candidate, dict):
            continue
        item = dict(candidate)
        binding = _target_formal_binding_for_draft(item.get("draftPath", ""))
        if binding:
            formal_item = binding.get("item", {}) if isinstance(binding.get("item"), dict) else {}
            item["displayName"] = formal_item.get("targetName") or formal_item.get("displayName") or item.get("displayName", "")
            item["semanticId"] = formal_item.get("semanticId") or item.get("semanticId", "")
            item["testId"] = binding.get("testId") or item.get("testId", "")
            item["pageId"] = formal_item.get("pageId") or item.get("pageId", "")
            item["role"] = formal_item.get("role") or item.get("role", "")
            item["elementType"] = formal_item.get("elementType") or item.get("elementType", "")
            item["reviewStatus"] = formal_item.get("reviewStatus") or item.get("reviewStatus", "")
            item["formalRef"] = binding.get("formalRef", "")
            item["evidenceRef"] = binding.get("evidenceRef", "")
            risks = list(item.get("risks") or [])
            if "candidate_already_confirmed" not in risks:
                risks.insert(0, "candidate_already_confirmed")
            item["risks"] = risks
        candidates.append(item)
    return candidates


