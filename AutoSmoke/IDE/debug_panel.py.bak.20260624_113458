def _find_latest_game_run_dir(screenshots_dir: str) -> str:
    """查找最新的 run_* 目录"""
    try:
        run_dirs = sorted(
            [d for d in os.listdir(screenshots_dir) if d.startswith("run_")],
            reverse=True
        )
        if run_dirs:
            return os.path.join(screenshots_dir, run_dirs[0])
    except Exception:
        pass
    return ""

def _find_latest_game_content_screenshot(screenshots_dir: str) -> str:
    """查找最新的 run_*/game_content_*.png"""
    try:
        candidates = []
        for d in os.listdir(screenshots_dir):
            run_dir = os.path.join(screenshots_dir, d)
            if not d.startswith("run_") or not os.path.isdir(run_dir):
                continue
            for f in os.listdir(run_dir):
                if f.startswith("game_content_") and f.endswith(".png"):
                    p = os.path.join(run_dir, f)
                    candidates.append((os.path.getmtime(p), p))
        if candidates:
            return sorted(candidates, reverse=True)[0][1]
    except Exception:
        pass
    return ""

def _find_latest_unity_cap_screenshot(screenshots_dir: str):
    """查找最新的 Unity 直出 run_*/cap_*.png"""
    try:
        candidates = []
        for d in os.listdir(screenshots_dir):
            run_dir = os.path.join(screenshots_dir, d)
            if not d.startswith("run_") or not os.path.isdir(run_dir):
                continue
            for f in os.listdir(run_dir):
                if f.startswith("cap_") and f.endswith(".png"):
                    p = os.path.join(run_dir, f)
                    candidates.append((os.path.getmtime(p), p, run_dir))
        if candidates:
            _, p, run_dir = sorted(candidates, reverse=True)[0]
            return p, run_dir
    except Exception:
        pass
    return "", ""

def _find_latest_game_view_screenshot(screenshots_dir: str) -> str:
    """查找最新的 run_*/game_view_*.png"""
    run_dir = _find_latest_game_run_dir(screenshots_dir)
    if not run_dir:
        return ""
    try:
        files = sorted(
            [f for f in os.listdir(run_dir) if f.startswith("game_view_") and f.endswith(".png")],
            reverse=True
        )
        if files:
            return os.path.join(run_dir, files[0]), run_dir
    except Exception:
        pass
    return "", ""

def _screen_rect_to_game_content(screen_rect, run_dir: str):
    """将 screenRect（monitor/design 坐标）转为 game_content.png 坐标系"""
    metadata_path = os.path.join(run_dir, sorted([f for f in os.listdir(run_dir) if f.startswith("metadata_")]).pop())
    try:
        with open(metadata_path, "r", encoding="utf-8") as f:
            meta = json.load(f)
    except Exception:
        return None

    gv = meta.get("game_view_coords", {})
    gc = meta.get("game_content_rect", {})

    if not isinstance(screen_rect, (list, tuple)) or len(screen_rect) < 4:
        return None

    x1, y1, x2, y2 = screen_rect[:4]

    # 试图判断坐标空间：如果数值 > 2000，可能是设计分辨率(1170x2532)
    # 如果数值较小(100-1200)，可能是 monitor 坐标
    # 统一先转成 game_view 相对坐标
    gv_left = gv.get("left", 0)
    gv_top = gv.get("top", 0)
    gv_w = gv.get("width", 1)
    gv_h = gv.get("height", 1)
    design_w = meta.get("game_resolution", {}).get("width", 1170)
    design_h = meta.get("game_resolution", {}).get("height", 2532)

    max_coord = max(abs(x1), abs(y1), abs(x2), abs(y2))
    # 设计分辨率坐标（Unity 直出/运行态推荐坐标系）→ game_content 原始截图
    if max_coord <= max(design_w, design_h) * 1.05:
        content_w = gc.get("width", 1) or 1
        content_h = gc.get("height", 1) or 1
        sx = content_w / max(design_w, 1)
        sy = content_h / max(design_h, 1)
        return [x1 * sx, y1 * sy, x2 * sx, y2 * sy]

    # monitor 坐标 → game_view 相对坐标
    if x1 > max(design_w, design_h) * 1.5 or y1 > max(design_w, design_h) * 1.5:
        view_x1 = x1 - gv_left
        view_y1 = y1 - gv_top
        view_x2 = x2 - gv_left
        view_y2 = y2 - gv_top
    else:
        view_x1, view_y1, view_x2, view_y2 = x1, y1, x2, y2

    # game_view → game_content
    gc_left = gc.get("left", 0)
    gc_top = gc.get("top", 0)
    content_x1 = view_x1 - gc_left
    content_y1 = view_y1 - gc_top
    content_x2 = view_x2 - gc_left
    content_y2 = view_y2 - gc_top

    return [content_x1, content_y1, content_x2, content_y2]

@app.route("/api/mapping/highlight", methods=["POST"])
def api_mapping_highlight():
    """高亮匹配元素（支持 draftPath + normalize_rect + is_valid_rect）"""
    try:
        data = request.get_json() or {}
        draft_path = data.get("draftPath", "")
        screen_rect = data.get("screenRect", [])
        screenshot_path = data.get("screenshotPath", "")
        rect_source = "param"

        # 如果传了 draftPath，自动从映射数据中读取 screenRect
        if draft_path and not screen_rect:
            from 元数据.element_mapping import ElementMappingManager
            mgr = ElementMappingManager()
            mgr.load()
            m = mgr.get(draft_path)
            if m:
                # 只使用顶层 screenRect（已通过 is_valid_rect 校验后才写入的）
                # 不直接使用 runtimeMatch.screenRect（可能包含无效负坐标）
                sr = m.get("screenRect", [])
                if sr and len(sr) >= 4:
                    screen_rect = sr
                    rect_source = "mapping.screenRect"

        if not screenshot_path:
            try:
                ok_cap, cap = _prepare_invoke_api("get", "/api/capture")
                if ok_cap and isinstance(cap, dict):
                    screenshot_path = cap.get("game_content_path") or cap.get("game_view_path") or ""
                    if screenshot_path:
                        rect_source = rect_source + "→fresh_capture"
            except Exception:
                pass

        if not screenshot_path:
            # 实时截图不可用时才回退历史截图目录。
            screenshots_dir = os.path.join(_CONF_DIR, "screenshots")
            cap_path, cap_run_dir = _find_latest_unity_cap_screenshot(screenshots_dir)
            if cap_path:
                screenshot_path = cap_path
                rect_source = rect_source + "→unity_cap"
            else:
                run_dir = _find_latest_game_run_dir(screenshots_dir)
                content_path = _find_latest_game_content_screenshot(screenshots_dir)
                if content_path:
                    run_dir = os.path.dirname(content_path)
                    screenshot_path = content_path
                    # 坐标转换为 game_content 坐标系
                    if screen_rect and len(screen_rect) >= 4 and run_dir:
                        conv = _screen_rect_to_game_content(screen_rect, run_dir)
                        if conv:
                            screen_rect = conv
                            rect_source = rect_source + "→game_content"
            if not screenshot_path:
                screenshot_path = os.path.join(screenshots_dir, "mapping_review", "current_page.png")

        if not os.path.exists(screenshot_path):
            return jsonify({"success": False, "error": "截图不存在"})

        from PIL import Image, ImageDraw, ImageFont
        from 元数据.runtime_matcher import normalize_rect, is_valid_rect
        img = Image.open(screenshot_path)

        # 统一坐标 + 校验
        nr = normalize_rect(screen_rect) if screen_rect else None
        if not nr:
            return jsonify({
                "success": False,
                "error": "invalid_rect",
                "reason": "无法解析 screenRect",
                "screenRect": screen_rect,
                "imageSize": [img.width, img.height],
                "rectSource": rect_source,
            })
        if nr:
            try:
                rx = float(nr.get("x", 0))
                ry = float(nr.get("y", 0))
                rw = float(nr.get("width", 0))
                rh = float(nr.get("height", 0))
                x1 = max(0, min(img.width, rx))
                y1 = max(0, min(img.height, ry))
                x2 = max(0, min(img.width, rx + rw))
                y2 = max(0, min(img.height, ry + rh))
                if x2 - x1 > 4 and y2 - y1 > 4:
                    nr = {"x": int(round(x1)), "y": int(round(y1)), "width": int(round(x2 - x1)), "height": int(round(y2 - y1))}
                    if "clipped" not in rect_source:
                        rect_source = rect_source + "→clipped"
            except Exception:
                pass
        if not is_valid_rect(nr, img.width, img.height):
            return jsonify({
                "success": False,
                "error": "invalid_rect",
                "reason": f"坐标无效: x={nr['x']} y={nr['y']} w={nr['width']} h={nr['height']}（必须>4像素且在图片范围内）",
                "screenRect": screen_rect,
                "normalizedRect": nr,
                "imageSize": [img.width, img.height],
                "rectSource": rect_source,
            })

        # 绘制高亮：暗色遮罩 + 目标区域亮显 + 红白边框 + 编号
        x, y, w, h = nr["x"], nr["y"], nr["width"], nr["height"]

        # 复制原图，加半透明暗色遮罩
        overlay = img.copy()
        dark = Image.new("RGBA", overlay.size, (0, 0, 0, 100))  # 半透明黑
        overlay = Image.alpha_composite(overlay.convert("RGBA"), dark)

        # 把目标区域恢复为原图
        crop = img.crop((x, y, x + w, y + h))
        overlay.paste(crop, (x, y))

        # 画红白双层边框
        draw = ImageDraw.Draw(overlay)
        # 外圈红色 6px
        draw.rectangle([x - 3, y - 3, x + w + 3, y + h + 3], outline="#FF0000", width=6)
        # 内圈白色 2px
        draw.rectangle([x - 1, y - 1, x + w + 1, y + h + 1], outline="#FFFFFF", width=2)

        # 编号标签
        label = "1"
        try:
            font = ImageFont.truetype("arial.ttf", 18)
        except Exception:
            font = ImageFont.load_default()
        bbox = draw.textbbox((0, 0), label, font=font)
        lw = bbox[2] - bbox[0] + 8
        lh = bbox[3] - bbox[1] + 4
        lx = x - 3
        ly = y - lh - 3
        if ly < 0:
            ly = y + h + 3
        draw.rectangle([lx, ly, lx + lw, ly + lh], fill="#FF0000")
        draw.text((lx + 4, ly + 1), label, fill="#FFFFFF", font=font)

        os.makedirs(os.path.join(_CONF_DIR, "screenshots", "mapping_review"), exist_ok=True)
        highlight_name = datetime.now().strftime("%Y%m%d_%H%M%S") + "_highlight.png"
        highlight_path = os.path.join(_CONF_DIR, "screenshots", "mapping_review", highlight_name)
        highlight_ref = _autosmoke_relpath(highlight_path)
        overlay.save(highlight_path)

        if draft_path:
            try:
                from 元数据.element_mapping import ElementMappingManager
                mgr = ElementMappingManager()
                mgr.load()
                m = mgr.get(draft_path)
                if m:
                    m["highlightImage"] = highlight_ref
                    m["screenshotRef"] = _autosmoke_relpath(screenshot_path)
                    m["hasScreenshot"] = True
                    m["highlightRect"] = [x, y, x + w, y + h]
                    m["highlightGeneratedAt"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
                    mgr.upsert(draft_path, m)
                    mgr.save()
            except Exception:
                pass

        return jsonify({
            "success": True,
            "highlightImage": highlight_ref,
            "normalizedRect": nr,
            "screenRectUsed": [x, y, x + w, y + h],
            "imageSize": [img.width, img.height],
            "rectSource": rect_source,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


