  fetch('/api/mapping/semantic/parse',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({description:desc,context:{path:rp,pageId:pageId,currentTestId:currentTestId}})})
    .then(function(r){return r.json();}).then(function(d){
      if(!d||!d.success){semanticFixSetInfo((d&&d.error)||'解析失败','isErr');return;}
