function targetRunNext(){
  var t=targetState.selected;if(!t)return;
  var s=t.status||'pending_match';
  var assertOnly=(t.interactionType==='assert_visible'||t.role==='visual_assert'||(t.assertion&&t.assertion.clickRequired===false));
  if(t.collection&&t.collection.type==='dynamic_list'){
    if(s==='collection_confirmed')return targetSetResult('动态列表规则已确认',true);
    return targetCall('/api/target/confirm_collection','规则确认');
  }
  if(s==='blocked'&&t.selectedDraftPath&&t.runtimeHint)return targetCall('/api/target/highlight','生成高亮');
  if(s==='blocked'&&t.selectedDraftPath)return targetCall('/api/target/runtime_match','运行匹配');
  if(s==='pending_match'||s==='blocked')return targetMatchCandidates();
  if(s==='candidate_found'&&t.runtimeHint)return targetCall('/api/target/highlight','生成高亮');
  if(s==='candidate_found')return targetCall('/api/target/runtime_match','运行匹配');
  if(s==='runtime_matched')return targetCall('/api/target/highlight','生成高亮');
  if(s==='highlight_generated')return targetCall('/api/target/visual_confirm','视觉确认');
  if(assertOnly&&s==='visual_confirmed')return targetSetResult((t.formalRef||t.evidenceRef)?'检查目标已视觉确认，已生成 formalRef/evidenceRef':'检查目标已视觉确认；如未生成引用，请重新点视觉确认',!!(t.formalRef||t.evidenceRef));
  if(s==='visual_confirmed')return targetCall('/api/target/test_click','测试点击');
  targetSetResult('当前状态无需下一步',true);
}
