def _read_current_ui_elements():
    """读取当前UI元素列表，用于映射缺失检查。

    优先读取 current_ui.json，并兼容 MetadataReader 兜底。
    仅保留可点击元素，避免无效干扰。
    """
    elements = []
    raw = _read_metadata_json("current_ui.json", fallback=None)
    if isinstance(raw, dict):
        raw_elements = raw.get("elements", [])
        if isinstance(raw_elements, list):
            elements = raw_elements
    if not elements:
        try:
            from 元数据.metadata_reader import MetadataReader
            reader = MetadataReader()
            elements = reader.get_elements() or []
        except Exception:
            elements = []

    normalized = []
    for item in elements:
        if not isinstance(item, dict):
            continue
        if _target_node_is_debug_overlay(item):
            continue
        if not item.get("clickable", False):
            continue
        path = item.get("path", item.get("elementPath", item.get("runtimePath", "")))
        if not path:
            continue
        normalized.append({
            "path": path,
            "name": item.get("name", item.get("nodeName", "")),
            "text": item.get("text", ""),
            "type": item.get("type", item.get("componentType", "")),
            "screenRect": item.get("screenRect", []),
            "canvas": item.get("canvas", item.get("pageId", "")),
            "source": "runtime",
        })
    return normalized


