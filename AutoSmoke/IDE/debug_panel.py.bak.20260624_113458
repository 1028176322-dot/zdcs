@app.route("/api/target/test_click", methods=["POST"])
def api_target_test_click():
    try:
        payload = request.get_json() or {}
        target_id = payload.get("targetId", "")
        catalog, task, draft_path, error = _target_selected_draft(target_id)
        if error:
            return jsonify(error)
        runtime_hint = task.get("runtimeHint", {}) if isinstance(task.get("runtimeHint", {}), dict) else {}
        runtime_hint = _target_resolve_runtime_hint(runtime_hint)
        resolved_runtime_path = ""
        if runtime_hint:
            resolved_runtime_path = runtime_hint.get("resolvedRuntimePath") or runtime_hint.get("clickTargetNode") or runtime_hint.get("runtimePath") or ""
        if runtime_hint:
            try:
                if not resolved_runtime_path:
                    raise ValueError("runtime_path_missing")
            except Exception as sync_error:
                return jsonify({"success": False, "error": "target_click_prepare_failed", "detail": str(sync_error)})
        click_timeout = float(payload.get("clickTimeoutSec", 4.5) or 4.5)
        if resolved_runtime_path:
            if _target_node_is_debug_overlay(resolved_runtime_path):
                return jsonify({
                    "success": False,
                    "targetId": target_id,
                    "status": "blocked",
                    "error": "debug_overlay_target_blocked",
                    "click": {
                        "draftPath": draft_path,
                        "success": False,
                        "error": "debug_overlay_target_blocked",
                        "detail": {"runtimePath": resolved_runtime_path},
                    },
                })
            debug_block = _target_rect_center_hits_debug_overlay(runtime_hint.get("screenRect", []))
            if debug_block:
                success, result = _unity_bridge_test_click(
                    resolved_runtime_path,
                    runtime_hint.get("instanceId", 0),
                    timeout_sec=max(click_timeout, 8.0),
                    bypass_debug_overlay=True,
                )
                detail = result.get("detail", {}) if isinstance(result.get("detail"), dict) else {}
                result["detail"] = {
                    **detail,
                    "debugOverlayBlock": debug_block,
                    "debugOverlayBypassRequested": True,
                }
            else:
                success, result = _unity_bridge_test_click(resolved_runtime_path, runtime_hint.get("instanceId", 0), timeout_sec=click_timeout)
            debug_hit = _target_click_result_hits_debug_overlay(result)
            result_detail = result.get("detail", {}) if isinstance(result.get("detail"), dict) else {}
            if debug_hit and not result_detail.get("debugOverlayBypassed") and not _target_node_is_debug_overlay(resolved_runtime_path):
                success = False
                result = {
                    **result,
                    "success": False,
                    "error": "debug_overlay_received_click",
                    "detail": {**(result.get("detail", {}) if isinstance(result.get("detail"), dict) else {}), "debugOverlayBlock": debug_hit},
                }
            if (
                not success
                and (result.get("error") == "TARGET_NOT_VISIBLE" or result.get("detail", {}).get("clickResult") == "TARGET_NOT_VISIBLE")
                and runtime_hint.get("screenRect")
            ):
                fallback_success, fallback_result = _target_coordinate_fallback_click(
                    runtime_hint.get("screenRect"),
                    reason="runtime_visible_but_injector_precheck_not_visible",
                )
                if fallback_success:
                    success = True
                    result = fallback_result
                else:
                    result.setdefault("detail", {})["coordinateFallback"] = fallback_result
            ok = True
        else:
            ok, result = _prepare_invoke_api("post", _target_mapping_api_path(draft_path, "/test_click"), {
                "disableCoordinateFallback": True,
                "clickTimeoutSec": click_timeout,
            })
            success = bool(ok and result.get("success"))
        evidence = {
            "draftPath": draft_path,
            "success": success,
            "clickMethod": result.get("clickMethod", ""),
            "detail": result.get("detail", {}),
            "error": result.get("error", ""),
        }
        status = "click_confirmed" if success else "blocked"
        confirm_result = {}
        confirmed_test_id = ""
        if success:
            confirm_result = _target_confirm_test_id(target_id, task, draft_path, evidence)
            if confirm_result.get("success") is False:
                evidence["success"] = False
                evidence["error"] = confirm_result.get("error", "target_confirm_failed")
                evidence["confirmBlocked"] = confirm_result
                catalog.record_evidence(target_id, "click", evidence, status="visual_confirmed")
                catalog.update_task(target_id, {
                    "blockedReason": confirm_result.get("error", "target_confirm_failed"),
                    "lastConfirmBlock": confirm_result,
                })
                return jsonify({
                    "success": False,
                    "targetId": target_id,
                    "status": "visual_confirmed",
                    "error": confirm_result.get("error", "target_confirm_failed"),
                    "detail": confirm_result,
                    "click": evidence,
                })
            confirmed_test_id = confirm_result.get("confirmedTestId", "")
            evidence["confirmedTestId"] = confirmed_test_id
            evidence["formalRef"] = confirm_result.get("formalRef", "")
            evidence["evidenceRef"] = confirm_result.get("evidenceRef", "")
        catalog.record_evidence(target_id, "click", evidence, status=status)
        if success:
            confirmed_display_name = _confirmed_target_display_name({
                **task,
                "status": "click_confirmed",
                "confirmedTestId": confirmed_test_id,
                "selectedDraftPath": draft_path,
            })
            click_updates = {
                "status": "click_confirmed",
                "targetName": confirmed_display_name or task.get("targetName", ""),
                "confirmedTestId": confirmed_test_id,
                "testIdSource": "business_semantic_runtime_click_confirmed",
                "formalRef": confirm_result.get("formalRef", ""),
                "evidenceRef": confirm_result.get("evidenceRef", ""),
                "blockedReason": "",
            }
            legacy_paths = {
                k: v for k, v in {
                    "legacyFormalPath": confirm_result.get("legacyFormalPath", ""),
                    "legacyEvidencePath": confirm_result.get("legacyEvidencePath", ""),
                }.items() if v
            }
            if legacy_paths:
                click_updates["legacyPaths"] = legacy_paths
            catalog.update_task(target_id, click_updates)
        if not success:
            click_reason = result.get("error") or result.get("detail", {}).get("clickResult") or "click_failed"
            conditional, condition_detail = _target_condition_not_applicable(task, click_reason)
            if conditional:
                catalog.update_task(target_id, {"status": "not_applicable", "blockedReason": condition_detail["reason"], "availabilityEvidence": condition_detail})
                status = "not_applicable"
                return jsonify({"success": True, "targetId": target_id, "status": status, "availability": condition_detail, "click": evidence})
            catalog.update_task(target_id, {"blockedReason": click_reason})
        return jsonify({"success": success, "targetId": target_id, "status": status, "confirmedTestId": confirmed_test_id, "click": evidence})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


