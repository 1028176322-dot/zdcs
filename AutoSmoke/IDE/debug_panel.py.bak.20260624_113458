        if not isinstance(item, dict):
            continue
        if item.get("path") == path or item.get("draftPath") == path or item.get("elementPath") == path:
            return item
    return None


def _formal_records():
    try:
        store = MappingStore(project_root=_project_root)
        if store.has_store():
            out = {}
            formal_files = list(store.formal_page_dir.glob("*.json")) + list(store.formal_global_dir.glob("*.json"))
            for page_file in sorted(formal_files):
                raw = _read_json_if_exists(str(page_file)) or {}
                mappings = raw.get("mappings") if isinstance(raw, dict) else {}
                if isinstance(mappings, dict):
                    for key, item in mappings.items():
                        if isinstance(item, dict):
                            out[key] = item
            if out:
                return out
    except Exception:
        pass
    project_path = os.path.join(_CONF_DIR, "metadata", "element_mapping_formal.json")
    raw = _read_json_if_exists(project_path)
    if raw is None:
        raw, _ = _read_metadata_payload("element_mapping_formal.json", fallback=None)
    if isinstance(raw, dict):
        mappings = raw.get("mappings")
        if isinstance(mappings, dict):
            return mappings
        if isinstance(mappings, list):
            out = {}
            for item in mappings:
                if isinstance(item, dict):
                    tid = _coerce_str(item.get("testId"))
                    if tid:
                        out[tid] = item
            return out
    return {}


