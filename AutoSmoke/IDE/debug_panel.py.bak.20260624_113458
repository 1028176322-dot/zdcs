def _mapping_gate_for_steps(steps, case_id=""):
    from 用例层.case_step_parser import CaseStepParser
    parser = CaseStepParser()
    formal = _formal_records()
    evidence = _mapping_evidence_records()
    allowed_click_status = {"click_confirmed", "case_verified", "manual_confirmed"}
    allowed_assert_status = {"visual_confirmed", "click_confirmed", "case_verified", "manual_confirmed"}
    checks = []
    blockers = []
    for index, step_text in enumerate(steps):
        parsed = parser.parse(str(step_text or ""))
        target = parsed.get("target") if isinstance(parsed, dict) else None
        if not isinstance(target, dict) or target.get("type") != "testId":
            continue
        test_id = str(target.get("value") or "").strip()
        entry = formal.get(test_id)
        check = {
            "stepIndex": index,
            "stepText": step_text,
            "testId": test_id,
            "status": "passed",
            "checks": [],
        }
        if not isinstance(entry, dict):
            repair_id = _create_mapping_repair_task("formal_mapping_missing", str(step_text), test_id, case_id)
            check["status"] = "blocked"
            check["checks"].append({"name": "formal_exists", "passed": False, "repairTargetId": repair_id})
            blockers.append(check)
            checks.append(check)
            continue
        review_status = str(entry.get("reviewStatus") or "")
        allowed = allowed_click_status if parsed.get("action") in ("click", "long_press", "input") else allowed_assert_status
        status_ok = review_status in allowed
        check["checks"].append({"name": "reviewStatus", "passed": status_ok, "value": review_status, "required": sorted(allowed)})
        evidence_ref = str(entry.get("evidenceRef") or f"EVIDENCE_{test_id}")
        evidence_item = evidence.get(evidence_ref)
        evidence_ok = isinstance(evidence_item, dict)
        check["checks"].append({"name": "evidenceRef", "passed": evidence_ok, "value": evidence_ref})
        locator = entry.get("locator") if isinstance(entry.get("locator"), dict) else {}
        locator_ok = bool(locator.get("type") and locator.get("value"))
        check["checks"].append({"name": "locator", "passed": locator_ok, "value": locator})
        if isinstance(evidence_item, dict):
            revalidate_status = str(entry.get("revalidateStatus") or evidence_item.get("revalidateStatus") or "")
        else:
            revalidate_status = str(entry.get("revalidateStatus") or "")
        stale = revalidate_status in {"stale", "failed"}
        check["checks"].append({"name": "versionRevalidation", "passed": not stale, "value": revalidate_status or "not_required"})
        if not (status_ok and evidence_ok and locator_ok and not stale):
            repair_id = _create_mapping_repair_task("mapping_gate_failed", str(step_text), test_id, case_id)
            check["status"] = "blocked"
            check["repairTargetId"] = repair_id
            blockers.append(check)
        checks.append(check)
    return {
        "passed": len(blockers) == 0,
        "checks": checks,
        "blockers": blockers,
    }


