@app.route("/api/target/confirm_collection", methods=["POST"])
def api_target_confirm_collection():
    try:
        payload = request.get_json() or {}
        target_id = _coerce_str(payload.get("targetId"))
        catalog = _target_catalog()
        task = catalog.get_task(target_id)
        if not task:
            return jsonify({"success": False, "error": "target_not_found", "targetId": target_id})
        collection = task.get("collection") if isinstance(task.get("collection"), dict) else {}
        if collection.get("type") != "dynamic_list":
            return jsonify({"success": False, "error": "target_is_not_dynamic_collection", "targetId": target_id})
        required = ["containerPath", "itemPattern", "semanticPattern"]
        missing = [key for key in required if not _coerce_str(collection.get(key))]
        if missing:
            return jsonify({"success": False, "error": "dynamic_collection_rule_incomplete", "missing": missing, "targetId": target_id})
        now = _utcnow()
        evidence = {
            "confirmedAt": now,
            "collectionId": collection.get("collectionId") or target_id,
            "containerPath": collection.get("containerPath", ""),
            "itemPattern": collection.get("itemPattern", ""),
            "semanticPattern": collection.get("semanticPattern", ""),
            "targetNamePattern": collection.get("targetNamePattern", ""),
            "visibleIndices": collection.get("visibleIndices", []),
            "requiresScrollForMissingIndex": bool(collection.get("requiresScrollForMissingIndex")),
        }
        saved = catalog.record_evidence(target_id, "collectionRule", evidence, status="collection_confirmed")
        formal_key = _coerce_str(task.get("testId"), _coerce_str(task.get("confirmedTestId")))
        formal_updated = False
        if formal_key:
            formal = _read_formal_records()
            entry = formal.get(formal_key) if isinstance(formal.get(formal_key), dict) else None
            if entry is not None:
                entry["reviewStatus"] = "collection_confirmed"
                entry["revalidateStatus"] = "ok"
                entry["collectionConfirmedAt"] = now
                entry["collectionEvidence"] = evidence
                _write_formal_records(formal)
                formal_updated = True
        return jsonify({
            "success": bool(saved.get("success")),
            "targetId": target_id,
            "status": "collection_confirmed",
            "task": saved.get("task", {}),
            "formalUpdated": formal_updated,
            "collection": evidence,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


@app.route("/api/target/runtime_match", methods=["POST"])
def api_target_runtime_match():
    try:
        payload = request.get_json() or {}
        target_id = payload.get("targetId", "")
        catalog, task, draft_path, error = _target_selected_draft(target_id)
        if error:
            return jsonify(error)
        ok, result = _prepare_invoke_api("post", "/api/mapping/runtime_match", {
            "draftPath": draft_path,
            "pageId": "",
            "includeResults": True,
        })
        if not ok or not result.get("success"):
            conditional, condition_detail = _target_condition_not_applicable(task, result.get("error", "runtime_match_failed"))
            if conditional:
                catalog.update_task(target_id, {"status": "not_applicable", "blockedReason": condition_detail["reason"], "availabilityEvidence": condition_detail})
                return jsonify({"success": True, "targetId": target_id, "status": "not_applicable", "availability": condition_detail})
            catalog.update_task(target_id, {"status": "blocked", "blockedReason": result.get("error", "runtime_match_failed")})
            return jsonify({"success": False, "error": result.get("error", "runtime_match_failed"), "detail": result})
        matched_item = {}
        for item in result.get("results", []):
            if item.get("draftPath") == draft_path:
                matched_item = item
                break
        match_score = float(matched_item.get("matchScore", 0) or 0)
        matched = bool(matched_item.get("matched")) and match_score >= 0.85
        status = "runtime_matched" if matched else "blocked"
        evidence = {
            "draftPath": draft_path,
            "matched": matched,
            "matchScore": match_score,
            "runtimePath": matched_item.get("runtimePath", ""),
            "screenRect": matched_item.get("screenRect", []),
            "reason": matched_item.get("matchFailReason", "") or ("" if matched else "low_confidence_runtime_match"),
        }
        catalog.record_evidence(target_id, "runtime", evidence, status=status)
        if not matched:
            conditional, condition_detail = _target_condition_not_applicable(task, evidence["reason"] or "runtime_node_missing")
            if conditional:
                catalog.update_task(target_id, {"status": "not_applicable", "blockedReason": condition_detail["reason"], "availabilityEvidence": condition_detail})
                return jsonify({"success": True, "targetId": target_id, "status": "not_applicable", "runtime": evidence, "availability": condition_detail})
            catalog.update_task(target_id, {"blockedReason": evidence["reason"] or "runtime_node_missing"})
        return jsonify({"success": True, "targetId": target_id, "status": status, "runtime": evidence, "summary": {k: v for k, v in result.items() if k != "results"}})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


