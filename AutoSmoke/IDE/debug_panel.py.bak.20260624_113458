function targetNextText(t){
  var s=t.status||'pending_match';
  var assertOnly=(t.interactionType==='assert_visible'||t.role==='visual_assert'||(t.assertion&&t.assertion.clickRequired===false));
  if(t.collection&&t.collection.type==='dynamic_list'){
    return s==='collection_confirmed'?'规则已确认':'规则确认';
  }
  if(assertOnly&&s==='visual_confirmed')return '已确认';
  if(s==='pending_match')return '匹配候选';
  if(s==='candidate_found'&&t.runtimeHint)return '生成高亮';
  if(s==='candidate_found')return '运行匹配';
  if(s==='runtime_matched')return '生成高亮';
  if(s==='highlight_generated')return '视觉确认';
  if(s==='visual_confirmed')return '测试点击';
  if(s==='click_confirmed')return '已可用';
  if(s==='not_applicable')return '条件不满足';
  if(s==='blocked'&&t.selectedDraftPath&&t.runtimeHint)return '生成高亮';
