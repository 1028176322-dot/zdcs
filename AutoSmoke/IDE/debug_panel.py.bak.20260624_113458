        "assertion": task.get("assertion", {}),
    }
    evidence_item = {
        "evidenceRef": f"EVIDENCE_{confirmed_test_id}",
        "testId": confirmed_test_id,
        "semanticId": semantic_id,
        "targetName": formal_item["targetName"],
        "displayName": formal_item["displayName"],
        "pageId": page_id,
        "role": formal_item["role"],
        "elementType": formal_item["elementType"],
        "structure": {"path": draft_path, "pageId": page_id, "elementType": formal_item["elementType"]},
