def _target_resolve_runtime_hint(runtime_hint):
    runtime_hint = runtime_hint if isinstance(runtime_hint, dict) else {}
    runtime_path = runtime_hint.get("runtimePath", "")
    if not runtime_path:
        return runtime_hint
    data = _read_json_if_exists(os.path.join(_RUNTIME_METADATA_DIR, "runtime_ui_tree_current.json")) or {}
    nodes = data.get("nodes", []) if isinstance(data, dict) else []
    candidates = []
    for node in nodes:
        if not isinstance(node, dict):
            continue
        if _target_node_is_debug_overlay(node):
            continue
        if node.get("runtimePath") == runtime_path or node.get("runtimePath", "").endswith("/" + runtime_path):
            candidates.append(node)
    if not candidates:
        return runtime_hint
    candidates.sort(key=lambda n: (bool(n.get("effectiveClickable")), len(n.get("runtimePath", ""))), reverse=True)
    node = candidates[0]
    merged = dict(runtime_hint)
    for key in ("clickTargetNode", "instanceId", "screenRect", "ownerPageId", "pageId", "runtimePath"):
        if node.get(key) not in (None, "", []):
            merged[key] = node.get(key)
    if node.get("clickTargetNode"):
        merged["resolvedRuntimePath"] = node.get("clickTargetNode")
    return merged


def _target_debug_overlay_text(value):
    if isinstance(value, dict):
        chunks = [
            value.get("runtimePath"),
            value.get("path"),
            value.get("prefabPath"),
            value.get("prefabNodePath"),
            value.get("pageId"),
            value.get("ownerPageId"),
            value.get("pageName"),
            value.get("nodeName"),
            value.get("displayName"),
            value.get("text"),
            value.get("chineseDescription"),
        ]
        text = " ".join(_coerce_str(x) for x in chunks)
    else:
        text = _coerce_str(value)
    return text.lower().replace("\\", "/")


def _target_node_is_debug_overlay(node):
    text = _target_debug_overlay_text(node)
    return any(token in text for token in (
        "ui_debuggraphic",
        "graphicdebug",
        "framework/debug",
        "/debug/",
        "debuggraphic",
        "uigmwindow",
        "gmwindow",
        "uiroot2/uigmwindow",
        "/btnshow",
        "btnshow/text",
    ))


def _target_rect_center(rect):
    if not isinstance(rect, list) or len(rect) < 4:
        return None
    try:
        x1, y1, x2, y2 = [float(v) for v in rect[:4]]
    except Exception:
        return None
    if x2 <= x1 or y2 <= y1:
        return None
    return ((x1 + x2) / 2.0, (y1 + y2) / 2.0)


def _target_point_in_rect(point, rect, padding=0):
    if point is None or not isinstance(rect, list) or len(rect) < 4:
        return False
    try:
        x1, y1, x2, y2 = [float(v) for v in rect[:4]]
        x, y = point
    except Exception:
        return False
    return (x1 - padding) <= x <= (x2 + padding) and (y1 - padding) <= y <= (y2 + padding)


def _target_debug_overlay_rects():
    # Debug/GM buttons are fixed overlays in dev builds.
    # Some runtime exports omit its rect, so keep a conservative reserved zone.
    rects = [
        [1040, 2380, 1170, 2532],
        [960, 0, 1170, 180],
    ]
    for filename in ("runtime_ui_tree_current.json", "current_ui.json"):
        data = _read_json_if_exists(os.path.join(_RUNTIME_METADATA_DIR, filename)) or _read_metadata_json(filename, fallback={})
        if not isinstance(data, dict):
            continue
        nodes = data.get("nodes")
        if not isinstance(nodes, list):
            nodes = data.get("elements", [])
        for node in nodes if isinstance(nodes, list) else []:
            if not isinstance(node, dict) or not _target_node_is_debug_overlay(node):
                continue
            rect = node.get("screenRect") or node.get("rect")
            if isinstance(rect, list) and len(rect) >= 4:
                rects.append(rect[:4])
    return rects


def _target_rect_center_hits_debug_overlay(rect):
    point = _target_rect_center(rect)
    if point is None:
        return {}
    for debug_rect in _target_debug_overlay_rects():
        if _target_point_in_rect(point, debug_rect, padding=4):
            return {
                "blocked": True,
                "reason": "debug_overlay_coordinate_collision",
                "screenPoint": [point[0], point[1]],
                "targetScreenRect": rect,
                "debugScreenRect": debug_rect,
                "hint": "Do not use coordinate fallback in the fixed Debug overlay area; use runtimePath click or hide Debug overlay first.",
            }
    return {}


def _target_click_result_hits_debug_overlay(result):
    detail = result.get("detail", {}) if isinstance(result, dict) else {}
    fields = [
        detail.get("hitRuntimePath"),
        detail.get("eventReceiver"),
        detail.get("targetGameObject"),
        detail.get("dispatchTarget"),
        detail.get("message"),
    ]
    hit = next((value for value in fields if _target_node_is_debug_overlay(value)), "")
    if not hit:
        return {}
    return {
        "blocked": True,
        "reason": "debug_overlay_received_click",
        "hitRuntimePath": hit,
        "hint": "The click was received by the fixed Debug overlay, so it cannot confirm a business target.",
    }


def _unity_bridge_test_click(runtime_path, instance_id=0, timeout_sec=4.5, bypass_debug_overlay=False):
    runtime_path = _coerce_str(runtime_path)
    if not runtime_path:
        return False, {"error": "runtime_path_empty", "detail": {"reason": "runtimePath is empty"}}
    try:
        timeout_sec = float(timeout_sec or 4.5)
    except Exception:
        timeout_sec = 4.5
    timeout_sec = max(0.5, min(timeout_sec, 8.0))
    bridge_dir = os.path.join(_CONF_DIR, "runtime", "bridge")
    request_id = "click_" + datetime.now().strftime("%Y%m%d_%H%M%S_%f")
    req_path = os.path.join(bridge_dir, "requests", f"test_click_{request_id}.json")
    resp_path = os.path.join(bridge_dir, "responses", request_id + ".json")
    done_path = os.path.join(bridge_dir, "responses", request_id + ".done")
    req_data = {
        "requestId": request_id,
        "type": "test_click_element",
        "createdAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
        "payload": {
            "runtimePath": runtime_path,
            "instanceId": int(instance_id or 0),
            "method": "unity_event_system",
            "verifyAfterClick": True,
            "bypassDebugOverlay": bool(bypass_debug_overlay),
        },
    }
    os.makedirs(os.path.dirname(req_path), exist_ok=True)
    os.makedirs(os.path.dirname(resp_path), exist_ok=True)
    with open(req_path, "w", encoding="utf-8") as f:
        json.dump(req_data, f, ensure_ascii=False)

    injector_result = Path.home() / ".autosmoke" / "click_result.json"

    def _recover_injector_payload():
        if not injector_result.exists():
            return {}
        try:
            with open(injector_result, "r", encoding="utf-8") as rf:
                injector_data = json.load(rf)
            if injector_data.get("requestId") != request_id:
                return {}
            click = injector_data.get("click") or {}
            return {
                "clickResult": injector_data.get("status") or "",
                "error": "",
                "message": injector_data.get("message", ""),
                "eventReceiverMatched": click.get("receiverMatchTarget", False),
                "hitRuntimePath": click.get("eventReceiver", ""),
                "targetGameObject": click.get("targetGameObject", ""),
                "dispatchTarget": click.get("dispatchTarget", ""),
                "screenPoint": click.get("screenPoint", []),
                "debugOverlayBypassed": click.get("debugOverlayBypassed", False),
                "debugOverlayReceiver": click.get("debugOverlayReceiver", ""),
                "injectorResultRecovered": True,
            }
        except Exception:
            return {}

    payload = {}
    deadline = time.time() + timeout_sec
    while time.time() < deadline:
        if os.path.exists(done_path):
            try:
                with open(resp_path, "r", encoding="utf-8") as f:
                    resp_data = json.load(f)
                payload = resp_data.get("payload", {}) if isinstance(resp_data, dict) else {}
            except Exception:
                payload = {}
            break
        recovered_payload = _recover_injector_payload()
        if recovered_payload:
            payload = recovered_payload
            break
        time.sleep(0.05)
    if not payload:
        payload = {
            "clickResult": "CLICK_TIMEOUT",
            "error": "Bridge did not write a test_click response before timeout",
            "requestId": request_id,
            "timeoutSec": timeout_sec,
        }
    if payload.get("clickResult") == "CLICK_TIMEOUT":
        for _ in range(100):
            recovered_payload = _recover_injector_payload()
            if recovered_payload:
                payload = {**payload, **recovered_payload}
                break
            time.sleep(0.05)
    success = payload.get("clickResult") in ("OK", "CLICK_CONFIRMED", "CLICK_OK", "CLICK_CHANGED") or bool(payload.get("success"))
    if not success and payload.get("requestId") == request_id and payload.get("error", "").startswith("Bridge did not write"):
        return False, {
            "error": "unity_bridge_no_click_response",
            "detail": {
                "reason": "Bridge did not write a test_click response before timeout",
                "timeoutSec": timeout_sec,
                "requestId": request_id,
            },
        }
    return success, {
        "success": success,
        "clickMethod": "unity_event_system",
        "detail": payload,
        "error": "" if success else (payload.get("error") or payload.get("clickResult") or "click_failed"),
    }


def _target_coordinate_fallback_click(screen_rect, reason=""):
    if not isinstance(screen_rect, list) or len(screen_rect) < 4:
        return False, {"error": "screen_rect_missing", "detail": {"reason": reason}}
    try:
        x1, y1, x2, y2 = [float(v) for v in screen_rect[:4]]
    except Exception:
        return False, {"error": "screen_rect_invalid", "detail": {"screenRect": screen_rect, "reason": reason}}
    cx = (x1 + x2) / 2.0
    cy = (y1 + y2) / 2.0
    if cx <= 0 or cy <= 0 or abs(x2 - x1) <= 2 or abs(y2 - y1) <= 2:
        return False, {"error": "screen_rect_invalid", "detail": {"screenRect": screen_rect, "reason": reason}}
    debug_block = _target_rect_center_hits_debug_overlay(screen_rect)
    if debug_block:
        return False, {"error": "debug_overlay_coordinate_blocked", "detail": debug_block}
    try:
        request_id = "click_" + datetime.now().strftime("%Y%m%d_%H%M%S_%f")
        request_dir = Path.home() / ".autosmoke"
        req_path = request_dir / "click_request.json"
        old_req_path = request_dir / "click_request.consumed"
        result_path = request_dir / "click_result.json"
        request_dir.mkdir(parents=True, exist_ok=True)
        for stale in (req_path, old_req_path, result_path):
            try:
                if stale.exists():
                    stale.unlink()
            except Exception:
                pass
        req_data = {
            "action": "click",
            "requestId": request_id,
            "timestamp": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
            "targetType": "coordinate",
            "x": int(round(cx)),
            "y": int(round(cy)),
            "gameResolution": [1170, 2532],
        }
        with open(req_path, "w", encoding="utf-8") as f:
            json.dump(req_data, f, ensure_ascii=False)
        click_result = {}
        deadline = time.time() + 4.0
        while time.time() < deadline:
            if result_path.exists():
                try:
                    with open(result_path, "r", encoding="utf-8") as f:
                        candidate = json.load(f)
                    if candidate.get("requestId") == request_id:
                        click_result = candidate
                        break
                except Exception:
                    pass
            time.sleep(0.05)
        if not click_result:
            click_result = {"status": "CLICK_TIMEOUT", "message": "coordinate fallback did not write click_result.json", "requestId": request_id}
    except Exception as exc:
        return False, {"error": "coordinate_fallback_failed", "detail": {"reason": reason, "exception": str(exc)}}
    success = (
        click_result.get("status") in ("OK", "CLICK_CONFIRMED", "CLICK_OK", "CLICK_CHANGED")
        or click_result.get("clickResult") in ("OK", "CLICK_CONFIRMED", "CLICK_OK", "CLICK_CHANGED")
        or click_result.get("result") in ("CLICK_OK", "CLICK_CHANGED")
        or bool(click_result.get("success"))
    )
    detail = dict(click_result or {})
    detail["fallbackReason"] = reason
    detail["screenRect"] = screen_rect
    detail["screenPoint"] = [cx, cy]
    return success, {
        "success": success,
        "clickMethod": "coordinate_fallback_after_visible_mismatch",
        "detail": detail,
        "error": "" if success else (detail.get("error") or detail.get("clickResult") or "coordinate_fallback_failed"),
    }


def _target_slug_test_id(value):
    text = str(value or "").strip()
    if not text:
        return ""
    text = re.sub(r"([A-Z]+)([A-Z][a-z])", r"\1_\2", text)
    text = re.sub(r"([a-z0-9])([A-Z])", r"\1_\2", text)
    text = re.sub(r"[^A-Za-z0-9_]+", "_", text).strip("_")
    text = re.sub(r"_+", "_", text).strip("_").lower()
    return text or ""


def _target_semantic_id_is_productized(value):
    text = _coerce_str(value)
    if not text:
        return False
    if "custom_" in text or ".." in text:
        return False
    if re.search(r"[\u4e00-\u9fff]", text):
        return False
    if not re.fullmatch(r"[a-z][a-z0-9_]*(\.[a-z0-9_]+)+", text):
        return False
    return True


def _target_semantic_id_is_generic_fallback(value):
    text = _coerce_str(value)
    if not text:
        return False
    if text.startswith("runtime."):
        return True
    base = re.sub(r"\.[0-9a-f]{6,12}$", "", text)
    return base in {
        "ui.entry.icon",
        "ui.entry.action",
        "ui.action",
        "ui.id.action",
        "ui.visual_check.action",
    } or bool(re.fullmatch(r"ui\.[a-z0-9_]+_(clone_)?[a-z0-9_\.]+", base))


