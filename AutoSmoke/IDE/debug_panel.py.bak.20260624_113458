def _normalize_case_context_payload(payload):
    if not isinstance(payload, dict):
        return {}
    mapping = {
        "path": "path",
        "stepField": "step_field",
        "step_field": "step_field",
        "caseIdField": "case_id_field",
        "case_id_field": "case_id_field",
        "sheetName": "sheet_name",
        "sheet_name": "sheet_name",
        "unityProject": "unity_project_path",
        "autosmokeRoot": "autosmoke_root",
        "pocoPath": "poco_sdk_path",
        "designWidth": "design_width",
        "design_height": "design_height",
        "designHeight": "design_height",
        "batchName": "batch_name",
        "batch_name": "batch_name",
        "runName": "batch_name",
        "run_name": "batch_name",
    }
    ctx = {}
    for key, target in mapping.items():
        if key in payload:
            value = payload[key]
            if value is None:
                continue
            if isinstance(value, str) and not value.strip():
                continue
            ctx[target] = value
    if "design_width" in ctx:
        try:
            ctx["design_width"] = int(ctx["design_width"])
        except Exception:
            ctx.pop("design_width", None)
    if "design_height" in ctx:
        try:
            ctx["design_height"] = int(ctx["design_height"])
        except Exception:
            ctx.pop("design_height", None)
    return ctx


def _get_case_context(payload=None):
    ctx = {}
    if payload is None:
        payload = {}
