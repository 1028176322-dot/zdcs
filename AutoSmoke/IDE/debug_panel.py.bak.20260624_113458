@app.route("/api/mapping_store/validate", methods=["GET", "POST"])
def api_mapping_store_validate():
    try:
        store = MappingStore(project_root=_project_root)
        indexes = store.rebuild_indexes()
        legacy = store.export_legacy_files()
        scan_roots = [
            store.store_dir,
            Path(_CONF_DIR) / "metadata" / "mapping_task_queue.json",
            Path(_CONF_DIR) / "metadata" / "target_candidate_recommendations.json",
        ]
        code_scan_roots = [
            Path(_CONF_DIR) / "IDE",
            Path(_CONF_DIR) / "元数据",
            Path(_CONF_DIR) / "用例层",
        ]
        absolute_hits = []
        code_absolute_hits = []
        slash = "\\"
        fslash = "/"
        workspace_name = "zd" + "cs"
        data_absolute_tokens = ("E:" + slash, "E:" + fslash, slash + workspace_name + slash, fslash + workspace_name + fslash)
        code_absolute_tokens = ("E:" + slash, "E:" + fslash, "C:" + slash, slash + workspace_name + slash, fslash + workspace_name + fslash)
        old_field_counts = {"formalPath": 0, "evidencePath": 0, "recommendationPath": 0}
        queue_path = Path(_CONF_DIR) / "metadata" / "mapping_task_queue.json"
        queue_data = _read_json_if_exists(str(queue_path)) or {}
        for task in queue_data.get("tasks", []) if isinstance(queue_data, dict) else []:
            if not isinstance(task, dict):
                continue
            for key in old_field_counts:
                if key in task:
                    old_field_counts[key] += 1
            evidence = task.get("evidence") if isinstance(task.get("evidence"), dict) else {}
            for item in evidence.values():
                if not isinstance(item, dict):
                    continue
                for key in ("formalPath", "evidencePath"):
                    if key in item:
                        old_field_counts[key] += 1
            match_summary = task.get("matchSummary") if isinstance(task.get("matchSummary"), dict) else {}
            if "recommendationPath" in match_summary:
                old_field_counts["recommendationPath"] += 1
        for root in scan_roots:
            root = Path(root)
            if not root.exists():
                continue
            files = [root] if root.is_file() else [p for p in root.rglob("*.json") if p.is_file()]
            for path in files:
                if path.name == "validation_report.json":
                    continue
                try:
                    text = path.read_text(encoding="utf-8")
                except Exception:
                    continue
                for token in data_absolute_tokens:
                    if token in text:
                        absolute_hits.append({"path": store.metadata_relpath(path) if str(path).startswith(str(store.metadata_dir)) else str(path), "token": token})
                        break
        for root in code_scan_roots:
            if not root.exists():
                continue
            for path in root.rglob("*.py"):
                try:
                    text = path.read_text(encoding="utf-8")
                except Exception:
                    continue
                for token in code_absolute_tokens:
                    if token in text:
                        code_absolute_hits.append({"path": str(path.relative_to(Path(_CONF_DIR))), "token": token})
                        break
        required_files = [
            store.store_dir / "manifest.json",
            store.index_dir / "page.index.json",
            store.index_dir / "draft.index.json",
            store.index_dir / "formal.index.json",
            store.index_dir / "evidence.index.json",
            store.index_dir / "testid.index.json",
            store.index_dir / "semantic.index.json",
            store.page_dictionary_path(),
        ]
        missing_required = [store.metadata_relpath(path) for path in required_files if not path.exists()]
        legacy_files = {
            "draft": Path(_CONF_DIR) / "元数据" / "element_mapping_draft.json",
            "formal": Path(_CONF_DIR) / "metadata" / "element_mapping_formal.json",
            "evidence": Path(_CONF_DIR) / "metadata" / "mapping_evidence.json",
        }
        legacy_counts = {}
        for key, path in legacy_files.items():
            raw = _read_json_if_exists(str(path)) or {}
            if key == "draft":
                legacy_counts[key] = len(raw.get("drafts") or []) if isinstance(raw, dict) else 0
            elif key == "formal":
                legacy_counts[key] = len(raw.get("mappings") or {}) if isinstance(raw, dict) else 0
            else:
                legacy_counts[key] = len(raw.get("evidence") or {}) if isinstance(raw, dict) else 0
        identity_audit = _audit_target_identity_conflicts(
            tasks=queue_data.get("tasks", []) if isinstance(queue_data, dict) else [],
            formal=_formal_records(),
        )
        identity_conflicts = identity_audit.get("issues", []) if isinstance(identity_audit, dict) else []
        passed = (
            bool(indexes.get("success"))
            and not absolute_hits
            and not code_absolute_hits
            and not missing_required
            and not any(old_field_counts.values())
            and not identity_conflicts
        )
        report = {
            "success": True,
            "passed": passed,
            "validatedAt": _utcnow(),
            "indexes": indexes,
            "legacyExport": legacy,
            "legacyCounts": legacy_counts,
            "oldFieldCounts": old_field_counts,
            "absolutePathHits": absolute_hits[:50],
            "absolutePathHitCount": len(absolute_hits),
            "codeAbsolutePathHits": code_absolute_hits[:50],
            "codeAbsolutePathHitCount": len(code_absolute_hits),
            "missingRequiredFiles": missing_required,
            "identityAudit": identity_audit,
            "identityConflictCount": len(identity_conflicts),
        }
        report_path = store.store_dir / "validation_report.json"
        try:
            _write_json_file(str(report_path), report)
            report["reportPath"] = store.metadata_relpath(report_path)
        except Exception as report_exc:
            report["reportWriteError"] = str(report_exc)
        return jsonify(report)
    except Exception as e:
        return jsonify({"success": False, "passed": False, "error": str(e)})

