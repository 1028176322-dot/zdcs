    return True, ""


def _validate_ui_payload(payload, filename):
    stats = {
        "file": filename,
        "nodeCount": 0,
        "pageCount": 0,
        "missingPageId": 0,
        "missingPath": 0,
        "missingScreenRect": 0,
        "errorCount": 0,
        "warningCount": 0,
        "errors": [],
        "warnings": [],
    }
    if not isinstance(payload, dict):
        return False, {"ok": False, "error": "JSON格式异常", "stats": stats}

    if payload.get("schemaVersion"):
        stats["schemaVersion"] = payload.get("schemaVersion")
    if isinstance(payload.get("nodes"), list):
        nodes = payload.get("nodes") or []
        stats["nodeCount"] = len(nodes)
        for n in nodes[:200]:
            ok, msg = _validate_ui_node(n)
            if not ok:
                stats["errorCount"] += 1
                stats["errors"].append(msg)
            elif "screenRect" not in n and "rect" not in n:
                stats["missingScreenRect"] += 1
                stats["warningCount"] += 1
                if len(stats["warnings"]) < 20:
                    stats["warnings"].append("节点缺少screenRect，将在运行态匹配阶段补齐")
        if not payload.get("pageId"):
            stats["missingPageId"] += 1
            stats["warningCount"] += 1
            stats["warnings"].append("nodes文件缺少pageId")
    elif isinstance(payload.get("pages"), list):
        pages = payload.get("pages") or []
        stats["pageCount"] = len(pages)
        for p in pages:
            if not isinstance(p, dict):
                continue
            if not p.get("pageId"):
                stats["missingPageId"] += 1
                stats["warningCount"] += 1
                stats["warnings"].append("page缺少pageId")
                continue
            nodes = p.get("nodes") if isinstance(p.get("nodes"), list) else []
            stats["nodeCount"] += len(nodes)
            for n in nodes[:100]:
                ok, msg = _validate_ui_node(n)
                if not ok:
                    stats["errorCount"] += 1
                    stats["errors"].append(msg)
                elif "screenRect" not in n and "rect" not in n:
                    stats["missingScreenRect"] += 1
                    stats["warningCount"] += 1
                    if len(stats["warnings"]) < 20:
                        stats["warnings"].append("节点缺少screenRect，将在运行态匹配阶段补齐")
    elif isinstance(payload.get("elements"), list):
        elements = payload.get("elements") or []
        stats["nodeCount"] = len(elements)
        for e in elements[:200]:
            ok, msg = _validate_ui_node(e)
            if not ok:
                stats["errorCount"] += 1
                stats["errors"].append(msg)
            elif "screenRect" not in e and "rect" not in e:
                stats["missingScreenRect"] += 1
                stats["warningCount"] += 1
                if len(stats["warnings"]) < 20:
                    stats["warnings"].append("节点缺少screenRect，将在运行态匹配阶段补齐")
    else:
        if not payload:
            stats["errors"].append("空对象")
        else:
            stats["warnings"].append("未检测到标准UI字段(nodes/pages/elements)")

    if not stats["errors"] and not stats["warnings"]:
        return True, {"ok": True, "stats": stats}
    if not stats["errors"]:
        return True, {"ok": True, "stats": stats}
    return False, {"ok": False, "stats": stats}


def _latest_candidates_from_dir(directory, patterns):
    abs_dir = _read_current_ui_source_files(directory)
    if not abs_dir:
        return []
    out = []
    for p in patterns:
        if "*" in p:
            for f in sorted(list(Path(abs_dir).glob(p))):
                out.append(str(f))
            continue
        path = os.path.join(abs_dir, p)
        if os.path.exists(path):
            out.append(path)
            continue
        if p.endswith(".json") and os.path.isdir(path):
            for f in sorted(Path(path).glob("*.json")):
                out.append(str(f))
    if not out and os.path.isdir(abs_dir):
        for f in sorted(Path(abs_dir).glob("*.json")):
            out.append(str(f))
    return out


