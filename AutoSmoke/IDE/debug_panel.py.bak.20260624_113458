@app.route("/api/ui/import", methods=["POST"])
def api_ui_import():
    try:
        data = request.get_json(silent=True) or {}
        mode = _normalize_import_mode(data.get("mode", "current"))
        source_file = (data.get("sourceFile") or "").strip()
        source_dir = (data.get("sourceDir") or "").strip()
        selected_pages = data.get("pages")
        if not isinstance(selected_pages, list):
            selected_pages = []

        if source_file:
            source_abs = _normalize_user_path(source_file)
            if not source_abs or not os.path.exists(source_abs):
                return jsonify({"success": False, "error": "sourceFile不存在", "sourceFile": source_file})
            candidates = [source_abs]
            payload = _read_json_if_exists(source_abs)
        elif mode == "pages":
            candidates = _latest_candidates_from_dir(_read_current_ui_source_files(source_dir), ["pages/*.json"])
            payload = _merge_pages_to_current_ui(_read_current_ui_source_files(source_dir) or "", selected_pages)
            source_abs = os.path.join(_read_current_ui_source_files(source_dir) or "", "pages")
        else:
            mode_files = _metadata_candidate_paths("project_ui_inventory.json" if mode == "project" else [
                "current_ui_tree.json",
                "enhanced_ui_tree.json",
                "current_ui.json",
                "ui_tree_full.json",
                "scene_objects.json",
            ])
            mode_dir = ""
            if mode == "runtime":
                mode_dir = _read_current_ui_source_files(source_dir)
                candidates = _latest_candidates_from_dir(mode_dir, _scan_ui_import_candidates(mode=mode))
                runtime_first = [
                    "current_ui_tree.json",
                    "enhanced_ui_tree.json",
                    "current_ui.json",
                    "ui_tree_full.json",
                    "project_ui_inventory.json",
                ]
                ranked = []
                for prefer in runtime_first:
                    p = os.path.join(mode_dir or "", prefer)
                    if os.path.exists(p):
                        ranked.append(p)
                ranked_set = set(ranked)
                candidates = ranked + [p for p in candidates if p not in ranked_set]
            elif mode == "project":
                # 方案 8.2：project 模式应先生成 enhanced_ui_tree.json
                project_dir = _read_current_ui_source_files(source_dir) or _normalize_user_path(os.path.join(_project_root, "runtime", "ui_tree"))
                project_path = os.path.join(project_dir, "project_ui_inventory.json")
                enhanced_path = os.path.join(project_dir, "enhanced_ui_tree.json")

                if os.path.exists(enhanced_path):
                    # 已有 enhanced，直接使用
                    candidates = [enhanced_path]
                    payload = _read_json_if_exists(enhanced_path)
                elif os.path.exists(project_path):
                    try:
                        # 自动生成 enhanced
                        from 元数据.ui_tree_enhancer import UITreeEnhancer
                        enhancer = UITreeEnhancer(source_dir=project_dir)
                        enhance_result = enhancer.run(overwrite=True)
                        if enhance_result.get("success"):
                            candidates = [enhance_result.get("enhancedPath", enhanced_path)]
                            payload = _read_json_if_exists(str(candidates[0]))
                        else:
                            # 增强失败，fallback 到 project
                            candidates = [project_path]
                            payload = _read_json_if_exists(project_path)
                    except Exception:
                        candidates = [project_path]
                        payload = _read_json_if_exists(project_path)
                else:
                    candidates = []
                    payload = None

                if not payload:
                    candidates = _latest_candidates_from_dir(project_dir, ["project_ui_inventory.json"])
                    candidates = [p for p in candidates if os.path.exists(p)]
                    source_abs = candidates[0] if candidates else ""
                    payload = _read_json_if_exists(source_abs) if source_abs else None
            elif mode == "current":
                candidates = mode_files
            else:
                candidates = mode_files
            candidates = [os.path.abspath(p) for p in candidates if p and os.path.exists(p)]
            if not candidates:
                return jsonify({
                    "success": False,
                    "error": "未发现可导入文件",
                    "mode": mode,
                    "candidates": candidates,
                })
            # 多文件时，优先带current_ui标识或含project_ui_inventory
            source_abs = candidates[0]
            for p in candidates:
                bn = os.path.basename(p)
                if bn == "project_ui_inventory.json":
                    source_abs = p
                    break
                if mode == "runtime" and bn in ("current_ui_tree.json", "enhanced_ui_tree.json", "current_ui.json", "ui_tree_full.json"):
                    source_abs = p
                    break
            payload = _read_json_if_exists(source_abs)
        if not isinstance(payload, dict):
            return jsonify({
                "success": False,
                "error": "无法解析导入JSON",
                "file": source_abs,
            })

        valid, vinfo = _validate_ui_payload(payload, source_abs)
        if not vinfo or not isinstance(vinfo, dict):
            vinfo = {}

        target_dir = os.path.join(_CONF_DIR, "metadata")
        os.makedirs(target_dir, exist_ok=True)
        target_file = os.path.join(target_dir, "current_ui.json")
        _write_json_file(target_file, payload)

        report_file = _write_import_report(source_abs, {
            "success": bool(valid and vinfo.get("ok", True)),
            "mode": mode,
            "source": source_abs,
            "sourceDir": source_dir,
            "info": vinfo.get("stats", {}),
            "checked": candidates[:20] if isinstance(candidates, list) else [],
        }, vinfo.get("stats", {}) if isinstance(vinfo, dict) else {})

        drafts_path = ""
        draft_count = 0
        if valid:
            try:
                from 元数据.element_mapping import ElementMappingManager
                mgr = ElementMappingManager()
                mgr.load()
                drafts_path = mgr.export_drafts()
                if drafts_path and os.path.exists(drafts_path):
                    with open(drafts_path, "r", encoding="utf-8") as f:
                        data_obj = json.load(f) if os.path.getsize(drafts_path) else {}
                    draft_count = data_obj.get("totalDrafts", 0) if isinstance(data_obj, dict) else 0
            except Exception as e:
                logger.warning("自动生成草稿失败: %s", e)

        return jsonify({
            "success": bool(valid and vinfo.get("ok", True)),
            "mode": mode,
            "file": os.path.abspath(source_abs),
            "target": os.path.abspath(target_file),
            "reportPath": os.path.abspath(report_file) if report_file else "",
            "drafts": {
                "path": drafts_path,
                "count": draft_count,
            },
            "validation": vinfo,
            "candidates": candidates,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


