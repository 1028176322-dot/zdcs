    try:
        data = request.get_json(silent=True) or {}
        max_clicks = int(data.get("maxClicks", data.get("max_clicks", 30)))
        if max_clicks <= 0:
            max_clicks = 30
        try:
            max_depth = int(data.get("maxDepth", data.get("max_depth", 0)))
        except Exception:
            max_depth = 0
        if max_depth < 0:
            max_depth = 0
        # AutoExplorer 当前实现以 max_clicks 为主，保留 maxDepth 便于前端回传展示
