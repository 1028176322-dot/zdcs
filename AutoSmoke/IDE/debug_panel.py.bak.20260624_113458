        os.path.join(_CONF_DIR, "metadata", "enhanced_ui_tree.json"),
        os.path.join(_CONF_DIR, "metadata", "project_ui_inventory.json"),
        os.path.join(_CONF_DIR, "metadata", "current_ui.json"),
        os.path.join(_CONF_DIR, "metadata", "current_ui_tree.json"),
    ]
    for p in candidates:
        payload = _read_json_if_exists(p)
        if isinstance(payload, dict):
            return payload, p
    return None, ""


def _prepare_collect_prefab_nodes(payload):
    page_nodes = []
    if not isinstance(payload, dict):
        return page_nodes

    if isinstance(payload.get("nodes"), list):
        for node in payload.get("nodes") or []:
            if isinstance(node, dict):
                node["runtimePath"] = node.get("path") or node.get("runtimePath", "")
                page_nodes.append(("Unknown", "", "", node))

    if isinstance(payload.get("prefabs"), list):
        for prefab in payload.get("prefabs") or []:
            if not isinstance(prefab, dict):
                continue
            prefab_path = prefab.get("assetPath") or prefab.get("prefab") or ""
            page_id = prefab.get("pageId") or prefab.get("name") or os.path.splitext(os.path.basename(prefab_path))[0] or "Unknown"
            prefab_name = prefab.get("assetPath") or prefab_path
            for node in prefab.get("nodes") or []:
                if not isinstance(node, dict):
                    continue
                if not isinstance(node.get("path"), str):
                    continue
                node["runtimePath"] = node.get("path")
                page_nodes.append((page_id, prefab_path, prefab_name, node))

    if isinstance(payload.get("pages"), list):
        for p in payload.get("pages") or []:
            if not isinstance(p, dict):
                continue
            page_id = p.get("pageId") or p.get("name") or "Unknown"
            prefab_path = p.get("prefab") or p.get("prefabPath") or ""
            for node in p.get("nodes") or []:
                if not isinstance(node, dict):
                    continue
                node["runtimePath"] = node.get("path") or node.get("runtimePath", "")
                page_nodes.append((page_id, prefab_path, prefab_name if (prefab_name := prefab_path) else page_id, node))

    return page_nodes


def _prepare_parse_code_handlers(text, source_file):
    handlers = []
    if not text:
        return handlers
    for m in re.finditer(r"\b(?:public|private|protected|local|function)?\s*(?:async\s+)?(?:void|IEnumerator|Task|bool|int|string|float|double|object|var|dynamic)?\s+([A-Za-z_][A-Za-z0-9_]*)\s*\(", text):
        name = m.group(1)
        if not name:
            continue
        line_no = text[:m.start()].count("\n") + 1
        handlers.append({
            "handler": name,
            "handlerLine": line_no,
            "sourceFile": os.path.relpath(source_file, _prepare_unity_project_root()),
        })
    return handlers


def _prepare_guess_action_type(text, name):
    key = ((text or "") + " " + (name or "")).lower()
    if re.search(r"\b(open|enter|show|进入|跳转|switch|切换)\b", key):
        return "open_page"
    if re.search(r"\b(close|隐藏|退出|dismiss|pop)\b", key):
        return "close_popup"
    if re.search(r"\b(tab|切换tab|switchtab)\b", key):
        return "switch_tab"
    if re.search(r"\b(select|选中|choose|选择)\b", key):
        return "select_item"
    if re.search(r"\b(use|使用|点击使用|consume|消耗)\b", key):
        return "use_item"
    if re.search(r"\b(buy|购买|purchase|支付)\b", key):
        return "buy"
    if re.search(r"\b(claim|领取|获取奖励|领|claim)\b", key):
        return "claim_reward"
    if re.search(r"\b(go|前往|navigate|跳转场景)\b", key):
        return "go_to"
    if re.search(r"\b(drag|拖拽|滑动)\b", key):
        return "drag"
    if re.search(r"\b(scroll|滚动)\b", key):
        return "scroll"
    if re.search(r"\b(close|cancel|取消|确认|cancel)\b", key):
        return "close_popup"
    return "unknown"


def _prepare_build_ui_semantics(project_root):
    if not project_root or not os.path.isdir(project_root):
        return {"success": False, "error": "未配置可用的Unity项目目录"}

    payload, source_file = _prepare_read_current_ui_payload()
    if not isinstance(payload, dict):
        return {"success": False, "error": f"未找到可用UI数据（已查找: current_ui/ui_tree）"}

    _prepare_ensure_rule_files()
    alias_rules, page_rules = _prepare_load_rules()
    try:
        from 元数据.code_semantic_indexer import build_ui_code_semantics
    except Exception as e:
        return {"success": False, "error": f"语义索引组件加载失败: {e}"}

    try:
        result = build_ui_code_semantics(
            project_root=project_root,
            ui_payload=payload,
            output_path=PREPARE_SEMANTICS_PATH,
            alias_rules=alias_rules,
            page_type_rules=page_rules,
        )
    except Exception as e:
        return {"success": False, "error": f"语义索引执行失败: {e}"}

    if not isinstance(result, dict):
        return {"success": False, "error": "语义索引返回值异常"}
    if not result.get("success"):
        return result

    data = result.get("data") or {}
    if isinstance(data, dict) and not os.path.exists(PREPARE_SEMANTICS_PATH):
        _write_json_file(PREPARE_SEMANTICS_PATH, data)

    return {
        "success": True,
        "summary": result.get("summary", data.get("stats", {})),
        "path": result.get("path", PREPARE_SEMANTICS_PATH),
        "data": data or result,
        "source": os.path.abspath(source_file) if source_file else "",
    }


def _import_page_elements_from_file(page_file):
    payload = _read_json_if_exists(page_file)
    if not isinstance(payload, dict):
        return [], None

    screenshot_ref = payload.get("screenshotRef") or payload.get("screenshot") or payload.get("image") or ""
    if not isinstance(screenshot_ref, str):
        screenshot_ref = ""
    page_base = os.path.splitext(os.path.basename(page_file))[0]
    page_dir = os.path.dirname(os.path.abspath(page_file))
    if not screenshot_ref:
        for candidate in (
            os.path.join(page_dir, "screenshots", page_base + ".png"),
            os.path.join(page_dir, "screenshots", page_base + ".jpg"),
            os.path.join(page_dir, "screenshots", page_base + ".jpeg"),
            os.path.join(page_dir, "screenshots", page_base + ".webp"),
            os.path.join(page_dir, page_base + ".png"),
            os.path.join(page_dir, page_base + ".jpg"),
            os.path.join(page_dir, page_base + ".jpeg"),
            os.path.join(page_dir, page_base + ".webp"),
            os.path.join(os.path.dirname(page_dir), "screenshots", page_base + ".png"),
            os.path.join(os.path.dirname(page_dir), "screenshots", page_base + ".jpg"),
            os.path.join(os.path.dirname(page_dir), "screenshots", page_base + ".jpeg"),
            os.path.join(os.path.dirname(page_dir), "screenshots", page_base + ".webp"),
        ):
            if os.path.exists(candidate):
                screenshot_ref = candidate
                break

    if screenshot_ref and not os.path.isabs(screenshot_ref):
        alt = os.path.join(page_dir, screenshot_ref)
        if os.path.exists(alt):
            screenshot_ref = alt

    page_id = payload.get("pageId") or os.path.splitext(os.path.basename(page_file))[0]
    elements = []
    raw_nodes = payload.get("nodes")
    if isinstance(raw_nodes, list):
        for n in raw_nodes:
            if not isinstance(n, dict):
                continue
            n = dict(n)
            n.setdefault("canvas", page_id)
            n.setdefault("pageId", page_id)
            if not n.get("path"):
                n_path = n.get("runtimePath") or n.get("elementPath") or ""
                if n_path:
                    n["path"] = n_path
            n.setdefault("screenRect", n.get("rect", []))
            if screenshot_ref:
                n.setdefault("screenshotRef", screenshot_ref)
            if n.get("path"):
                elements.append(n)

    elif isinstance(payload.get("elements"), list):
        for e in payload.get("elements", []):
            if not isinstance(e, dict):
                continue
            e = dict(e)
            e.setdefault("canvas", page_id)
            e.setdefault("pageId", page_id)
            if screenshot_ref:
                e.setdefault("screenshotRef", screenshot_ref)
            if e.get("path"):
                elements.append(e)

    return elements, {
        "pageId": page_id,
        "file": os.path.abspath(page_file),
        "count": len(elements),
        "screenshotRef": screenshot_ref,
    }


def _merge_pages_to_current_ui(source_dir, page_files=None):
    ui_root = _read_current_ui_source_files(source_dir) or _normalize_user_path(os.path.join(_project_root, "runtime", "ui_tree"))
    if not ui_root or not os.path.isdir(ui_root):
        return []
    candidates = []
    if isinstance(page_files, list) and page_files:
        for p in page_files:
            abs_p = _normalize_user_path(p)
            if not abs_p:
                continue
            if os.path.isdir(abs_p):
                candidates.extend([str(f) for f in sorted(Path(abs_p).glob("*.json"))])
            elif abs_p.endswith("*.json"):
                candidates.extend([str(f) for f in sorted(Path(os.path.dirname(abs_p)).glob("*.json"))])
            elif os.path.isfile(abs_p):
                candidates.append(abs_p)
    else:
        pages_dir = os.path.join(ui_root, "pages")
        if os.path.isdir(pages_dir):
            candidates.extend([str(f) for f in sorted(Path(pages_dir).glob("*.json"))])
    pages = []
    all_elements = []
    merged_screenshot_refs = []
    for f in candidates:
        elems, info = _import_page_elements_from_file(f)
        if info:
            pages.append(info)
            all_elements.extend(elems)
            if info.get("screenshotRef"):
                merged_screenshot_refs.append(info.get("screenshotRef"))
    if not all_elements:
        return []
    top_screenshot_ref = ""
    if merged_screenshot_refs:
        top_screenshot_ref = merged_screenshot_refs[0]
    return {
        "schemaVersion": "1.0",
        "importMode": "pages_merge",
        "mergedAt": time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()),
        "sourceDir": ui_root,
        "screenshotRef": top_screenshot_ref,
        "pages": pages,
        "elements": all_elements,
    }

