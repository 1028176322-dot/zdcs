@app.route("/api/mapping/import", methods=["POST"])
def api_mapping_import():
    """
    导入数据并生成映射草稿

    请求参数：
        sourceDir: 数据目录（默认 元数据/）
        source: 指定数据源文件，如 enhanced_ui_tree.json / project_ui_inventory.json
        autoEnhance: 如果只有 project_ui_inventory.json 时是否自动生成 enhanced（默认 true）

    策略：
        1. 优先使用 enhanced_ui_tree.json
        2. 没有 enhanced 但有 project_ui_inventory.json → 自动调用 enhance
        3. 从 enhanced 生成草稿（使用增强字段）
    """
    try:
        data = request.get_json() or {}
        src_dir = data.get("sourceDir", "")
        src_hint = data.get("source", "")
        auto_enhance = data.get("autoEnhance", True)

        if not src_dir:
            src_dir = os.path.join(_CONF_DIR, "元数据")
            if not os.path.exists(src_dir):
                src_dir = os.path.join(os.environ.get("USERPROFILE", "."), ".autosmoke", "metadata")
        if not os.path.exists(src_dir):
            return jsonify({"success": False, "error": f"目录不存在: {src_dir}"})

        from 元数据.element_mapping import ElementMappingManager
        mgr = ElementMappingManager()
        mgr.load()

        # 数据源优先级
        enhanced_path = os.path.join(src_dir, "enhanced_ui_tree.json")
        project_path = os.path.join(src_dir, "project_ui_inventory.json")
        runtime_path = os.path.join(src_dir, "current_ui_tree.json")

        source_file = ""
        source_type = ""

        if src_hint:
            # 用户指定数据源
            hint_path = os.path.join(src_dir, src_hint)
            if os.path.exists(hint_path):
                source_file = hint_path
                source_type = "enhanced" if "enhanced" in src_hint else "normal"
        elif os.path.exists(enhanced_path):
            source_file = enhanced_path
            source_type = "enhanced"
        elif os.path.exists(project_path) and auto_enhance:
            # 自动生成 enhanced
            from 元数据.ui_tree_enhancer import UITreeEnhancer
            enhancer = UITreeEnhancer(source_dir=src_dir)
            enhance_result = enhancer.run(overwrite=True)
            if enhance_result.get("success"):
                source_file = enhance_result.get("enhancedPath", enhanced_path)
                source_type = "enhanced"
            else:
                # 增强失败，回退到 project
                source_file = project_path
                source_type = "normal"
        elif os.path.exists(project_path):
            source_file = project_path
            source_type = "normal"
        elif os.path.exists(runtime_path):
            source_file = runtime_path
            source_type = "normal"

        if not source_file or not os.path.exists(source_file):
            return jsonify({"success": False, "error": "未发现可导入数据文件"})

        with open(source_file, "r", encoding="utf-8") as f:
            payload = json.load(f)

        elements = ElementMappingManager.normalize_elements_from_payload(payload)
        total_nodes = len(elements)
        total_clickable = sum(1 for e in elements if e.get("clickable"))

        drafts = mgr.generate_drafts(elements, source_type=source_type)
        if drafts:
            for d in drafts:
                mgr.upsert(d.get("path", ""), d)

        mgr.save()
        stats = mgr.stats()
        all_vals = list(mgr._mappings.values())
        pending_count = sum(1 for m in all_vals if m.get("reviewStatus") == "pending")
        miss_desc = sum(1 for m in all_vals if not m.get("chineseDescription"))
        source_name = os.path.basename(source_file)

        return jsonify({"success": True, "summary": {
            "dataSource": source_name,
            "sourceType": source_type,
            "totalNodes": total_nodes,
            "totalClickable": total_clickable,
            "totalDrafts": stats.get("totalMappings", 0),
            "pending": pending_count,
            "missingDescription": miss_desc,
        }, "sources": [source_name]})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


