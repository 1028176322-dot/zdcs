def _rect_delta(a, b):
    if not (isinstance(a, list) and isinstance(b, list) and len(a) == 4 and len(b) == 4):
        return None
    try:
        return max(abs(float(a[i]) - float(b[i])) for i in range(4))
    except Exception:
        return None


def _formal_fallback_screen_rect(entry):
    for locator in entry.get("fallbackLocators", []) or []:
        if not isinstance(locator, dict):
            continue
        if locator.get("type") == "screenRect" and isinstance(locator.get("value"), list):
            return locator.get("value")
        if locator.get("type") == "runtimeHint" and isinstance(locator.get("value"), dict):
            rect = locator.get("value", {}).get("screenRect")
            if isinstance(rect, list):
                return rect
    return []


def _revalidate_formal_mappings(test_ids=None):
    formal = _formal_records()
    nodes, runtime_path = _runtime_nodes_by_path()
    requested = set([_coerce_str(x) for x in (test_ids or []) if _coerce_str(x)])
    results = {}
    now = _utcnow()
    for test_id, entry in formal.items():
        if requested and test_id not in requested:
            continue
        if not isinstance(entry, dict):
            continue
        locator = entry.get("locator") if isinstance(entry.get("locator"), dict) else {}
        value = _coerce_str(locator.get("value"))
        node = nodes.get(value)
        if not node and value:
            suffix = value.split("/")[-1]
            for rp, n in nodes.items():
                if rp.endswith(value) or (suffix and rp.endswith(suffix)):
                    node = n
                    break
        old_rect = _formal_fallback_screen_rect(entry)
        new_rect = node.get("screenRect", []) if isinstance(node, dict) else []
        delta = _rect_delta(old_rect, new_rect)
        exists = isinstance(node, dict)
        stale = (not exists) or (delta is not None and delta > 12)
        status = "ok" if not stale else "stale"
        entry["revalidateStatus"] = status
        entry["revalidatedAt"] = now
        entry["revalidateRuntimePath"] = node.get("runtimePath", "") if isinstance(node, dict) else ""
        entry["revalidateDeltaPx"] = delta
        results[test_id] = {
            "testId": test_id,
            "status": status,
            "exists": exists,
            "runtimePath": entry.get("revalidateRuntimePath", ""),
            "rectDeltaPx": delta,
            "oldScreenRect": old_rect,
            "currentScreenRect": new_rect,
            "runtimeTreePath": runtime_path,
        }
    if results:
        _write_formal_records(formal)
    path = os.path.join(_CONF_DIR, "metadata", "mapping_revalidation_report.json")
    payload = {
        "schema_version": "mapping_revalidation_report.v1",
        "updated_at": now,
        "runtimeTreePath": runtime_path,
        "results": results,
        "summary": {
            "total": len(results),
            "ok": len([r for r in results.values() if r.get("status") == "ok"]),
            "stale": len([r for r in results.values() if r.get("status") == "stale"]),
        },
    }
    _write_json_file(path, payload)
    return {"success": True, "path": path, **payload}


def _semantic_impact_summary(draft_path, old_test_id, new_test_id, semantic_id, queue_result, updated_files):
    formal = _formal_records()
    tasks = _target_catalog().list_tasks(limit=1000).get("tasks", [])
    affected_targets = []
    for task in tasks:
        if not isinstance(task, dict):
            continue
        if str(task.get("targetId", "")).startswith("repair.") or task.get("elementType") == "mapping_repair" or task.get("status") == "ignored":
            continue
        if task.get("selectedDraftPath") == draft_path or task.get("testId") in {old_test_id, new_test_id} or task.get("confirmedTestId") in {old_test_id, new_test_id}:
            affected_targets.append({
                "targetId": task.get("targetId", ""),
                "status": task.get("status", ""),
                "testId": task.get("testId", ""),
                "confirmedTestId": task.get("confirmedTestId", ""),
            })
    rules, rule_path = _read_semantic_rules()
    rule_hits = []
    for rule in rules.get("rules", []) if isinstance(rules, dict) else []:
        if not isinstance(rule, dict):
            continue
        if rule.get("draftPath") == draft_path or rule.get("semanticId") == semantic_id or rule.get("testId") in {old_test_id, new_test_id}:
            rule_hits.append(rule.get("ruleId", ""))
    hints = [
        "testId rename requires case references to use the new id" if old_test_id and new_test_id and old_test_id != new_test_id else "",
        "semantic rules affect future auto-generated mapping suggestions" if rule_hits else "",
    ]
    return {
        "testIdRenamed": bool(old_test_id and new_test_id and old_test_id != new_test_id),
        "oldTestId": old_test_id,
        "newTestId": new_test_id,
        "formalEntryExists": bool(new_test_id and new_test_id in formal),
        "affectedTargets": affected_targets,
        "affectedTargetCount": len(affected_targets),
        "queueUpdated": bool(queue_result.get("success")),
        "rulePath": str(rule_path or ""),
        "matchedRuleIds": [r for r in rule_hits if r],
        "updatedFiles": [p for p in updated_files if p],
        "globalImpactHints": [h for h in hints if h],
    }


def _replace_test_id_in_json_value(value, old_test_id, new_test_id):
    changed = False
    if isinstance(value, dict):
        out = {}
        for key, item in value.items():
            new_key = new_test_id if key == old_test_id else key
            new_item, item_changed = _replace_test_id_in_json_value(item, old_test_id, new_test_id)
            out[new_key] = new_item
            changed = changed or item_changed or new_key != key
        return out, changed
    if isinstance(value, list):
        out = []
        for item in value:
            new_item, item_changed = _replace_test_id_in_json_value(item, old_test_id, new_test_id)
            out.append(new_item)
            changed = changed or item_changed
        return out, changed
    if isinstance(value, str):
        if value == old_test_id:
            return new_test_id, True
        if old_test_id in value:
            return value.replace(old_test_id, new_test_id), True
    return value, False


def _semantic_json_migration_roots():
    roots = []
    for item in [
        os.path.join(_CONF_DIR, "metadata"),
        os.path.join(_CONF_DIR, "元数据"),
        os.path.join(_CONF_DIR, "runtime"),
    ]:
        if item and os.path.isdir(item) and item not in roots:
            roots.append(item)
    return roots


def _migrate_test_id_json_references(old_test_id, new_test_id):
    migrated = []
    skipped = []
    for root in _semantic_json_migration_roots():
        for dirpath, _, filenames in os.walk(root):
            for name in filenames:
                if not name.lower().endswith(".json"):
                    continue
                path = os.path.join(dirpath, name)
                raw = _read_json_if_exists(path)
                if raw is None:
                    skipped.append({"path": path, "reason": "invalid_json"})
                    continue
                updated, changed = _replace_test_id_in_json_value(raw, old_test_id, new_test_id)
                if changed:
                    _write_json_file(path, updated)
                    migrated.append(path)
    return {"migratedFiles": migrated, "skippedFiles": skipped}


def _migrate_test_id_case_file(old_test_id, new_test_id):
    ctx = _get_case_context()
    path = _coerce_str(ctx.get("path")) if isinstance(ctx, dict) else ""
    if not path or not os.path.exists(path):
        return {"caseFile": path, "migrated": False, "reason": "case_file_missing"}
    ext = os.path.splitext(path)[1].lower()
    if ext in {".txt", ".csv", ".json", ".md", ".yaml", ".yml"}:
        try:
            with open(path, "r", encoding="utf-8") as f:
                text = f.read()
            if old_test_id not in text:
                return {"caseFile": path, "migrated": False, "reason": "old_test_id_not_found"}
            with open(path, "w", encoding="utf-8") as f:
                f.write(text.replace(old_test_id, new_test_id))
            return {"caseFile": path, "migrated": True, "mode": "text_replace"}
        except Exception as exc:
            return {"caseFile": path, "migrated": False, "reason": str(exc)}
    if ext in {".xlsx", ".xlsm"}:
        try:
            import openpyxl

            workbook = openpyxl.load_workbook(path)
            changed = 0
            for sheet in workbook.worksheets:
                for row in sheet.iter_rows():
                    for cell in row:
                        value = cell.value
                        if isinstance(value, str) and old_test_id in value:
                            cell.value = value.replace(old_test_id, new_test_id)
                            changed += 1
            if changed:
                workbook.save(path)
                return {"caseFile": path, "migrated": True, "mode": "xlsx_replace", "changedCells": changed}
            return {"caseFile": path, "migrated": False, "mode": "xlsx_replace", "changedCells": 0, "reason": "old_test_id_not_found"}
        except Exception as exc:
            return {"caseFile": path, "migrated": False, "reason": f"xlsx_migration_failed:{exc}"}
    return {"caseFile": path, "migrated": False, "reason": f"unsupported_case_file:{ext}"}


def _migrate_test_id_references(old_test_id, new_test_id):
    if not old_test_id or not new_test_id or old_test_id == new_test_id:
        return {"needed": False, "oldTestId": old_test_id, "newTestId": new_test_id}
    json_result = _migrate_test_id_json_references(old_test_id, new_test_id)
    case_result = _migrate_test_id_case_file(old_test_id, new_test_id)
    return {
        "needed": True,
        "oldTestId": old_test_id,
        "newTestId": new_test_id,
        **json_result,
        "caseMigration": case_result,
    }


