def _prepare_project_import_source_dir(source_dir=""):
    """解析工程态 UI 清单导入目录。

    Unity 工程路径用于代码语义索引；UI 清单通常由 IDE/Unity 导出到 AutoSmoke 元数据目录。
    因此 source_dir 若没有 project_ui_inventory/enhanced_ui_tree，需要自动回退到元数据目录。
    """
    wanted = ("enhanced_ui_tree.json", "project_ui_inventory.json")
    checked = []
    candidates = []
    if source_dir:
        candidates.append(source_dir)
    candidates.extend([
        os.path.join(_CONF_DIR, "元数据"),
        os.path.join(_CONF_DIR, "metadata"),
        os.path.join(_CONF_DIR, "runtime", "ui_tree"),
        os.path.join(os.path.expanduser("~"), ".autosmoke", "metadata"),
    ])
    for d in candidates:
        abs_dir = _normalize_user_path(d)
        if not abs_dir or abs_dir in checked:
            continue
        checked.append(abs_dir)
        if not os.path.isdir(abs_dir):
            continue
        if any(os.path.exists(os.path.join(abs_dir, name)) for name in wanted):
            return abs_dir, checked
    return (_normalize_user_path(source_dir) or ""), checked


def _prepare_guess_page_type(page_id: str) -> str:
    v = (page_id or "").lower()
    if not v:
        return "unknown"
    if "loading" in v:
        return "loading"
    if "reconnect" in v or "reconnect" in (v.replace(" ", "")):
        return "reconnect"
    if "dialog" in v or "popup" in v or "tip" in v:
        return "popup"
    if "map" in v:
        return "map"
    if "city" in v:
        return "city"
    if any(x in v for x in ("shop", "bag", "inventory", "main", "gm")):
        return "fullscreen_ui"
    return "fullscreen_ui"


def _prepare_invoke_api(method, path, payload=None):
    try:
        with app.test_client() as client:
            if method.lower() == "post":
                rv = client.post(path, json=payload or {})
            elif method.lower() == "get":
                if payload:
                    params = "&".join(f"{k}={v}" for k, v in payload.items())
                    rv = client.get(path + ("?" + params if params else ""))
                else:
                    rv = client.get(path)
            else:
                return False, {"error": "不支持的方法"}
        data = None
        try:
            data = rv.get_json()
        except Exception:
            data = None
        if data is None:
            data = {"success": False, "error": "内置调用无返回JSON"}
        return True, data
    except Exception as e:
        return False, {"error": f"内置调用失败: {e}"}


