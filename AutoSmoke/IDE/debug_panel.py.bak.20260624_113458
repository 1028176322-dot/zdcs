        "pageId": mapping.get("pageId", ""),
        "role": mapping.get("role", ""),
        "elementType": mapping.get("elementType", ""),
        "elementPath": mapping.get("elementPath", ""),
        "locator": locator,
        "fallbackLocators": [
            {"type": "screenRect", "value": mapping.get("screenRect", [])},
            {"type": "runtimeHint", "value": task.get("runtimeHint", {})},
        ],
        "reviewStatus": "click_confirmed",
        "source": "target_workbench",
        "evidenceRef": evidence_ref,
    }
    visual = (task.get("evidence") or {}).get("visual", {}) if isinstance(task.get("evidence"), dict) else {}
    runtime = (task.get("evidence") or {}).get("runtime", {}) if isinstance(task.get("evidence"), dict) else {}
    evidence_item = {
