    by_key = {}
    out = []
    for task in normalized:
        if task.get("status") == "ignored" or str(task.get("targetId", "")).startswith("repair.") or task.get("elementType") == "mapping_repair":
            continue
        formal_key = _target_formal_key(task, formal=formal)
        if not formal_key:
            out.append(task)
            continue
        existing = by_key.get(formal_key)
        if not existing:
            task["dedupeKey"] = formal_key
            by_key[formal_key] = task
            out.append(task)
            continue
        if _target_rank_for_dedupe(task) > _target_rank_for_dedupe(existing):
            replacement = _merge_target_for_display(task, existing, formal_key)
            by_key[formal_key] = replacement
            for idx, item in enumerate(out):
                if item is existing:
                    out[idx] = replacement
                    break
        else:
            merged = _merge_target_for_display(existing, task, formal_key)
            by_key[formal_key] = merged
            for idx, item in enumerate(out):
                if item is existing:
                    out[idx] = merged
                    break
    return out


def _audit_target_identity_conflicts(tasks=None, formal=None):
    tasks = tasks if isinstance(tasks, list) else _target_catalog().list_tasks(limit=5000).get("tasks", [])
    formal = formal if isinstance(formal, dict) else _formal_records()
    issues = []
    by_confirmed = {}
    for task in tasks or []:
        if not isinstance(task, dict):
            continue
        if task.get("status") == "ignored" or str(task.get("targetId", "")).startswith("repair."):
            continue
        test_id = _coerce_str(task.get("confirmedTestId") or task.get("testId"))
        if not test_id:
            continue
        paths = set()
        for key in ["selectedDraftPath", "elementPath", "path", "draftPath"]:
            paths.update(_target_path_variants(task.get(key)))
        runtime_hint = task.get("runtimeHint")
        if isinstance(runtime_hint, dict):
            paths.update(_target_path_variants(runtime_hint.get("runtimePath")))
            paths.update(_target_path_variants(runtime_hint.get("clickTargetNode")))
        by_confirmed.setdefault(test_id, []).append({"task": task, "paths": paths})
    for test_id, records in by_confirmed.items():
        if len(records) <= 1:
            continue
        for i in range(len(records)):
            for j in range(i + 1, len(records)):
                left, right = records[i], records[j]
                if left["paths"] and right["paths"] and not _target_paths_overlap(left["paths"], right["paths"]):
                    issues.append({
                        "type": "confirmed_test_id_shared_by_distinct_paths",
                        "testId": test_id,
                        "leftTargetId": left["task"].get("targetId", ""),
                        "leftTargetName": left["task"].get("targetName", ""),
                        "leftPath": left["task"].get("selectedDraftPath", ""),
                        "rightTargetId": right["task"].get("targetId", ""),
                        "rightTargetName": right["task"].get("targetName", ""),
                        "rightPath": right["task"].get("selectedDraftPath", ""),
                    })
    for test_id, item in formal.items():
        if not isinstance(item, dict):
            continue
        semantic_id = _coerce_str(item.get("semanticId"))
        if not semantic_id:
            continue
        target_name = _coerce_str(item.get("targetName"))
        expected = {}
        if target_name and re.search(r"[\u4e00-\u9fff]", target_name):
            semantic_task = dict(item)
            semantic_task["targetName"] = target_name
            semantic_task["selectedDraftPath"] = item.get("elementPath") or item.get("path") or item.get("draftPath") or ""
            semantic_task["pageHint"] = item.get("pageId", "")
            expected = _target_semantic_from_target_name(semantic_task, current_test_id="")
        if expected:
            expected_semantic = _coerce_str(expected.get("semanticId")) if isinstance(expected, dict) else ""
            expected_page = _coerce_str(expected.get("pageId"))
            page_id = _coerce_str(item.get("pageId"))
            if expected_semantic and expected_semantic != semantic_id:
                issues.append({
                    "type": "target_name_semantic_id_mismatch",
                    "testId": test_id,
                    "semanticId": semantic_id,
                    "expectedSemanticId": expected_semantic,
                    "targetName": target_name,
                    "path": item.get("elementPath") or (item.get("locator") or {}).get("value", ""),
                })
            if expected_page and page_id and expected_page != page_id:
                issues.append({
                    "type": "target_name_page_id_mismatch",
                    "testId": test_id,
                    "semanticId": semantic_id,
                    "pageId": page_id,
                    "expectedPageId": expected_page,
                    "targetName": target_name,
                })
            if expected_semantic and test_id != expected_semantic:
                issues.append({
                    "type": "target_name_test_id_mismatch",
                    "testId": test_id,
                    "expectedTestId": expected_semantic,
                    "semanticId": semantic_id,
                    "targetName": target_name,
                    "path": item.get("elementPath") or (item.get("locator") or {}).get("value", ""),
                })
        elif target_name and re.search(r"[\u4e00-\u9fff]", target_name) and _target_semantic_id_is_generic_fallback(semantic_id):
            issues.append({
                "type": "target_name_semantic_unresolved",
                "testId": test_id,
                "semanticId": semantic_id,
                "targetName": target_name,
                "path": item.get("elementPath") or (item.get("locator") or {}).get("value", ""),
            })
        for other_id, other in formal.items():
            if other_id <= test_id or not isinstance(other, dict):
                continue
            if _coerce_str(other.get("semanticId")) != semantic_id:
                continue
            left_path = item.get("elementPath") or (item.get("locator") or {}).get("value", "")
            right_path = other.get("elementPath") or (other.get("locator") or {}).get("value", "")
            if left_path and right_path and not _target_path_variants(left_path).intersection(_target_path_variants(right_path)):
                issues.append({
                    "type": "semantic_id_shared_by_distinct_formals",
                    "semanticId": semantic_id,
                    "leftTestId": test_id,
                    "leftPath": left_path,
                    "rightTestId": other_id,
                    "rightPath": right_path,
                })
    return {"success": True, "passed": len(issues) == 0, "issueCount": len(issues), "issues": issues}


