def _target_slug_case(value):
    text = str(value or "").strip()
    if not text:
        return ""
    text = re.sub(r"([A-Z]+)([A-Z][a-z])", r"\1_\2", text)
    text = re.sub(r"([a-z0-9])([A-Z])", r"\1_\2", text)
    text = re.sub(r"[^A-Za-z0-9_]+", "_", text).strip("_").lower()
    return re.sub(r"_+", "_", text)


def _case_payload_to_steps(payload):
    steps = []
    if isinstance(payload, dict):
        for key in ("steps", "caseSteps", "texts"):
            value = payload.get(key)
            if isinstance(value, list):
                steps.extend(value)
            elif isinstance(value, str):
                steps.extend([x.strip() for x in re.split(r"[\r\n]+", value) if x.strip()])
        if isinstance(payload.get("text"), str) and payload.get("text").strip():
            steps.append(payload.get("text").strip())
        cases = payload.get("cases")
        if isinstance(cases, list):
            for case in cases:
                if not isinstance(case, dict):
                    continue
                raw_steps = case.get("steps") or case.get("caseSteps") or case.get("text") or case.get("stepsText")
                case_id = case.get("caseId") or case.get("case_id") or case.get("id") or case.get("name")
                if isinstance(raw_steps, list):
                    for step in raw_steps:
                        steps.append({"caseId": case_id, "text": step})
                elif isinstance(raw_steps, str):
                    for step in [x.strip() for x in re.split(r"[\r\n]+", raw_steps) if x.strip()]:
                        steps.append({"caseId": case_id, "text": step})
    elif isinstance(payload, list):
        steps.extend(payload)
    return steps


def _case_step_text_and_id(step, index):
    if isinstance(step, dict):
        text = step.get("text") or step.get("step") or step.get("action") or ""
        case_id = step.get("caseId") or step.get("case_id") or step.get("id") or f"CASE_{index + 1}"
        return str(text or "").strip(), str(case_id or "").strip()
    return str(step or "").strip(), f"CASE_{index + 1}"


def _case_target_role_type(parsed, target):
    action = parsed.get("action", "")
    ttype = target.get("type", "")
    value = str(target.get("value", "") or "")
    lower = value.lower()
    role = "action"
    element_type = "click_target" if action in ("click", "long_press") else "assertion_target"
    if "close" in lower or "关闭" in value:
        role, element_type = "close", "button"
    elif "claim" in lower or "领取" in value:
        role, element_type = "claim", "button"
    elif "use" in lower or "使用" in value:
        role, element_type = "use", "button"
    elif "entry" in lower or "入口" in value:
        role, element_type = "entry", "button"
    elif ttype == "testId":
        suffix = lower.rsplit(".", 1)[-1]
        if suffix in {"button", "btn"}:
            element_type = "button"
        elif suffix in {"cell", "item"}:
            role, element_type = "item", "item_cell"
        elif suffix:
            role = suffix
    return role, element_type


def _case_step_to_target(parsed, step_text, case_id, index):
    target = parsed.get("target") if isinstance(parsed, dict) else None
    if not isinstance(target, dict):
        return None
    action = parsed.get("action", "")
    if action not in ("click", "long_press", "assert_exists", "assert_not_exists", "input"):
        return None
    ttype = target.get("type", "")
    value = target.get("value")
    if value is None:
        if "x" in target and "y" in target:
            value = f"{target.get('x')},{target.get('y')}"
        elif "nx" in target and "ny" in target:
            value = f"{target.get('nx')},{target.get('ny')}"
        else:
            value = step_text
    value = str(value or "").strip()
    role, element_type = _case_target_role_type(parsed, target)
    target_id = "case." + hashlib.sha1(f"{case_id}|{index}|{action}|{ttype}|{value}".encode("utf-8")).hexdigest()[:12]
    task = {
        "targetId": target_id,
        "targetName": f"{case_id} {action} {value or step_text}".strip(),
        "aliases": [value, step_text],
        "sourceCases": [case_id],
        "pageHint": "",
        "role": role,
        "elementType": element_type,
        "priority": "P1" if action in ("click", "long_press", "input") else "P2",
        "expectedBehavior": f"{action} {value}".strip(),
        "status": "pending_match",
        "sourceStep": step_text,
        "locatorHint": target,
        "evidence": {
            "generation": {
                "source": "case_step",
                "caseId": case_id,
                "stepIndex": index,
                "stepText": step_text,
                "parsed": parsed,
                "recordedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
            }
        },
    }
    if ttype == "testId" and value:
        task["testId"] = value
        parts = value.split(".")
        if len(parts) > 1:
            task["pageHint"] = parts[0]
    return task


def _extract_targets_from_cases(payload):
    from 用例层.case_step_parser import CaseStepParser
    parser = CaseStepParser()
    targets = []
    parse_errors = []
    seen = set()
    for index, raw_step in enumerate(_case_payload_to_steps(payload)):
        text, case_id = _case_step_text_and_id(raw_step, index)
        if not text:
            continue
        parsed = parser.parse(text)
        if not parsed.get("valid"):
            parse_errors.append({"caseId": case_id, "step": text, "error": parsed.get("error", "parse_failed")})
            continue
        task = _case_step_to_target(parsed, text, case_id, index)
        if not task:
            continue
        if task["targetId"] in seen:
            continue
        seen.add(task["targetId"])
        targets.append(task)
    return targets, parse_errors


def _mapping_evidence_records():
    try:
        store = MappingStore(project_root=_project_root)
        if store.has_store():
            index = _read_json_if_exists(str(store.index_dir / "evidence.index.json")) or {}
            items = index.get("items") if isinstance(index, dict) else {}
            out = {}
            if isinstance(items, dict):
