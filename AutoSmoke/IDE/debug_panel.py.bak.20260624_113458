def _check_bridge_service():
    bridge_dir = Path(os.path.expanduser("~")) / ".autosmoke"
    bridge_dir.mkdir(parents=True, exist_ok=True)
    request_file = bridge_dir / "bridge_request.json"
    response_file = bridge_dir / "game_view_pos.json"
    payload = {
        "action": "export",
        "request_id": int(time.time() * 1000),
        "source": "ide_precheck",
    }
    result = {
        "ok": False,
        "request_file": str(request_file),
        "response_file": str(response_file),
    }

    try:
        with open(request_file, "w", encoding="utf-8") as f:
            json.dump(payload, f, ensure_ascii=False)
    except Exception as e:
        result["error"] = f"请求文件写入失败: {e}"
        return result

    old_mtime = response_file.stat().st_mtime if response_file.exists() else 0
    waited = 0.0
    max_wait, step = 2.5, 0.2
    while waited < max_wait:
        time.sleep(step)
        waited += step
        if not response_file.exists():
            continue
        try:
            new_mtime = response_file.stat().st_mtime
            if new_mtime <= old_mtime + 0.001:
                continue
            with open(response_file, "r", encoding="utf-8") as f:
                state = json.load(f) if response_file.stat().st_size > 0 else {}
            result["ok"] = True
            result["state_file_mtime"] = round(new_mtime, 3)
            if isinstance(state, dict):
                for key in ("scene", "pageId", "currentScene", "current_scene"):
                    if state.get(key):
                        result["scene"] = state.get(key)
                        break
                if "status" in state:
                    result["response_status"] = state.get("status")
            break
        except Exception as e:
            result["error"] = f"读取响应失败: {e}"
            break

    if not result["ok"] and "error" not in result:
        result["error"] = f"{max_wait}s 内未读取到新的响应文件"
    return result


