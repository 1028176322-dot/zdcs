def _target_formal_key(task, formal=None):
    if not isinstance(task, dict):
        return ""
    if str(task.get("targetId", "")).startswith("repair.") or task.get("elementType") == "mapping_repair":
        return ""
    formal = formal if isinstance(formal, dict) else _formal_records()
    keys = [
        _coerce_str(task.get("confirmedTestId")),
        _coerce_str(task.get("testId")),
        _coerce_str(task.get("targetId")),
    ]
    for key in keys:
        if key and key in formal:
            item = formal.get(key)
            task_paths = set()
            for path_key in ["selectedDraftPath", "elementPath", "path", "draftPath"]:
                task_paths.update(_target_path_variants(task.get(path_key)))
            runtime_hint = task.get("runtimeHint")
            if isinstance(runtime_hint, dict):
                task_paths.update(_target_path_variants(runtime_hint.get("runtimePath")))
                task_paths.update(_target_path_variants(runtime_hint.get("clickTargetNode")))
            for cand in task.get("candidates") or []:
                if not isinstance(cand, dict):
                    continue
                task_paths.update(_target_path_variants(cand.get("draftPath")))
                task_paths.update(_target_path_variants(cand.get("path")))
                task_paths.update(_target_path_variants(cand.get("elementPath")))
            item_paths = set()
            if isinstance(item, dict):
                for path_key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
                    item_paths.update(_target_path_variants(item.get(path_key)))
                locator = item.get("locator")
                if isinstance(locator, dict):
                    item_paths.update(_target_path_variants(locator.get("value")))
            if task_paths and item_paths and not _target_paths_overlap(task_paths, item_paths):
                continue
            return key
    selected_path = _coerce_str(task.get("selectedDraftPath"))
    if selected_path:
        for key, item in formal.items():
            if isinstance(item, dict) and _target_paths_overlap(item.get("elementPath"), selected_path):
                return key
    runtime_hint = task.get("runtimeHint")
    runtime_paths = set()
    if isinstance(runtime_hint, dict):
        runtime_paths.update(_target_path_variants(runtime_hint.get("runtimePath")))
        runtime_paths.update(_target_path_variants(runtime_hint.get("clickTargetNode")))
    for cand in task.get("candidates") or []:
        if not isinstance(cand, dict):
            continue
        cand_test_id = _coerce_str(cand.get("testId") or cand.get("semanticId"))
        if cand_test_id and cand_test_id in formal:
            return cand_test_id
        runtime_paths.update(_target_path_variants(cand.get("draftPath")))
        runtime_paths.update(_target_path_variants(cand.get("path")))
        runtime_paths.update(_target_path_variants(cand.get("elementPath")))
    if runtime_paths:
        for key, item in formal.items():
            if not isinstance(item, dict):
                continue
            item_paths = set()
            for path_key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
                item_paths.update(_target_path_variants(item.get(path_key)))
            locator = item.get("locator")
            if isinstance(locator, dict):
                item_paths.update(_target_path_variants(locator.get("value")))
            if item_paths and _target_paths_overlap(runtime_paths, item_paths):
                return key
    return ""


def _target_path_variants(value):
    text = _coerce_str(value).strip()
    if not text:
        return set()
    raw = text.replace("\\", "/").strip()
    variants = {raw}
    if raw.startswith("__runtime__::"):
        runtime_tail = raw[len("__runtime__::"):]
        variants.add(runtime_tail)
        variants.add(runtime_tail.replace("::", "/"))
    if "::" in raw:
        tail = raw.split("::")[-1]
        if tail:
            variants.add(tail)
            variants.add(tail.replace("::", "/"))
    for prefix in ("DeepUI/LayerUI/", "content/"):
        if raw.startswith(prefix):
            variants.add(raw[len(prefix):])
    return {v.strip("/") for v in variants if v}


def _target_paths_overlap(left, right):
    left_variants = left if isinstance(left, set) else _target_path_variants(left)
    right_variants = right if isinstance(right, set) else _target_path_variants(right)
    if not left_variants or not right_variants:
        return False
    if left_variants.intersection(right_variants):
        return True
    for a in left_variants:
        for b in right_variants:
            if a.endswith("/" + b) or b.endswith("/" + a):
                return True
    return False


def _target_formal_keys(task, formal=None, extra_ids=None, extra_paths=None):
    if not isinstance(task, dict):
        return []
    if str(task.get("targetId", "")).startswith("repair.") or task.get("elementType") == "mapping_repair":
        return []
    formal = formal if isinstance(formal, dict) else _formal_records()
    ids = []
    for value in [
        task.get("confirmedTestId"),
        task.get("testId"),
        task.get("targetId"),
    ]:
        value = _coerce_str(value)
        if value and value not in ids:
            ids.append(value)
    for value in extra_ids or []:
        value = _coerce_str(value)
        if value and value not in ids:
            ids.append(value)

    path_variants = set()
    for key in ["selectedDraftPath", "elementPath", "path", "draftPath"]:
        path_variants.update(_target_path_variants(task.get(key)))
    runtime_hint = task.get("runtimeHint")
    if isinstance(runtime_hint, dict):
        path_variants.update(_target_path_variants(runtime_hint.get("runtimePath")))
        path_variants.update(_target_path_variants(runtime_hint.get("clickTargetNode")))
    for cand in task.get("candidates") or []:
        if not isinstance(cand, dict):
            continue
        cand_test_id = _coerce_str(cand.get("testId") or cand.get("semanticId"))
        if cand_test_id and cand_test_id not in ids:
            ids.append(cand_test_id)
        path_variants.update(_target_path_variants(cand.get("draftPath")))
        path_variants.update(_target_path_variants(cand.get("path")))
        path_variants.update(_target_path_variants(cand.get("elementPath")))
    for value in extra_paths or []:
        path_variants.update(_target_path_variants(value))

    out = []
    for key in ids:
        if key and key in formal and key not in out:
            item = formal.get(key)
            item_paths = set()
            if isinstance(item, dict):
                for path_key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
                    item_paths.update(_target_path_variants(item.get(path_key)))
                locator = item.get("locator")
                if isinstance(locator, dict):
                    item_paths.update(_target_path_variants(locator.get("value")))
            if path_variants and item_paths and not _target_paths_overlap(path_variants, item_paths):
                continue
            out.append(key)
    for key, item in formal.items():
        if not isinstance(item, dict):
            continue
        item_test_id = _coerce_str(item.get("testId"))
        if item_test_id and item_test_id in ids and key not in out:
            out.append(key)
            continue
        item_paths = set()
        for path_key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
            item_paths.update(_target_path_variants(item.get(path_key)))
        locator = item.get("locator")
        if isinstance(locator, dict):
            item_paths.update(_target_path_variants(locator.get("value")))
        if path_variants and item_paths and _target_paths_overlap(path_variants, item_paths) and key not in out:
            out.append(key)
    return out


def _target_rank_for_dedupe(task):
    status_score = {
        "case_verified": 50,
        "click_confirmed": 45,
        "visual_confirmed": 35,
        "highlight_generated": 25,
        "modified": 30,
        "runtime_matched": 20,
        "candidate_found": 10,
        "pending_match": 0,
    }.get(_coerce_str(task.get("status")), 0)
    if task.get("confirmedTestId"):
        status_score += 8
    if task.get("selectedDraftPath"):
        status_score += 5
    if _coerce_str(task.get("role")) in ("item_click", "button", "entry"):
        status_score += 14
    if _coerce_str(task.get("elementType")).lower() in ("button", "interactive_icon"):
        status_score += 3
    if _coerce_str(task.get("role")) == "visual_assert" or _coerce_str(task.get("interactionType")) == "assert_visible":
        status_score -= 3
    if str(task.get("targetId", "")).startswith("runtime."):
        status_score += 3
    return status_score


def _merge_target_for_display(primary, duplicate, formal_key):
