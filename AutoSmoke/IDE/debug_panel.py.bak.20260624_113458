def _diff_dict(before, after):
    b = before if isinstance(before, dict) else {}
    a = after if isinstance(after, dict) else {}
    keys = set(b.keys()) | set(a.keys())
    out = []
    for k in sorted(keys):
        bv = b.get(k)
        av = a.get(k)
        if isinstance(bv, (dict, list)) or isinstance(av, (dict, list)):
            continue
        if bv != av:
            out.append({"key": k, "before": bv, "after": av})
    return out


def _normalize_user_path(raw_path):
    if not raw_path:
        return ""
    raw_path = str(raw_path).strip().strip('"').strip("'")
    if raw_path.lower().startswith("file://"):
        raw_path = raw_path[7:]
    raw_path = raw_path.replace("\\", "/")
    if os.path.isabs(raw_path):
        return str(Path(raw_path))
    return as_abs_path(raw_path)


def _safe_filename(text, max_len=64):
