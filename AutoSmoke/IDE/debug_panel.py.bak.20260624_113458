function targetRefreshSelected(){
  var current=targetState.selected||{};
  var id=current.targetId;
  if(!id){return;}
  fetch('/api/target/list?limit=1000').then(function(r){return r.json();}).then(function(d){
    var tasks=d.tasks||[];
    var updated=tasks.find(function(x){return x.targetId===id;});
    if(!updated){
      updated=tasks.find(function(x){return (x.mergedTargetIds||[]).indexOf(id)>=0;});
    }
    if(!updated&&current.dedupeKey){
      updated=tasks.find(function(x){return x.dedupeKey===current.dedupeKey||x.confirmedTestId===current.dedupeKey;});
    }
    if(!updated&&current.selectedDraftPath){
      updated=tasks.find(function(x){return x.selectedDraftPath===current.selectedDraftPath&&x.confirmedTestId;});
    }
    if(!updated){
      targetState.items=(targetState.items||[]).filter(function(x){return x.targetId!==id;});
      targetState.selected=null;
      targetRenderListItems(targetState.items, targetState.items.length, targetState.items.length);
      targetRender(null);
      return;
    }
    var idx=(targetState.items||[]).findIndex(function(x){return x.targetId===id;});
    if(idx>=0){
      targetState.items[idx]=updated;
      targetRenderListItems(targetState.items, targetState.items.length, targetState.items.length);
    }
    targetState.selected=updated;
    targetRender(updated);
  });
}
