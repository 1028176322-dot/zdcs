    impact = _semantic_impact_summary(
        draft_path,
        old_test_id,
        test_id or old_test_id,
        semantic_id,
        {},
        [],
    )
    rules, rule_path = _read_semantic_rules()
    rule_conflicts = []
    for rule in rules.get("rules", []) if isinstance(rules, dict) else []:
        if not isinstance(rule, dict):
            continue
        same_semantic = semantic_id and rule.get("semanticId") == semantic_id
        same_test = test_id and rule.get("testId") == test_id
        same_draft = draft_path and rule.get("draftPath") == draft_path
        if (same_semantic or same_test) and not same_draft:
            rule_conflicts.append({
                "ruleId": rule.get("ruleId", ""),
                "draftPath": rule.get("draftPath", ""),
                "testId": rule.get("testId", ""),
                "semanticId": rule.get("semanticId", ""),
                "reason": "semantic_or_testid_conflict",
            })
    issues = []
    for key in ("testId", "semanticId"):
        for item in duplicates.get(key, []) or []:
            issues.append({"type": f"duplicate_{key}", "source": item.get("source", ""), "path": item.get("path", ""), "value": item.get(key, "")})
    for item in rule_conflicts:
        issues.append({"type": "rule_conflict", **item})
    return {
        "success": True,
        "draftPath": draft_path,
        "testId": test_id,
        "semanticId": semantic_id,
        "ok": len(issues) == 0,
        "duplicates": duplicates,
        "rulePath": str(rule_path or ""),
        "ruleConflicts": rule_conflicts,
        "issues": issues,
        "impact": impact,
    }


def _collect_duplicates(candidate):
    if not isinstance(candidate, dict):
        return {"testId": [], "semanticId": []}

    test_id = _coerce_str(candidate.get("testId"))
    semantic_id = _coerce_str(candidate.get("semanticId"))
    target_path = _coerce_str(candidate.get("path"), _coerce_str(candidate.get("draftPath")))
    ignore_test_id = _coerce_str(candidate.get("ignoreTestId"))
    ignore_path = _coerce_str(candidate.get("ignorePath"), target_path)

    duplicates = {"testId": [], "semanticId": []}
    if test_id:
        for existing_id, mapping in _formal_records().items():
            if existing_id == ignore_test_id:
                continue
            if mapping.get("testId") == test_id or existing_id == test_id:
                duplicates["testId"].append({
                    "source": "formal",
                    "testId": test_id,
                    "path": mapping.get("elementPath", ""),
                })
    else:
        duplicates["testId"] = []

    if semantic_id:
        for existing_id, mapping in _formal_records().items():
            if mapping.get("semanticId") == semantic_id and existing_id != ignore_test_id:
                duplicates["semanticId"].append({
                    "source": "formal",
                    "semanticId": semantic_id,
                    "testId": existing_id,
                    "path": mapping.get("elementPath", ""),
                })

    drafts, _ = _read_draft_list()
    for d in drafts:
        if not isinstance(d, dict):
            continue
        pid = _coerce_str(d.get("path"))
        if ignore_path and pid == ignore_path:
            continue
        dtid = _coerce_str(d.get("testId"), _coerce_str(d.get("suggestedTestId")))
        if test_id and dtid and dtid == test_id:
            duplicates["testId"].append({
                "source": "draft",
                "path": pid,
                "testId": dtid,
            })
        dsem = _coerce_str(d.get("semanticId"), _coerce_str(d.get("suggestedSemanticId")))
        if semantic_id and dsem and dsem == semantic_id:
            duplicates["semanticId"].append({
                "source": "draft",
                "path": pid,
                "semanticId": dsem,
            })

    if semantic_id:
        current = { _coerce_str(e.get("path")): e for e in _read_current_ui_elements() }
        for p, e in current.items():
            if p == ignore_path:
                continue
            if target_path and p == target_path:
                duplicates["semanticId"].append({
                    "source": "runtime",
                    "path": p,
                    "semanticId": semantic_id,
                })
                break

    duplicates["testId"] = [d for d in duplicates["testId"] if d.get("testId") != ignore_test_id]
    duplicates["semanticId"] = [d for d in duplicates["semanticId"] if d.get("testId") != ignore_test_id]
    return duplicates


def _build_rule_record(payload, source="manual_corrected"):
    draft_path = _coerce_str(payload.get("draftPath"), "")
    test_id = _coerce_str(payload.get("testId"), _coerce_str(payload.get("suggestedTestId")))
    semantic_id = _coerce_str(payload.get("semanticId"), _coerce_str(payload.get("suggestedSemanticId")))
    rule_type = _coerce_str(payload.get("ruleType", payload.get("rule_type")), "text_rule")
    if rule_type not in {"fixed_slot", "text_rule", "path_rule", "hybrid"}:
        rule_type = "text_rule"

    rule_id = _coerce_str(payload.get("ruleId"))
    if not rule_id:
        safe_source = _coerce_str(payload.get("source"), "MANUAL")
        slug = _coerce_str(draft_path.replace("/", "_").replace("\\", "_"), f"RULE_{int(time.time()*1000)}").replace(" ", "_")
        rule_id = f"RULE_{safe_source}_{slug[:24]}_{int(time.time()*1000)}"

    match_obj = {
        "pageId": _coerce_str(payload.get("pageId"), _coerce_str(payload.get("page_hint"))),
        "chineseDescription": _coerce_str(payload.get("chineseDescription")),
        "descriptionKeywords": _coerce_str(payload.get("description"), ""),
        "path_contains": draft_path.replace("\\", "/"),
        "nameContains": _coerce_str(payload.get("name"), ""),
    }
    if rule_type == "fixed_slot":
        slot_index = "0"
        if draft_path:
            slot_match = re.search(r"(\d+)$", draft_path.replace("\\", "/").rsplit("/", 1)[-1])
            if slot_match:
                slot_index = slot_match.group(1)
        rule_match = {
            "node_regex": r"\w+_(\d+)$",
            "pageId": match_obj["pageId"],
            "path_contains": match_obj["path_contains"],
        }
        slot_mapping = {
            slot_index: {
                "targetName": _coerce_str(payload.get("targetName")),
                "semanticId": semantic_id,
                "testId": test_id,
                "role": _coerce_str(payload.get("role"), "action"),
                "elementType": _coerce_str(payload.get("elementType"), _coerce_str(payload.get("componentType"), "")),
                "status": "enabled",
            }
        }
    else:
        rule_match = match_obj
        slot_mapping = {}

    rule = {
        "ruleId": rule_id,
        "created_at": _utcnow(),
        "createdAt": _utcnow(),
        "source": source,
        "draftPath": draft_path,
        "testId": test_id,
        "semanticId": semantic_id,
        "targetName": _coerce_str(payload.get("targetName")),
        "displayName": _coerce_str(payload.get("displayName")),
        "pageId": _coerce_str(payload.get("pageId")),
        "rule_type": rule_type,
        "role": _coerce_str(payload.get("role"), "action"),
        "elementType": _coerce_str(payload.get("elementType"), _coerce_str(payload.get("componentType"), "")),
        "match": {
            "path_contains": match_obj["path_contains"],
            "description_keywords": _coerce_str(payload.get("description"), ""),
            "pageId": _coerce_str(payload.get("pageId")),
        },
        "slot_mapping": slot_mapping,
        "text_rule": {
            "chineseDescription": _coerce_str(payload.get("chineseDescription")),
            "path_hint": draft_path,
            "name_hint": _coerce_str(payload.get("name")),
            "text_hint": _coerce_str(payload.get("text")),
            "class_hint": _coerce_str(payload.get("componentType")),
        },
        "raw": payload,
    }
    if rule_type == "fixed_slot":
        rule["match"] = rule_match
    return rule


def _feed_semantic_rule(payload):
    payload = payload or {}
    rules, rule_path = _read_semantic_rules()
    rules_list = rules.get("rules")
    if not isinstance(rules_list, list):
        rules_list = []
    rule = _build_rule_record(payload, source=_coerce_str(payload.get("source"), "manual"))
    rule_id = rule["ruleId"]
    replaced = False
    for idx, existing in enumerate(rules_list):
        if not isinstance(existing, dict):
            continue
        if existing.get("ruleId") == rule_id:
            rules_list[idx] = rule
            replaced = True
            break
        if existing.get("semanticId") == rule.get("semanticId") and rule.get("semanticId") and existing.get("draftPath") == rule.get("draftPath"):
            rules_list[idx] = rule
            replaced = True
            break
    if not replaced:
        rules_list.append(rule)
    rules["rules"] = rules_list
    saved = _write_semantic_rules(rules, rules_path=rule_path)
    return saved, rule


