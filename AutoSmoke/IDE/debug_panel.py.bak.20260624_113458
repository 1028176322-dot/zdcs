@app.route("/api/mapping/drafts")
def api_mapping_drafts():
    try:
        page_id = request.args.get("pageId", "")
        status = request.args.get("status", "")
        keyword = request.args.get("keyword", "")
        group = request.args.get("group", "")
        priority = request.args.get("priority", "")     # P0/P1/P2/P3/LOW
        element_type = request.args.get("elementType", "")  # button/tab/icon/...
        role = request.args.get("role", "")             # close_popup/confirm/...
        data_source = request.args.get("dataSource", "")   # enhanced_ui_tree
        try:
            offset = int(request.args.get("offset", "0"))
        except Exception:
            offset = 0
        try:
            limit = int(request.args.get("limit", "300"))
        except Exception:
            limit = 300
        offset = max(0, offset)
        limit = max(1, min(limit, 1000))
        store = MappingStore(project_root=_project_root)
        store_result = store.list_drafts(page_id=page_id, status=status, keyword=keyword, group=group, limit=50000, offset=0) if store.has_store() else {}
        if store_result.get("success"):
            drafts = store_result.get("drafts", [])
        else:
            from 元数据.element_mapping import ElementMappingManager
            mgr = ElementMappingManager()
            mgr.load()
            drafts = list(mgr._mappings.values()) if hasattr(mgr, "_mappings") else []
            if page_id:
                drafts = [d for d in drafts if (d.get("pageId") or "") == page_id]
        if group and not store_result.get("success"):
            drafts = [d for d in drafts if store.classify_group(d) == group]
        if status:
            states = {s.strip().lower() for s in str(status).replace(",", " ").split() if s.strip()}
            def _match_status(d):
                if not states:
                    return True
                ds = str(d.get("reviewStatus") or d.get("status") or d.get("source") or "").lower()
                if ds == "manual_confirmed":
                    ds = "click_confirmed"
                return ds in states
            drafts = [d for d in drafts if _match_status(d)]
        if keyword:
            kw = keyword.lower()
            drafts = [d for d in drafts if kw in d.get("displayName", "").lower()
                      or kw in d.get("chineseDescription", "").lower()
                      or kw in d.get("testId", "").lower()]
        if priority:
            drafts = [d for d in drafts if d.get("priority", "") == priority]
        if element_type:
            drafts = [d for d in drafts if d.get("elementType", "") == element_type]
        if role:
            drafts = [d for d in drafts if d.get("role", "") == role]
        if data_source:
            drafts = [d for d in drafts if d.get("dataSource", "") == data_source]
        total = len(drafts)
        page = []
        for draft in drafts[offset:offset + limit]:
            item = dict(draft)
            item["_group"] = item.get("_group") or store.classify_group(item)
            page.append(item)
        return jsonify({"total": total, "returned": len(page), "offset": offset, "limit": limit, "group": group, "source": "mapping_store" if store_result.get("success") else "legacy", "drafts": page})
    except Exception as e:
        return jsonify({"error": str(e)})

@app.route("/api/mapping/drafts/<path:draft_path>/save", methods=["POST"])
def api_mapping_draft_save(draft_path):
    try:
        data = request.get_json() or {}
        store = MappingStore(project_root=_project_root)
        store_draft = store.get_draft(draft_path) if store.has_store() else {}
        from 元数据.element_mapping import ElementMappingManager
        mgr = ElementMappingManager()
        mgr.load()
        if hasattr(mgr, "_mappings"):
            m = dict(store_draft or mgr._mappings.get(draft_path, {}))
            # 校验必填字段
            required_checks = {
                "displayName": "显示名称不能为空，否则影响审核和报告可读性",
                "pageId": "所属页面不能为空，否则无法进行当前页匹配",
                "elementType": "元素类型不能为空，否则无法分类审核",
                "interactionType": "交互方式不能为空，否则自动化不知道如何操作",
                "clickTargetNode": "点击目标不能为空，否则无法执行自动点击",
            }
            for field, msg in required_checks.items():
                val = data.get(field, "").strip() if data.get(field) else ""
                if not val and not m.get(field, ""):
                    return jsonify({"success": False, "error": msg, "field": field})

            # 保存所有可编辑字段
            editable_fields = ["displayName", "chineseDescription", "testId", "semanticId",
                               "role", "pageId", "elementType", "interactionType",
                               "priority", "clickTargetNode", "visualNode", "reviewHint"]
            update = {k: data.get(k, "") for k in editable_fields}
            update["source"] = "modified"
            update["reviewStatus"] = "modified"
            update["reviewedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime())
            m.update(update)
            item_path = m.get("path") or m.get("elementPath") or draft_path
            m["path"] = item_path
            m["elementPath"] = m.get("elementPath") or item_path
            mgr._mappings[draft_path] = m
            legacy_ok = mgr.save()
            store_result = store.save_draft(m)
            return jsonify({"success": bool(legacy_ok or store_result.get("success")), "path": draft_path, "store": store_result})
        return jsonify({"success": False, "error": "未找到映射"})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

