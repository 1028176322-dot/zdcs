        for case_id in src if isinstance(src, list) else []:
            if case_id and case_id not in source_cases:
                source_cases.append(case_id)
    aliases = list(merged.get("aliases", []) or [])
    for name in [primary.get("originalTargetName"), primary.get("targetName"), duplicate.get("originalTargetName"), duplicate.get("targetName")]:
