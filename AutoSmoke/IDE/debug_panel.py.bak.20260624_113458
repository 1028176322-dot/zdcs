@app.route("/api/target/bulk_action", methods=["POST"])
def api_target_bulk_action():
    try:
        payload = request.get_json() or {}
        action = _coerce_str(payload.get("action"))
        target_ids = payload.get("targetIds", [])
        catalog = _target_catalog()
        tasks = catalog.list_tasks(limit=1000).get("tasks", [])
        if not target_ids:
            status_filter = _coerce_str(payload.get("status"))
            target_ids = [
                t.get("targetId", "")
                for t in tasks
                if isinstance(t, dict)
                and t.get("targetId")
                and t.get("status") != "ignored"
                and (not status_filter or t.get("status") == status_filter)
            ]
        if isinstance(target_ids, str):
            target_ids = [x.strip() for x in target_ids.replace(",", " ").split() if x.strip()]
        target_ids = [x for x in target_ids if x]
        results = []
        if action == "recommend":
            from 元数据.target_candidate_matcher import recommend_candidates
            by_id = {t.get("targetId"): t for t in tasks if isinstance(t, dict)}
            for target_id in target_ids[:200]:
                task = by_id.get(target_id, {})
                if not task:
                    results.append({"targetId": target_id, "success": False, "error": "target_not_found"})
                    continue
                rec = recommend_candidates(task, limit=int(payload.get("limit", 10)))
                saved_rec = _persist_target_recommendation(target_id, task, rec)
                saved = catalog.update_task(target_id, _target_recommendation_update_payload(task, rec, saved_rec))
                results.append({"targetId": target_id, "success": saved.get("success", False), "totalCandidates": rec.get("totalCandidates", 0)})
        elif action == "ignore":
            reason = _coerce_str(payload.get("reason"), "bulk_ignored")
            for target_id in target_ids[:500]:
                results.append(catalog.ignore_task(target_id, reason))
        elif action == "revalidate":
            test_ids = []
            for task in tasks:
                if isinstance(task, dict) and task.get("targetId") in target_ids:
                    tid = _coerce_str(task.get("confirmedTestId"), _coerce_str(task.get("testId")))
                    if tid:
                        test_ids.append(tid)
            return jsonify(_revalidate_formal_mappings(test_ids=test_ids))
        else:
            return jsonify({"success": False, "error": "unsupported_action", "actions": ["recommend", "ignore", "revalidate"]})
        return jsonify({"success": True, "action": action, "total": len(results), "results": results})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


