def _feed_semantic_dictionary_from_parse(semantic_parse, dictionary_path=None):
    dictionary_path = dictionary_path or SEMANTIC_DICTIONARY_PATH
    if not isinstance(semantic_parse, dict):
        return {"updated": False, "reason": "parse_missing"}
    warnings = semantic_parse.get("warnings", [])
    if "object_from_input_fallback" not in warnings and "object_auto_translated" not in warnings and "tab_button_rule" not in warnings:
        return {"updated": False, "reason": "no_input_fallback"}
    evidence = semantic_parse.get("parseEvidence", {}) if isinstance(semantic_parse.get("parseEvidence"), dict) else {}
    obj = evidence.get("object", {}) if isinstance(evidence.get("object"), dict) else {}
    object_name = _coerce_str(obj.get("name"))
    object_id = _coerce_str(obj.get("id"))
    if not object_name or not object_id:
        return {"updated": False, "reason": "object_missing"}
    if object_id.startswith("custom_"):
        pending_path = os.path.join(_CONF_DIR, "metadata", "semantic_dictionary_pending.json")
        pending = _read_json_file(pending_path, fallback={})
        if not isinstance(pending, dict):
            pending = {}
        items = pending.setdefault("items", [])
        if not isinstance(items, list):
            items = []
            pending["items"] = items
        exists = any(isinstance(item, dict) and item.get("name") == object_name for item in items)
        if not exists:
            items.append({
                "name": object_name,
                "suggestedTemporaryId": object_id,
                "status": "english_id_required",
                "source": "targetName_input",
                "createdAt": _utcnow(),
            })
        pending["schema_version"] = "semantic_dictionary_pending.v1"
        pending["updated_at"] = _utcnow()
        _write_json_file(pending_path, pending)
        return {"updated": False, "reason": "english_id_required", "objectName": object_name, "suggestedTemporaryId": object_id, "pendingPath": pending_path}
    dictionary = _read_json_file(dictionary_path, fallback={})
    if not isinstance(dictionary, dict):
        dictionary = {}
    objects = dictionary.setdefault("objects", {})
    if not isinstance(objects, dict):
        objects = {}
        dictionary["objects"] = objects
    current = objects.get(object_name)
    if current == object_id or (isinstance(current, dict) and _coerce_str(current.get("id")) == object_id):
        return {"updated": False, "reason": "already_exists", "objectName": object_name, "objectId": object_id}
    objects[object_name] = {
        "id": object_id,
        "name": object_name,
        "keywords": [object_name],
        "source": "targetName_input_fallback",
        "fedAt": _utcnow(),
    }
    dictionary["updated_at"] = _utcnow()
    _write_json_file(dictionary_path, dictionary)
    return {"updated": True, "objectName": object_name, "objectId": object_id, "dictionaryPath": dictionary_path}


