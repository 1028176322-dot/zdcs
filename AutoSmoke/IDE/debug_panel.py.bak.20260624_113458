@app.route("/api/target/rename", methods=["POST"])
def api_target_rename():
    try:
        payload = request.get_json() or {}
        target_id = _coerce_str(payload.get("targetId"))
        target_name = _coerce_str(payload.get("targetName")).strip()
        if not target_id:
            return jsonify({"success": False, "error": "targetId is required"})
        if not target_name:
            return jsonify({"success": False, "error": "targetName is required"})
        catalog = _target_catalog()
        task = catalog.get_task(target_id)
        if not task:
            return jsonify({"success": False, "error": "target_not_found", "targetId": target_id})

        formal = _formal_records()
        payload_formal_key = _coerce_str(payload.get("dedupeKey"))
        formal_keys = _target_formal_keys(task, formal=formal, extra_ids=[payload_formal_key])
        if payload_formal_key and payload_formal_key in formal and payload_formal_key not in formal_keys:
            formal_keys.insert(0, payload_formal_key)
        formal_key = formal_keys[0] if formal_keys else ""
        update_ids = []
        initial_ids = [target_id]
        if payload.get("applyMerged", False):
            initial_ids += list(payload.get("mergedTargetIds") or task.get("mergedTargetIds") or [])
        for tid in initial_ids:
            tid = _coerce_str(tid)
            if tid and tid not in update_ids:
                update_ids.append(tid)
        if payload.get("applyMerged", False) and formal_key:
            for item in catalog.list_tasks(limit=1000).get("tasks", []):
                if not isinstance(item, dict):
                    continue
                if item.get("status") == "ignored" or item.get("elementType") == "mapping_repair":
                    continue
                if str(item.get("targetId", "")).startswith("repair."):
                    continue
                item_formal_keys = _target_formal_keys(item, formal=formal)
                if formal_key and formal_key in item_formal_keys:
                    tid = _coerce_str(item.get("targetId"))
                    if tid and tid not in update_ids:
                        update_ids.append(tid)

        timestamp = _utcnow()
        formal_entry = formal.get(formal_key) if formal_key and isinstance(formal.get(formal_key), dict) else {}
        semantic_updates = {}
        semantic_parse = {}
        dictionary_feedback = {}
        try:
            semantic_parse = parse_chinese_semantic(
                description=target_name,
                context={
                    "path": _coerce_str(task.get("selectedDraftPath"), _coerce_str(formal_entry.get("elementPath"))),
                    "pageId": _coerce_str(task.get("pageHint"), _coerce_str(formal_entry.get("pageId"))),
                    # Rename must derive a fresh business semantic id from the
                    # user's Chinese targetName. The old testId is only a
                    # migration source; passing it into the parser can preserve
                    # runtime fallback ids such as ui.xxx_visual_check.action.
                    "currentTestId": "",
                },
                dictionary_path=SEMANTIC_DICTIONARY_PATH,
            )
            semantic_warnings = semantic_parse.get("warnings", []) if isinstance(semantic_parse, dict) else []
            parsed_semantic_id = _coerce_str(semantic_parse.get("semanticId"))
            requires_english_id = _coerce_bool(semantic_parse.get("requiresEnglishId"), False) or ".custom_" in parsed_semantic_id or parsed_semantic_id.startswith("custom_")
            low_confidence_semantic = any(
                warning in {"type_not_found_fallback"}
                for warning in semantic_warnings
            ) or requires_english_id
            for key in ["displayName", "semanticId", "pageId", "role", "elementType"]:
                value = _coerce_str(semantic_parse.get(key))
                if value and not low_confidence_semantic:
                    semantic_updates[key] = value
                elif value and requires_english_id and key in {"displayName", "pageId", "role", "elementType"}:
                    semantic_updates[key] = value
            if requires_english_id:
                semantic_warnings.append("english_id_required")
            if not low_confidence_semantic:
                dictionary_feedback = _feed_semantic_dictionary_from_parse(semantic_parse, SEMANTIC_DICTIONARY_PATH)
            if low_confidence_semantic:
                for key in ["displayName", "semanticId", "pageId", "role", "elementType"]:
                    if semantic_updates.get(key):
                        continue
                    if requires_english_id and key == "semanticId":
                        continue
                    existing = _coerce_str(formal_entry.get(key), _coerce_str(task.get("pageHint" if key == "pageId" else key)))
                    if existing:
                        semantic_updates[key] = existing
        except Exception as parse_exc:
            semantic_parse = {"warnings": [f"semantic_parse_failed:{parse_exc}"]}

        page_suggestion = {}
        try:
            suggestion_item = {}
            if isinstance(formal_entry, dict):
                suggestion_item.update(formal_entry)
            if isinstance(task, dict):
                suggestion_item.update(task)
            suggestion_item["targetName"] = target_name
            suggestion_item["displayName"] = semantic_updates.get("displayName") or suggestion_item.get("displayName") or ""
            page_suggestion = MappingStore(project_root=_project_root).suggest_page(
                target_name=target_name,
                current_page_id=semantic_updates.get("pageId") or task.get("pageHint") or formal_entry.get("pageId") or "",
                item=suggestion_item,
            )
            suggestion_page_id = _coerce_str(page_suggestion.get("pageId"))
            if suggestion_page_id and suggestion_page_id != "unknown" and page_suggestion.get("exists"):
                semantic_updates["pageId"] = suggestion_page_id
        except Exception as page_exc:
            page_suggestion = {"success": False, "error": str(page_exc)}

        new_confirmed_test_id = ""
        if semantic_updates.get("semanticId") and _target_semantic_id_is_productized(semantic_updates.get("semanticId")):
            new_confirmed_test_id = semantic_updates.get("semanticId")

        updates = {
            "targetName": target_name,
            "displayName": semantic_updates.get("displayName", ""),
            "semanticId": semantic_updates.get("semanticId", ""),
            "pageHint": semantic_updates.get("pageId", ""),
            "role": semantic_updates.get("role", ""),
            "elementType": semantic_updates.get("elementType", ""),
            "targetNameEditedAt": timestamp,
            "targetNameEditedBy": "target_workbench",
            "semanticSyncedAt": timestamp,
            "semanticSyncedBy": "target_workbench",
        }
        if new_confirmed_test_id:
            updates["confirmedTestId"] = new_confirmed_test_id
            updates["formalRef"] = f"formal://{semantic_updates.get('pageId') or task.get('pageHint') or 'unknown'}/{new_confirmed_test_id}"
            updates["evidenceRef"] = f"EVIDENCE_{new_confirmed_test_id}"
            updates["testIdSource"] = "business_semantic_target_rename"
        updates = {k: v for k, v in updates.items() if v != ""}
        updated = []
        for tid in update_ids:
            result = catalog.update_task(tid, updates)
            if result.get("success"):
                updated.append(tid)

        catalog_data = catalog.list_tasks(limit=1000)
        if new_confirmed_test_id:
            new_formal_ref = updates.get("formalRef", "")
            new_evidence_ref = updates.get("evidenceRef", "")
            for item in catalog_data.get("tasks", []):
                if not isinstance(item, dict) or item.get("targetId") not in update_ids:
                    continue
                evidence_bucket = item.get("evidence")
                if isinstance(evidence_bucket, dict):
                    for evidence_kind in ("visual", "click", "runtime"):
                        evidence_item = evidence_bucket.get(evidence_kind)
                        if isinstance(evidence_item, dict):
                            evidence_item.pop("confirmBlocked", None)
                            evidence_item["confirmedTestId"] = new_confirmed_test_id
                            evidence_item["formalRef"] = new_formal_ref
                            evidence_item["evidenceRef"] = new_evidence_ref
                legacy_paths = item.get("legacyPaths")
                if isinstance(legacy_paths, dict):
                    legacy_paths.pop("legacyFormalPath", None)
                    legacy_paths.pop("legacyEvidencePath", None)
        try:
            catalog._write_catalog(catalog_data.get("tasks", []))
        except Exception:
            pass

        formal_updated = False
        formal_updated_keys = []
        if formal_keys:
            store_for_formal = MappingStore(project_root=_project_root)
            for current_formal_key in formal_keys:
                if not current_formal_key or not isinstance(formal.get(current_formal_key), dict):
                    continue
                old_evidence_ref = _coerce_str(formal[current_formal_key].get("evidenceRef")) or f"EVIDENCE_{current_formal_key}"
                old_formal_key = current_formal_key
                formal[current_formal_key]["targetName"] = target_name
                for key in ["displayName", "semanticId", "pageId", "role", "elementType"]:
                    if semantic_updates.get(key):
                        formal[current_formal_key][key] = semantic_updates.get(key)
                if new_confirmed_test_id:
                    formal[current_formal_key]["testId"] = new_confirmed_test_id
                    formal[current_formal_key]["evidenceRef"] = f"EVIDENCE_{new_confirmed_test_id}"
                formal[current_formal_key]["targetNameEditedAt"] = timestamp
                formal[current_formal_key]["targetNameEditedBy"] = "target_workbench"
                formal[current_formal_key]["semanticSyncedAt"] = timestamp
                formal[current_formal_key]["semanticSyncedBy"] = "target_workbench"
                formal_updated_keys.append(new_confirmed_test_id or current_formal_key)
                try:
                    store_result = store_for_formal.upsert_formal(formal[current_formal_key])
                    if new_confirmed_test_id and old_formal_key != new_confirmed_test_id:
                        old_evidence = store_for_formal.get_evidence(evidence_ref=old_evidence_ref, test_id=old_formal_key)
                        if isinstance(old_evidence, dict) and old_evidence:
                            old_evidence.update({
                                "evidenceRef": f"EVIDENCE_{new_confirmed_test_id}",
                                "testId": new_confirmed_test_id,
                                "semanticId": semantic_updates.get("semanticId") or old_evidence.get("semanticId", ""),
                                "targetName": target_name,
                                "displayName": semantic_updates.get("displayName") or old_evidence.get("displayName", ""),
                                "pageId": semantic_updates.get("pageId") or old_evidence.get("pageId", ""),
                                "role": semantic_updates.get("role") or old_evidence.get("role", ""),
                                "elementType": semantic_updates.get("elementType") or old_evidence.get("elementType", ""),
                            })
                            if isinstance(old_evidence.get("structure"), dict):
                                old_evidence["structure"]["pageId"] = old_evidence.get("pageId", "")
                                old_evidence["structure"]["elementType"] = old_evidence.get("elementType", "")
                            if isinstance(old_evidence.get("visual"), dict):
                                old_evidence["visual"]["confirmedTestId"] = new_confirmed_test_id
                                old_evidence["visual"]["formalRef"] = store_result.get("formalRef", f"formal://{old_evidence.get('pageId', 'unknown')}/{new_confirmed_test_id}")
                                old_evidence["visual"]["evidenceRef"] = f"EVIDENCE_{new_confirmed_test_id}"
                            store_for_formal.upsert_evidence(old_evidence)
                        _target_remove_formal_key(old_formal_key)
                        _target_remove_evidence_ref(old_formal_key, old_evidence_ref)
                except Exception:
                    pass
            if formal_updated_keys:
                formal_updated = True
                try:
                    store_for_formal.export_legacy_files()
                except Exception:
                    pass

        draft_updated = False
        draft_paths = set()
        formal_entries = [formal.get(key) for key in formal_keys if isinstance(formal.get(key), dict)]
        for item in [task, formal_entry] + formal_entries:
            if isinstance(item, dict):
                for key in ["selectedDraftPath", "elementPath", "path", "draftPath"]:
                    value = _coerce_str(item.get(key))
                    if value:
                        draft_paths.add(value)
        if draft_paths:
            try:
                store = MappingStore(project_root=_project_root)
                old_suspend = getattr(store, "_suspend_rebuild", False)
                store._suspend_rebuild = True
                for draft_path in draft_paths:
                    draft = store.get_draft(draft_path) if store.has_store() else {}
                    if not isinstance(draft, dict) or not draft:
                        continue
                    draft["targetName"] = target_name
                    draft["displayName"] = semantic_updates.get("displayName", draft.get("displayName", ""))
                    draft["semanticId"] = semantic_updates.get("semanticId", draft.get("semanticId", ""))
                    draft["pageId"] = semantic_updates.get("pageId", draft.get("pageId", ""))
                    draft["role"] = semantic_updates.get("role", draft.get("role", ""))
                    draft["elementType"] = semantic_updates.get("elementType", draft.get("elementType", ""))
                    if new_confirmed_test_id:
                        draft["testId"] = new_confirmed_test_id
                        draft["confirmedTestId"] = new_confirmed_test_id
                        draft["evidenceRef"] = f"EVIDENCE_{new_confirmed_test_id}"
                    draft["semanticSyncedAt"] = timestamp
                    draft["semanticSyncedBy"] = "target_workbench"
                    store.save_draft(draft)
                    draft_updated = True
                store._suspend_rebuild = old_suspend
            except Exception:
                try:
                    store._suspend_rebuild = old_suspend
                except Exception:
                    pass
                draft_updated = False

        display_tasks = _dedupe_confirmed_targets(catalog_data.get("tasks", []))
        display_task = None
        for item in display_tasks:
            merged_ids = item.get("mergedTargetIds", []) if isinstance(item, dict) else []
            if item.get("targetId") == target_id or target_id in merged_ids:
                display_task = item
                break
        return jsonify({
            "success": True,
            "task": display_task or catalog.get_task(target_id),
            "updatedTargetIds": updated,
            "formalKey": formal_key,
            "formalKeys": formal_updated_keys or formal_keys,
            "formalUpdated": formal_updated,
            "draftUpdated": draft_updated,
            "semanticUpdated": semantic_updates,
            "semanticWarnings": semantic_parse.get("warnings", []) if isinstance(semantic_parse, dict) else [],
            "dictionaryFeedback": dictionary_feedback,
            "pageSuggestion": page_suggestion,
            "catalogPath": str(catalog.catalog_path),
            "queuePath": str(catalog.queue_path),
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


