def _record_case_replay_status(case_result, mapping_gate=None):
    if not isinstance(case_result, dict):
        return {"success": False, "error": "case_result_invalid"}
    case_id = _coerce_str(case_result.get("case_id"), "manual")
    run_id = _coerce_str(case_result.get("run_id"))
    result = _coerce_str(case_result.get("result")).upper()
    test_ids = _case_result_test_ids(case_result)
    path = os.path.join(_CONF_DIR, "metadata", "case_replay_status.json")
    payload = _read_json_file(path, fallback={})
    if not isinstance(payload, dict):
        payload = {}
    records = payload.get("cases")
    if not isinstance(records, dict):
        records = {}
    record = {
        "caseId": case_id,
        "runId": run_id,
        "result": result,
        "testIds": test_ids,
        "total": case_result.get("total", 0),
        "passed": case_result.get("passed", 0),
        "failed": case_result.get("failed", 0),
        "resultPath": case_result.get("result_path", ""),
        "mappingGate": mapping_gate or case_result.get("mappingGate", {}),
        "updatedAt": _utcnow(),
    }
    records[case_id] = record
    payload.update({
        "schema_version": "case_replay_status.v1",
        "updated_at": _utcnow(),
        "cases": records,
    })
    _write_json_file(path, payload)

    catalog = _target_catalog()
    list_result = catalog.list_tasks(limit=1000)
    linked = []
    for task in list_result.get("tasks", []):
        if not isinstance(task, dict):
            continue
        if str(task.get("targetId", "")).startswith("repair.") or task.get("elementType") == "mapping_repair":
            continue
        task_cases = task.get("sourceCases", []) if isinstance(task.get("sourceCases"), list) else []
        task_test_ids = {
            _coerce_str(task.get("testId")),
            _coerce_str(task.get("confirmedTestId")),
        }
        case_linked = case_id in task_cases
        test_linked = bool(set(test_ids) & {tid for tid in task_test_ids if tid})
        if not (case_linked or test_linked):
            continue
        replay = dict(record)
        replay["linkedBy"] = "sourceCase" if case_linked else "testId"
        updates = {
            "caseReplayStatus": replay,
            "lastReplayAt": record["updatedAt"],
        }
        if result == "PASS":
            updates.update({"status": "case_verified", "blockedReason": ""})
        elif result in {"BLOCKED", "FAIL", "ERROR"}:
            updates["lastReplayFailure"] = replay
            if (mapping_gate or {}).get("blockers"):
                updates["blockedReason"] = "case_replay_mapping_gate_failed"
        saved = catalog.update_task(task.get("targetId", ""), updates)
        if saved.get("success"):
            linked.append(saved.get("task", {}).get("targetId", task.get("targetId", "")))
    record["linkedTargets"] = linked
    records[case_id] = record
    payload["cases"] = records
    _write_json_file(path, payload)
    return {"success": True, "path": path, "record": record, "linkedTargets": linked}


