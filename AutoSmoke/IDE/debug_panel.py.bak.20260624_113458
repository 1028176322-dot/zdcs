function targetMaybeCreatePage(suggestion, targetName){
  suggestion=suggestion||{};
  if(!suggestion.createRequired||!suggestion.pageId||suggestion.pageId==='unknown'){
    return Promise.resolve({created:false});
  }
  var files=suggestion.files||{};
  var msg='识别到新的页面：'+(suggestion.displayName||suggestion.pageId)+'\n'
    +'pageId: '+suggestion.pageId+'\n'
    +'草稿文件: '+(files.draft||'')+'\n'
    +'正式文件: '+(files.formal||'')+'\n\n'
    +'是否创建页面字典和拆分文件？';
  if(!confirm(msg)){
    return Promise.resolve({created:false, skipped:true});
  }
  return fetch('/api/mapping_store/page_create',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      pageId:suggestion.pageId,
      displayName:suggestion.displayName||suggestion.pageId,
      aliases:[suggestion.displayName||'', targetName||''].filter(Boolean)
    })
  }).then(function(r){return r.json();}).then(function(d){
    if(d.success){
      mappingPageState.loaded=false;
      return {created:true, result:d};
    }
    return {created:false, error:d.error||'page_create_failed'};
  });
}
function targetSaveName(){
