function targetReplaceCurrentItem(updated){
  if(!updated||!updated.targetId){return;}
  var idx=(targetState.items||[]).findIndex(function(x){return x.targetId===updated.targetId;});
  if(idx>=0){
    targetState.items[idx]=updated;
    targetState.selected=updated;
    targetRenderListItems(targetState.items, targetState.items.length, targetState.items.length);
  }else{
    targetState.selected=updated;
    targetRender(updated);
  }
