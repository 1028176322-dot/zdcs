@app.route("/api/mapping/semantic/save", methods=["POST"])
def api_mapping_semantic_save():
    try:
        payload = request.get_json() or {}
        parsed_block = payload.get("parsed")
        if isinstance(parsed_block, dict):
            for key in ["targetName", "displayName", "semanticId", "pageId", "role", "elementType", "testId", "chineseDescription"]:
                if payload.get(key) is None or payload.get(key) == "":
                    payload[key] = parsed_block.get(key, payload.get(key, ""))
        draft_path = _coerce_str(payload.get("draftPath"), _coerce_str(payload.get("path"), _coerce_str(payload.get("elementKey"))))
        if not draft_path:
            return jsonify({"success": False, "error": "draftPath/path 是必填项"})

        draft_map, draft_path_file = _read_draft_list()
        target_draft = _find_draft(draft_map, draft_path)
        if not isinstance(target_draft, dict):
            target_draft = {}
        old_test_id_for_impact = _coerce_str(target_draft.get("testId"), target_draft.get("suggestedTestId", ""))
        old_values = {
            "targetName": target_draft.get("targetName", ""),
            "displayName": target_draft.get("displayName", ""),
            "semanticId": target_draft.get("semanticId", target_draft.get("suggestedSemanticId", "")),
            "pageId": target_draft.get("pageId", ""),
            "role": target_draft.get("role", ""),
            "elementType": target_draft.get("elementType", target_draft.get("componentType", "")),
            "testId": old_test_id_for_impact,
        }

        semantic_fields = {
            "targetName": _coerce_str(payload.get("targetName"), target_draft.get("targetName", "")),
            "displayName": _coerce_str(payload.get("displayName"), target_draft.get("displayName", "")),
            "chineseDescription": _coerce_str(payload.get("chineseDescription"), target_draft.get("chineseDescription", "")),
            "semanticId": _coerce_str(payload.get("semanticId"), target_draft.get("semanticId", target_draft.get("suggestedSemanticId", ""))),
            "pageId": _coerce_str(payload.get("pageId"), target_draft.get("pageId", "")),
            "role": _coerce_str(payload.get("role"), target_draft.get("role", "action")),
            "elementType": _coerce_str(payload.get("elementType"), target_draft.get("elementType", target_draft.get("componentType", ""))),
        }

        rename_test_id = _coerce_bool(payload.get("rename_test_id", False))
        if rename_test_id is False:
            rename_test_id = _coerce_bool(payload.get("renameTestId", False))
        provided_test_id = _coerce_str(payload.get("testId"), target_draft.get("testId", target_draft.get("suggestedTestId", "")))
        current_test_id = _coerce_str(target_draft.get("testId"), target_draft.get("suggestedTestId", ""))
        test_id = provided_test_id if rename_test_id else current_test_id
        if not test_id and provided_test_id:
            test_id = provided_test_id

        update_time = _utcnow()
        review_status = _coerce_str(payload.get("reviewStatus"), _coerce_str(target_draft.get("reviewStatus"), "pending"))
        force_sync_queue = _coerce_bool(payload.get("syncTaskQueue", True), True)

        merged = dict(target_draft)
        merged.update(semantic_fields)
        merged.update({
            "path": draft_path,
            "elementPath": draft_path,
            "testId": test_id,
            "reviewStatus": review_status,
            "reviewLevel": "manual",
            "modifiedBy": _coerce_str(payload.get("modifiedBy"), "manual"),
            "modifiedAt": update_time,
            "modifyReason": _coerce_str(payload.get("modifyReason"), merged.get("modifyReason", "")),
            "source": _coerce_str(payload.get("source"), "manual_corrected"),
            "oldValues": old_values,
            "semanticCorrectionAudit": {
                "modifiedBy": _coerce_str(payload.get("modifiedBy"), "manual"),
                "modifiedAt": update_time,
                "modifyReason": _coerce_str(payload.get("modifyReason"), "semantic_correction"),
                "oldSemanticId": old_values.get("semanticId", ""),
                "newSemanticId": semantic_fields.get("semanticId", ""),
                "oldTargetName": old_values.get("targetName", ""),
                "newTargetName": semantic_fields.get("targetName", ""),
                "oldTestId": old_test_id_for_impact,
                "newTestId": test_id,
                "renameTestId": bool(rename_test_id and old_test_id_for_impact and old_test_id_for_impact != test_id),
            },
        })

        updated = []
        found = False
        for item in draft_map:
            if not isinstance(item, dict):
                continue
            p = _coerce_str(item.get("path"), _coerce_str(item.get("draftPath"), item.get("elementPath")))
            if p == draft_path:
                updated.append(merged)
                found = True
            else:
                updated.append(item)
        if not found:
            updated.append(merged)

        draft_file = _write_draft_list(updated, draft_path=draft_path_file)
        updated_files = [draft_file]

        formal_file = ""
        if review_status in {"manual", "confirmed", "manual_confirmed", "click_confirmed", "auto_confirmed"} and test_id:
            formal = _formal_records()
            existing_key = _coerce_str(payload.get("existingTestId"), old_test_id_for_impact if rename_test_id else "")
            if existing_key and existing_key != test_id:
                formal.pop(existing_key, None)
            formal_entry = _formal_entry_from_draft(merged)
            formal[test_id] = formal_entry
            formal_file = _write_formal_records(formal)
            updated_files.append(formal_file)

            # 同步映射证据（存在时）
            evidence_map = _mapping_evidence_records()
            ref = _coerce_str(payload.get("evidenceRef"), _coerce_str(payload.get("evidenceID")))
            if ref and ref in evidence_map:
                rec = evidence_map.get(ref) or {}
                if isinstance(rec, dict):
                    rec["confirmedBy"] = merged.get("modifiedBy")
                    rec["confirmedAt"] = update_time
                    rec["testId"] = test_id
                    rec["semanticId"] = merged.get("semanticId")
                    store = MappingStore(project_root=_project_root)
                    evidence_result = store.upsert_evidence(rec)
                    if evidence_result.get("evidenceRef"):
                        updated_files.append(evidence_result.get("evidenceRef"))
                    store.export_legacy_files()

        queue_result = {}
        if force_sync_queue:
            queue_result = _semantic_upsert_task_queue(merged, review_status)
            if queue_result.get("success"):
                updated_files.append(queue_result.get("path", ""))

        migration = {}
        if rename_test_id and old_test_id_for_impact and test_id and old_test_id_for_impact != test_id:
            migration = _migrate_test_id_references(old_test_id_for_impact, test_id)
            for path in migration.get("migratedFiles", []) or []:
                if path not in updated_files:
                    updated_files.append(path)

        revalidation = {}
        if _coerce_bool(payload.get("revalidate", False), False) and test_id:
            revalidation = _revalidate_formal_mappings(test_ids=[test_id])
            if revalidation.get("path"):
                updated_files.append(revalidation.get("path"))

        next_action = "draft_saved"
        if formal_file:
            next_action = "formal_updated"
        if queue_result.get("success"):
            next_action = "task_queue_updated"
        if queue_result.get("path") and not formal_file and not _coerce_bool(payload.get("isDraftOnly", False), False):
            next_action = "draft_and_task_queue_updated"
        impact = _semantic_impact_summary(
            draft_path,
            old_test_id_for_impact,
            test_id,
            merged.get("semanticId"),
            queue_result,
            updated_files,
        )

        return jsonify({
            "success": True,
            "updatedFiles": [str(p) for p in updated_files if p],
            "reviewStatus": review_status,
            "nextAction": next_action,
            "draftPath": draft_path,
            "testId": test_id,
            "semanticId": merged.get("semanticId"),
            "savedAt": update_time,
            "mappingTaskQueue": {
                "updated": queue_result.get("success", False),
                "path": str(queue_result.get("path", "")),
                "status": _semantic_review_status_to_task_status(review_status),
                "error": queue_result.get("error", ""),
            },
            "migration": migration,
            "revalidation": revalidation,
            "impact": impact,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


