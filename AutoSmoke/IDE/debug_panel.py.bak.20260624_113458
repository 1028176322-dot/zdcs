        "testId": test_id,
        "semanticId": mapping.get("semanticId", ""),
        "targetName": mapping.get("targetName") or mapping.get("displayName") or task.get("targetName", ""),
        "pageId": mapping.get("pageId", ""),
        "structure": {
            "path": mapping.get("elementPath", ""),
            "pageId": mapping.get("pageId", ""),
            "elementType": mapping.get("elementType", ""),
        },
        "runtime": {
            "matched": True,
            "runtimePath": mapping.get("runtimePath", ""),
            "screenRect": mapping.get("screenRect", []),
            "matchScore": runtime.get("matchScore", ""),
        },
        "visual": {
            "confirmed": bool(visual.get("confirmed")),
            "highlightImage": visual.get("highlightImage", ""),
            "screenRectUsed": visual.get("screenRectUsed", []),
        },
        "click": {
            "confirmed": True,
            "result": "PASS",
            "method": click_evidence.get("clickMethod", ""),
            "detail": click_evidence.get("detail", {}),
