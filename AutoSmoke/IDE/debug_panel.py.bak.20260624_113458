function _semanticFixCommit(options){
  options=options||{};
  var body=_semanticFixSavePayload();
  body.revalidate=!!options.revalidate;
  if(!body.draftPath){document.getElementById('rr').innerHTML='<span style=\"color:#f44336;\">保存失败：未选择草稿</span>';return;}
  if(body.renameTestId){
    if(!window.confirm('同步修改 testId 会迁移 formal key、evidenceRef、task queue 和当前用例文件引用。请确认继续。')){document.getElementById('rr').innerHTML='<span style=\"color:#f44336;\">已取消 testId 迁移</span>';return;}
  }
  fetch('/api/mapping/semantic/check_unique',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:body.draftPath,testId:body.testId,semanticId:body.semanticId})})
    .then(function(r){return r.json();}).then(function(chk){
      var ok=chk&&chk.ok!==false;
      if(!ok){
        var msg='语义字段存在重复：'+((chk.issues||[]).map(function(i){return i.message;}).slice(0,3).join('；')||'重复冲突');
        if(!window.confirm(msg+'，仍要继续保存吗？')){document.getElementById('rr').innerHTML='<span style=\"color:#f44336;\">已取消保存</span>';return;}
      }
      fetch('/api/mapping/semantic/impact_preview',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
        .then(function(r){return r.json();}).then(function(prev){
          if(prev&&prev.ok===false){
            var pmsg='保存影响预览：影响目标 '+(((prev.impact||{}).affectedTargetCount)||0)+' 个；冲突 '+((prev.issues||[]).length)+' 个';
            if(!window.confirm(pmsg+'，仍要继续保存吗？')){document.getElementById('rr').innerHTML='<span style=\"color:#f44336;\">已取消保存</span>';return null;}
          }
          return fetch('/api/mapping/semantic/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        }).then(function(r){return r?r.json():null;}).then(function(sd){
          if(!sd)return;
          if(!sd.success){document.getElementById('rr').innerHTML='<span style=\"color:#f44336;\">语义修正保存失败: '+(sd.error||'')+'</span>';return;}
          document.getElementById('rr').innerHTML='<span style=\"color:#4CAF50;\">✅ 语义修正已保存</span>';
          var sfState=semanticFixState[rp];
          if(!sfState||typeof sfState!=='object'){sfState={};semanticFixState[rp]=sfState;}
          var impact=sd.impact||{};
          var impactText='影响目标 '+(impact.affectedTargetCount||0)+' 个';
          if(impact.testIdRenamed){impactText+='；testId: '+(impact.oldTestId||'-')+' → '+(impact.newTestId||'-');}
          if(impact.globalImpactHints&&impact.globalImpactHints.length){impactText+='；'+impact.globalImpactHints.join('；');}
          if(sd.revalidation&&sd.revalidation.success){impactText+='；重验证 '+((sd.revalidation.summary&&sd.revalidation.summary.ok)||0)+' 通过 / '+((sd.revalidation.summary&&sd.revalidation.summary.stale)||0)+' 过期';}
          if(sd.migration&&sd.migration.needed){impactText+='；迁移文件 '+((sd.migration.migratedFiles||[]).length)+' 个';}
          sfState.lastMessage='已保存：'+((sd.mappingTaskQueue&&sd.mappingTaskQueue.status)||'已写入草稿')+'；'+impactText;
          semanticFixSetInfo(sfState.lastMessage);
          if(options.feedRule){
            semanticFixFeedRule(body.semanticId||'', '保存后已写入草稿', body);
          }
          if(sd.updatedFiles&&sd.updatedFiles.length){ldDrafts();}
        });
    });
}
