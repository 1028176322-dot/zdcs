@app.route("/api/mapping/runtime_match", methods=["POST"])
def api_mapping_runtime_match():
    """候选元素与实时 UI 树+场景对象匹配"""
    try:
        data = request.get_json() or {}
        page_id = data.get("pageId", "")
        priority = data.get("priority", "")
        metadata_dir = _RUNTIME_METADATA_DIR
        requested_draft_path = data.get("draftPath", "")
        matcher_draft_path = requested_draft_path

        # 加载场景对象作为运行时节点补充
        scene_obj_path = os.path.join(metadata_dir, "scene_interaction_tree.json")
        scene_objects = []
        if os.path.exists(scene_obj_path):
            try:
                with open(scene_obj_path, "r", encoding="utf-8") as f:
                    so_data = json.load(f)
                for obj in so_data.get("objects", []):
                    obj["_source"] = "scene_object"
                    obj["runtimePath"] = obj.get("gameObjectPath", "")
                    obj["clickable"] = obj.get("clickable", False)
                    obj["visible"] = True
                    scene_objects.append(obj)
            except Exception:
                pass

        if requested_draft_path and not os.path.exists(requested_draft_path):
            from 元数据.element_mapping import ElementMappingManager
            mgr_for_single = ElementMappingManager()
            mgr_for_single.load()
            single_draft = mgr_for_single.get(requested_draft_path)
            if not single_draft:
                return jsonify({"success": False, "error": "draft_not_found", "draftPath": requested_draft_path})
            single_draft = dict(single_draft)
            single_draft["path"] = requested_draft_path
            single_draft["elementPath"] = requested_draft_path
            single_path = os.path.join(metadata_dir, "_runtime_match_single_draft.json")
            with open(single_path, "w", encoding="utf-8") as f:
                json.dump(single_draft, f, ensure_ascii=False, indent=2)
            matcher_draft_path = single_path

        from 元数据.runtime_matcher import run_runtime_match, normalize_rect, is_valid_rect, is_debug_ui
        result = run_runtime_match(
            draft_path=matcher_draft_path,
            page_id=page_id,
            metadata_dir=metadata_dir,
        )
        if not result.get("success"):
            return jsonify(result)

        result["sceneObjectCount"] = len(scene_objects)

        from 元数据.element_mapping import ElementMappingManager
        mgr = ElementMappingManager()
        mgr.load()

        for r in result.get("results", []):
            path = r.get("draftPath", "")
            if not path:
                continue
            m = mgr.get(path)
            if not m:
                continue
            screen_rect = r.get("screenRect", [])
            runtime_path = r.get("runtimePath", "")
            match_score = r.get("matchScore", 0)
            is_matched = r.get("matched") and match_score >= 0.85

            if is_matched:
                # 同步顶层字段，供前端 hasRect/hasRuntimeMatch 判断
                m["reviewStatus"] = "runtime_matched"
                m["sourceLevel"] = "L2"
                m["hasRuntimeMatch"] = True
                m["runtimePath"] = runtime_path or m.get("runtimePath", "")
                m["codeSemantic"] = r.get("codeSemantic", {})
                # 校验坐标有效性
                from 元数据.runtime_matcher import normalize_rect, is_valid_rect
                nr = normalize_rect(screen_rect) if screen_rect else None
                rect_valid = is_valid_rect(nr)
                if screen_rect and len(screen_rect) >= 4 and rect_valid:
                    m["screenRect"] = screen_rect
                    m["hasHighlightRect"] = True
                else:
                    m["hasHighlightRect"] = False
                m["runtimeMatch"] = {
                    "status": "matched",
                    "matchScore": match_score,
                    "matchLevel": r.get("matchLevel", ""),
                    "runtimePath": runtime_path,
                    "runtimePageId": r.get("runtimePageId", ""),
                    "ownerPageId": r.get("ownerPageId", ""),
                    "instanceId": r.get("instanceId", 0),
                    "visible": r.get("visible", False),
                    "interactable": r.get("interactable", False),
                    "screenRect": screen_rect,
                    "codeSemantic": r.get("codeSemantic", {}),
                    "matchedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                }
            else:
                # 写入未匹配/失败原因
                fail_reason = r.get("matchFailReason", "")
                dbg = r.get("matchFailReason", "") == "debug_ui（调试界面元素，不参与业务匹配）"
                if m.get("reviewStatus") == "runtime_matched":
                    m["reviewStatus"] = m.get("previousReviewStatus") or "auto_draft"
                m["hasRuntimeMatch"] = False
                m["hasHighlightRect"] = False
                m.pop("screenRect", None)
                m.pop("runtimePath", None)
                m.pop("lastRuntimePath", None)
                m.pop("instanceId", None)
                m.pop("lastInstanceId", None)
                if dbg:
                    m["excludeReason"] = "debug_ui"
                    m["elementType"] = m.get("elementType", "debug_ui")
                    m["allowRuntimeMatch"] = False
                    m["businessCandidate"] = False
                m["runtimeMatch"] = {
                    "status": "not_matched",
                    "reason": fail_reason,
                    "matchedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                }
                # 保留 draftPageId/currentPageId 供前端显示
                if r.get("draftPageId") or r.get("currentPageId"):
                    m["runtimeMatch"]["draftPageId"] = r.get("draftPageId", "")
                    m["runtimeMatch"]["currentPageId"] = r.get("currentPageId", "")
                m["codeSemantic"] = r.get("codeSemantic", {})

            # 如果有运行时截图路径，同步给元素
            state_path = os.path.join(metadata_dir, "current_runtime_state.json")
            if os.path.exists(state_path):
                try:
                    with open(state_path, "r", encoding="utf-8") as f:
                        st = json.load(f)
                    # 场景对象可以后续通过 capture 获取，暂时不标记 hasScreenshot
                except Exception:
                    pass

            mgr.upsert(path, m)

        # Runtime-only clickable discovery: project inventory can miss nodes that
        # only become obvious at runtime, such as TopRes add icons or tab items
        # whose project name is tab1 but runtime name is 0.
        discovered_count = 0
        try:
            runtime_tree_path = os.path.join(metadata_dir, "runtime_ui_tree_current.json")
            runtime_data = {}
            if os.path.exists(runtime_tree_path):
                with open(runtime_tree_path, "r", encoding="utf-8") as f:
                    runtime_data = json.load(f)

            runtime_nodes = runtime_data.get("nodes", [])
            current_page = result.get("pageId") or runtime_data.get("pageId", "")
            m_page = re.match(r"^(UI[A-Za-z0-9_]+|ui[A-Za-z0-9_]+)", current_page or "")
            draft_page = m_page.group(1) if m_page else (current_page or "")
            allowed_types = {
                "button", "close_button", "tab", "interactive_icon",
                "item_cell", "reward_cell", "shop_item_cell", "clickable_unknown",
            }
            if hasattr(mgr, "_mappings"):
                for old_path, old_item in list(mgr._mappings.items()):
                    if old_item.get("source") == "runtime_discovered" and old_item.get("pageId") == draft_page:
                        del mgr._mappings[old_path]
            existing_paths = set(mgr._mappings.keys()) if hasattr(mgr, "_mappings") else set()
            used_runtime_paths = set()
            if hasattr(mgr, "_mappings"):
                for mm in mgr._mappings.values():
                    rp = (mm.get("runtimeMatch") or {}).get("runtimePath") or mm.get("runtimePath") or ""
                    if rp:
                        used_runtime_paths.add(rp)

            text_by_prefix = {}
            for n in runtime_nodes:
                txt = (n.get("text") or "").strip()
                if not txt:
                    continue
                pth = n.get("runtimePath", "") or ""
                parts = pth.split("/")
                for i in range(len(parts) - 1, 0, -1):
                    parent = "/".join(parts[:i])
                    text_by_prefix.setdefault(parent, txt)

            def runtime_discover_key(node):
                rp0 = node.get("runtimePath", "") or ""
                name0 = (node.get("nodeName", "") or "").lower()
                et0 = node.get("elementType", "") or ""
                if "/Root/TopRes/" in "/" + rp0 and name0 == "add":
                    return rp0
                if "/Root/TopRes/" in "/" + rp0:
                    return ""
                if "/Root/Shop/Tab/Tab/View/Content/" in "/" + rp0:
                    parts0 = rp0.split("/")
                    try:
                        idx = parts0.index("Content")
                        return "/".join(parts0[:idx + 2])
                    except Exception:
                        return rp0
                if "/Root/Shop/Content/Bag/ScrollView/ViewPort/Content/Item(Clone)/PropItem_" in "/" + rp0:
                    parts0 = rp0.split("/")
                    prop = next((x for x in parts0 if x.startswith("PropItem_")), "")
                    if not prop:
                        return ""
                    base = "/".join(parts0[:parts0.index(prop) + 1])
                    return base
                if et0 in ("button", "close_button"):
                    return rp0
                return ""

            def runtime_discover_rank(node):
                rp0 = node.get("runtimePath", "") or ""
                name0 = (node.get("nodeName", "") or "").lower()
                et0 = node.get("elementType", "") or ""
                if name0 == "clickcontent":
                    return 100
                if et0 == "tab" and name0.isdigit():
                    return 95
                if name0 == "add":
                    return 90
                if name0.startswith("propitem_"):
                    return 80
                if et0 in ("button", "close_button"):
                    return 75
                if name0 in ("quality", "icon", "on", "off"):
                    return 10
                if "item(clone)" in name0:
                    return 5
                return 30

            grouped_runtime_nodes = {}
            for n in runtime_nodes:
                rp = n.get("runtimePath", "") or ""
                if not rp or rp in used_runtime_paths:
                    continue
                if n.get("ownerPageId", "") != current_page:
                    continue
                if not n.get("effectiveClickable"):
                    continue
                et = n.get("elementType", "") or ""
                if et not in allowed_types:
                    continue
                if (n.get("nodeName", "") or "").lower() in ("on", "off"):
                    continue
                key = runtime_discover_key(n)
                if not key:
                    continue
                old = grouped_runtime_nodes.get(key)
                if not old or runtime_discover_rank(n) > runtime_discover_rank(old):
                    grouped_runtime_nodes[key] = n

            for n in grouped_runtime_nodes.values():
                rp = n.get("runtimePath", "") or ""
                if not rp or rp in used_runtime_paths:
                    continue
                et = n.get("elementType", "") or ""
                synthetic_path = f"__runtime__::{draft_page}::{rp}"
                if synthetic_path in existing_paths:
                    continue
                rect = n.get("screenRect", []) or []
                label_text = text_by_prefix.get(rp, "")
                node_name = n.get("nodeName", "") or rp.split("/")[-1]
                if node_name.lower() == "add":
                    parent = rp.split("/")[-2] if "/" in rp else ""
                    display_name = f"{parent}加号"
                    desc = f"{draft_page}顶部资源加号"
                elif et == "tab":
                    display_name = label_text or node_name
                    desc = f"{draft_page}页签：{display_name}"
                elif label_text:
                    display_name = f"{label_text}-{node_name}"
                    desc = f"{draft_page}运行态发现元素：{label_text}"
                else:
                    display_name = node_name
                    desc = f"{draft_page}运行态发现元素：{node_name}"

                item = {
                    "path": synthetic_path,
                    "elementPath": synthetic_path,
                    "nodeName": node_name,
                    "displayName": display_name,
                    "chineseDescription": desc,
                    "pageId": draft_page,
                    "elementType": et,
                    "interactionType": n.get("interactionType", "click") or "click",
                    "clickable": True,
                    "effectiveClickable": True,
                    "source": "runtime_discovered",
                    "reviewStatus": "runtime_matched",
                    "sourceLevel": "L2",
                    "confidence": 0.8,
                    "priority": "P1",
                    "suggestedTestId": f"{draft_page}.{node_name}.{n.get('instanceId', 0)}",
                    "suggestedSemanticId": f"{draft_page}.{display_name}",
                    "runtimePath": rp,
                    "screenRect": rect,
                    "hasRuntimeMatch": True,
                    "hasHighlightRect": bool(rect and len(rect) >= 4),
                    "runtimeMatch": {
                        "status": "matched",
                        "matchScore": 1.0,
                        "matchLevel": "RUNTIME_DISCOVERED",
                        "runtimePath": rp,
                        "runtimePageId": n.get("pageId", ""),
                        "ownerPageId": n.get("ownerPageId", ""),
                        "instanceId": n.get("instanceId", 0),
                        "visible": n.get("visible", False),
                        "interactable": n.get("interactable", False),
                        "screenRect": rect,
                        "matchedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                    },
                    "reviewHint": "运行态自动发现，请通过高亮和测试点击确认",
                }
                mgr.upsert(synthetic_path, item)
                discovered_count += 1
                used_runtime_paths.add(rp)
            result["runtimeDiscovered"] = discovered_count
        except Exception as discover_error:
            result["runtimeDiscoverError"] = str(discover_error)
        mgr.save()

        try:
            result_path = os.path.join(metadata_dir, "runtime_match_result.json")
            with open(result_path, "w", encoding="utf-8") as f:
                json.dump(result, f, ensure_ascii=False, indent=2)
            result["resultPath"] = result_path
        except Exception as save_error:
            result["resultSaveError"] = str(save_error)

        if data.get("includeResults"):
            return jsonify(result)

        response = {k: v for k, v in result.items() if k != "results"}
        response["resultTruncated"] = True
        response["resultCount"] = len(result.get("results", []))
        return jsonify(response)
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


