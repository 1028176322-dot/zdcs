@app.route("/api/relocate", methods=["POST"])
def api_relocate():
    try:
        from core_engine.game_content_locator import find_game_content_rect
        from 坐标截图.screenshot_game_content import GameContentScreenshot
        import json as _json
        req_path = Path(os.path.expanduser("~")) / ".autosmoke" / "locate_request.json"
        bridge_req = Path(os.path.expanduser("~")) / ".autosmoke" / "bridge_request.json"
        result_path = Path(os.path.expanduser("~")) / ".autosmoke" / "game_view_pos.json"

        req_path.write_text(_json.dumps({"action": "locate"}))
        bridge_req.write_text(_json.dumps({"action": "export"}))

        waited, max_wait, step = 0, 15, 0.2
        old_mtime = result_path.stat().st_mtime if result_path.exists() else 0
        while waited < max_wait:
            time.sleep(step); waited += step
            if result_path.exists():
                new_mtime = result_path.stat().st_mtime
                if new_mtime > old_mtime + 0.01:
                    break

        capturer = GameContentScreenshot(mapper=_get_mapper())
        cap = capturer.capture()
        img = cap.get("game_content_image")
        if img is not None:
            import numpy as np
            result = find_game_content_rect(np.array(img))
        else:
            result = {"status": "ERROR", "error": "截图失败"}

        if result.get("status") == "OK":
            cr = result.get("gameContentRect", {})
            gv = result.get("gameViewPanelRect", {})
            config = _json.load(open(CONFIG_FILE))
            config["game_view_coords"] = {"left": gv.get("left"), "top": gv.get("top"),
                                          "right": gv.get("left",0)+gv.get("width",0),
                                          "bottom": gv.get("top",0)+gv.get("height",0),
                                          "width": gv.get("width"), "height": gv.get("height"),
                                          "source": "auto_relocate"}
            config["game_content_rect"] = {"left": cr.get("left"), "top": cr.get("top"),
                                           "width": cr.get("width"), "height": cr.get("height"),
                                           "source": "auto_relocate"}
            _json.dump(config, open(CONFIG_FILE, "w"), indent=2)
            _reset_runtime_cache()

        return jsonify(result)
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


