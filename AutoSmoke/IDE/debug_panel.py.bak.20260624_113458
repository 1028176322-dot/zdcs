        var sem=d.semanticUpdated||{};
        var semKeys=Object.keys(sem).filter(function(k){return sem[k];});
        var fb=d.dictionaryFeedback||{};
        var suffix=fb.reason==='english_id_required'?'；需要为“'+targetEsc(fb.objectName||'新词')+'”补英文ID后再同步 semanticId':'';
        var baseMsg='targetName 已保存，已更新当前目标；语义字段 '+(semKeys.length?semKeys.join(', '):'未变更')+suffix;
        targetMaybeCreatePage(d.pageSuggestion||{}, name).then(function(pageResult){
          if(pageResult.created){
            targetSetResult(baseMsg+'；已创建页面 '+((d.pageSuggestion||{}).pageId||''),true);
          }else if(pageResult.error){
            targetSetResult(baseMsg+'；页面创建失败: '+pageResult.error,false);
          }else if(pageResult.skipped){
            targetSetResult(baseMsg+'；新页面待创建 '+((d.pageSuggestion||{}).pageId||''),true);
          }else{
            targetSetResult(baseMsg,true);
