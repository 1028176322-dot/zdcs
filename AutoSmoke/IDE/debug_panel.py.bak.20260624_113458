        explorer = AutoExplorer()
        try:
            stats = explorer.run(max_clicks=max_clicks, max_depth=max_depth)
        except TypeError:
            stats = explorer.run(max_clicks=max_clicks)
        if not isinstance(stats, dict):
            stats = {}
        page_graph_file = _metadata_path("page_graph.json")
        report = {
            "page_graph": os.path.abspath(page_graph_file) if page_graph_file else "",
