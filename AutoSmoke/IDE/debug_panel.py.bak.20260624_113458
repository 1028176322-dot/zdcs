        conflict = _target_candidate_conflict(task, draft_path) if _target_is_assert_only(task) else {}
        if conflict:
            updates = {
                "status": "blocked",
                "blockedReason": "candidate_already_confirmed",
                "selectedDraftPath": "",
                "conflictDraftPath": draft_path,
                "conflictFormalRef": conflict.get("formalRef", ""),
                "conflictEvidenceRef": conflict.get("evidenceRef", ""),
                "conflictTargetName": conflict.get("targetName", ""),
                "conflictTestId": conflict.get("testId", ""),
                "legacyPaths": {},
                "allowStatusRegression": True,
            }
            saved = catalog.update_task(target_id, updates)
            return jsonify({
                "success": False,
                "error": "candidate_already_confirmed",
                "message": "Selected candidate is already confirmed by another target. Re-match candidates or ignore this duplicate runtime target.",
                "targetId": target_id,
                "existing": {
                    "targetName": updates["conflictTargetName"],
                    "testId": conflict.get("testId", ""),
                    "formalRef": updates["conflictFormalRef"],
                    "evidenceRef": updates["conflictEvidenceRef"],
                },
                "task": saved.get("task", task) if isinstance(saved, dict) else task,
            })
        highlight_payload = {"draftPath": draft_path}
        runtime_hint = task.get("runtimeHint", {}) if isinstance(task.get("runtimeHint", {}), dict) else {}
        if runtime_hint.get("screenRect"):
            highlight_payload["screenRect"] = runtime_hint.get("screenRect")
        ok_cap, cap = _prepare_invoke_api("get", "/api/capture")
        if ok_cap and isinstance(cap, dict):
            fresh_screenshot = cap.get("game_content_path") or cap.get("game_view_path") or ""
            if fresh_screenshot:
                highlight_payload["screenshotPath"] = fresh_screenshot
        ok, result = _prepare_invoke_api("post", "/api/mapping/highlight", highlight_payload)
        if (not result.get("success")) and runtime_hint.get("screenRect") and highlight_payload.get("draftPath"):
            retry_payload = {
                "screenRect": runtime_hint.get("screenRect"),
            }
            if highlight_payload.get("screenshotPath"):
                retry_payload["screenshotPath"] = highlight_payload.get("screenshotPath")
            ok, result = _prepare_invoke_api("post", "/api/mapping/highlight", retry_payload)
        if not ok or not result.get("success"):
            conditional, condition_detail = _target_condition_not_applicable(task, result.get("reason") or result.get("error", "highlight_failed"))
            if conditional:
                catalog.update_task(target_id, {"status": "not_applicable", "blockedReason": condition_detail["reason"], "availabilityEvidence": condition_detail})
                return jsonify({"success": True, "targetId": target_id, "status": "not_applicable", "availability": condition_detail, "detail": result})
            catalog.update_task(target_id, {"status": "blocked", "blockedReason": result.get("reason") or result.get("error", "highlight_failed")})
            return jsonify({"success": False, "error": result.get("error", "highlight_failed"), "detail": result})
        evidence = {
            "draftPath": draft_path,
            "highlightImage": result.get("highlightImage", ""),
            "screenRectUsed": result.get("screenRectUsed", []),
            "imageSize": result.get("imageSize", []),
            "rectSource": result.get("rectSource", ""),
        }
        catalog.record_evidence(target_id, "visual", evidence, status="highlight_generated")
        catalog.update_task(target_id, {"blockedReason": ""})
        return jsonify({"success": True, "targetId": target_id, "status": "highlight_generated", "visual": evidence})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


