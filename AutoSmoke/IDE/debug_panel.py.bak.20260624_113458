def _target_business_test_id(task, mapping, candidate, draft_path):
    runtime_hint = task.get("runtimeHint", {}) if isinstance(task.get("runtimeHint", {}), dict) else {}
    page = _target_slug_test_id(mapping.get("pageId") or candidate.get("pageId") or "ui")
    area = _target_slug_test_id(task.get("pageHint") or runtime_hint.get("ownerPageId") or runtime_hint.get("pageId") or "")
    node = _target_slug_test_id(mapping.get("nodeName") or candidate.get("nodeName") or runtime_hint.get("nodeName") or Path(str(draft_path).replace("\\", "/")).name)
    role = _target_slug_test_id(task.get("role") or mapping.get("role") or candidate.get("role") or "")
    element_type = _target_slug_test_id(task.get("elementType") or mapping.get("elementType") or candidate.get("elementType") or "")
    suffix_map = {
        "button": "button",
        "interactive_icon": "button",
        "item_cell": "cell",
        "clickable_unknown": "target",
        "tab": "tab",
        "panel": "panel",
    }
    suffix = suffix_map.get(element_type, element_type or role or "target")
    if role == "item" and node.startswith("res_item_"):
        node = node.replace("res_item_", "item_", 1)
    parts = [page]
    if area and area != page:
        parts.append(area)
    if node and node not in parts:
        parts.append(node)
    if suffix and suffix != node and not node.endswith("_" + suffix):
        parts.append(suffix)
    return ".".join(p for p in parts if p)


def _target_existing_test_id_owner(test_id, draft_path, mgr):
    if not test_id:
        return ""
    draft_variants = _target_path_variants(draft_path)
    for path, item in getattr(mgr, "_mappings", {}).items():
        if item.get("testId") != test_id:
            continue
        item_variants = set()
        item_variants.update(_target_path_variants(path))
        for key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
            item_variants.update(_target_path_variants(item.get(key)))
        locator = item.get("locator")
        if isinstance(locator, dict):
            item_variants.update(_target_path_variants(locator.get("value")))
        if draft_variants and item_variants and _target_paths_overlap(draft_variants, item_variants):
            continue
        if path != draft_path:
            return path
    formal_item = _formal_records().get(test_id)
    if isinstance(formal_item, dict):
        owner = formal_item.get("elementPath") or formal_item.get("locator", {}).get("value", "")
        owner_variants = set()
        for key in ["elementPath", "path", "draftPath", "selectedDraftPath"]:
            owner_variants.update(_target_path_variants(formal_item.get(key)))
        locator = formal_item.get("locator")
        if isinstance(locator, dict):
            owner_variants.update(_target_path_variants(locator.get("value")))
        if owner and draft_variants and owner_variants and draft_variants.intersection(owner_variants):
            return ""
        if owner and owner != draft_path:
            return owner
    return ""


def _target_unique_test_id(base_test_id, draft_path, mgr):
    test_id = base_test_id or f"target.{hashlib.sha1(str(draft_path).encode('utf-8')).hexdigest()[:10]}"
    owner = _target_existing_test_id_owner(test_id, draft_path, mgr)
    if not owner:
        return test_id, False
    suffix = hashlib.sha1(str(draft_path).encode("utf-8")).hexdigest()[:6]
    return f"{test_id}.{suffix}", True


