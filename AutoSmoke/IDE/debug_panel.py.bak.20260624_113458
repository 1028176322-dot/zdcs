@app.route("/api/precheck")
def api_precheck():
    ctx = _get_case_context()
    result = {
        "status": "OK",
        "canExecute": True,
        "checks": [],
        "items": [],
        "blockers": [],
    }
    try:
        cfg = _read_json_file(CONFIG_FILE, {})
        unity_project = cfg.get("unity_project_path", "")
        poco_path = cfg.get("poco_sdk_path", "")
        game_resolution = cfg.get("game_resolution", {})
        result["checks"].append(_safe_check_item(
            "应用配置",
            bool(unity_project) and bool(poco_path),
            {
                "unityProject": unity_project,
                "pocoPath": poco_path,
                "designWidth": _coerce_int(game_resolution.get("width"), 0),
                "designHeight": _coerce_int(game_resolution.get("height"), 0),
            },
            blocker=True,
            quick_fix=_precheck_quick_fixes("应用配置", {
                "unityProject": unity_project,
                "pocoPath": poco_path,
            }),
        ))

        exec_ok = True
        try:
            executor = _get_executor()
            prereq = executor.check_prerequisites()
            exec_ok = bool(prereq.get("ok", False))
            detail = prereq
        except Exception as e:
            exec_ok = False
            detail = {"error": str(e)}
        result["checks"].append(_safe_check_item(
            "用例执行前置",
            exec_ok,
            detail,
            blocker=True,
            quick_fix=_precheck_quick_fixes("用例执行前置", detail),
        ))

        deploy_ok = False
        deploy_detail = {}
        deploy_impl = None
        try:
            from 部署_tools.deploy_tools import DeployManager as DM
            deploy_impl = DM
        except Exception:
            try:
                from deploy_tools import DeployManager as DM
                deploy_impl = DM
            except Exception:
                try:
                    from 閮ㄧ讲宸ュ叿.deploy_tools import DeployManager as DM
                    deploy_impl = DM
                except Exception:
                    deploy_detail = {"error": "DeployManager 未安装/不可用"}

        if deploy_impl is not None:
            try:
                dm = deploy_impl()
                dep = dm.check_status()
                deploy_ok = bool(dep.get("all_ok", False))
                deploy_detail = {"project_path": dep.get("project_path"), "all_ok": dep.get("all_ok"), "status": dep}
            except Exception as e:
                deploy_ok = False
                deploy_detail = {"error": str(e)}
        result["checks"].append(_safe_check_item(
            "Unity脚本部署",
            deploy_ok,
            deploy_detail,
            blocker=True,
            quick_fix=_precheck_quick_fixes("Unity脚本部署", deploy_detail),
        ))

        mapper_ok = True
        mapper_detail = {}
        try:
            from 坐标截图.coordinate_mapper import CoordinateMapper
            mapper = CoordinateMapper.from_config()
            mapper_ok = mapper is not None and bool(getattr(mapper, "design_width", 0)) and bool(getattr(mapper, "design_height", 0))
            mapper_detail = {
                "design_width": getattr(mapper, "design_width", None) if mapper else None,
                "design_height": getattr(mapper, "design_height", None) if mapper else None,
                "game_view": bool(getattr(mapper, "gv_right", None)),
            }
        except Exception as e:
            mapper_ok = False
            mapper_detail = {"error": str(e)}
        result["checks"].append(_safe_check_item(
            "坐标映射配置",
            mapper_ok,
            mapper_detail,
            blocker=True,
            quick_fix=_precheck_quick_fixes("坐标映射配置", mapper_detail),
        ))

        capture_probe = _check_capture_channels()
        result["checks"].append(_safe_check_item(
            "截图通道",
            bool(capture_probe.get("ok", False)),
            capture_probe,
            blocker=True,
            quick_fix=_precheck_quick_fixes("截图通道", capture_probe),
        ))

        bridge_probe = _check_bridge_service()
        result["checks"].append(_safe_check_item(
            "日志/服务可达性",
            bool(bridge_probe.get("ok", False)),
            bridge_probe,
            blocker=True,
            quick_fix=_precheck_quick_fixes("日志/服务可达性", bridge_probe),
        ))

        case_ok = True
        case_detail = {}
        case_path = ctx.get("path") if isinstance(ctx, dict) else ""
        if case_path:
            case_ok = os.path.exists(case_path)
            case_detail = {
                "path": case_path,
                "exists": case_ok,
                "stepField": ctx.get("step_field"),
                "caseIdField": ctx.get("case_id_field"),
            }
        else:
            case_ok = False
            case_detail = {"path": "", "exists": False, "error": "未设置用例文件路径"}
        result["checks"].append(_safe_check_item(
            "用例文件",
            case_ok,
            case_detail,
            blocker=False,
            quick_fix=_precheck_quick_fixes("用例文件", case_detail),
        ))

        blockers = [c for c in result["checks"] if c["blocker"] and not c["ok"]]
        result["blockers"] = blockers
        result["canExecute"] = len(blockers) == 0
        if blockers:
            result["status"] = "ERROR"
        elif any(not c.get("ok") for c in result["checks"]):
            result["status"] = "WARN"
        result["items"] = [{"name": c.get("name"), "ok": c["ok"], "blocker": c.get("blocker", False)} for c in result["checks"]]
        return jsonify(result)
    except Exception as e:
        return jsonify({"status": "ERROR", "error": str(e), "canExecute": False, "checks": []})


