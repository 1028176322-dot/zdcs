@app.route("/api/mapping/semantic/check_unique", methods=["POST"])
def api_mapping_semantic_check_unique():
    try:
        data = request.get_json() or {}
        test_id = _coerce_str(data.get("testId", data.get("suggestedTestId")))
        semantic_id = _coerce_str(data.get("semanticId", data.get("suggestedSemanticId")))
        if not test_id and not semantic_id:
            return jsonify({"success": False, "error": "testId 或 semanticId 至少提供一个"})

        candidate = {
            "path": _coerce_str(data.get("path"), _coerce_str(data.get("draftPath"), _coerce_str(data.get("elementKey")))),
            "testId": test_id,
            "semanticId": semantic_id,
            "ignoreTestId": _coerce_str(data.get("ignoreTestId")),
            "ignorePath": _coerce_str(data.get("ignorePath")),
        }
        duplicates = _collect_duplicates(candidate)
        issues = []
        for item in duplicates.get("testId", []):
            code = f"duplicate_test_id_{item.get('source', 'unknown')}"
            path = _coerce_str(item.get("path"), item.get("pathKey", ""))
            issues.append({
                "code": code,
                "message": f"testId 已存在: {test_id}",
                "existingPath": path,
                "source": item.get("source", ""),
            })
        for item in duplicates.get("semanticId", []):
            code = f"duplicate_semantic_id_{item.get('source', 'unknown')}"
            path = _coerce_str(item.get("path"), item.get("pathKey", ""))
            issues.append({
                "code": code,
                "message": f"semanticId 已存在: {semantic_id}",
                "existingPath": path,
                "source": item.get("source", ""),
            })

        ok = len(issues) == 0
        return jsonify({
            "success": True,
            "testId": test_id,
            "semanticId": semantic_id,
            "ok": ok,
            "isUnique": {
                "testId": len(duplicates.get("testId", [])) == 0,
                "semanticId": len(duplicates.get("semanticId", [])) == 0,
            },
            "duplicates": duplicates,
            "issues": issues,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


