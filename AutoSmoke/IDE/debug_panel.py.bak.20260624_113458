@app.route("/api/report/export/fail_package", methods=["POST"])
def api_report_export_fail_package():
    try:
        data = request.get_json(silent=True) or {}
        run_id = data.get("runId")
        if not run_id and data.get("path"):
            p = _normalize_user_path(data["path"])
            run_id = os.path.basename(os.path.dirname(p))
        if not run_id and data.get("batch_report"):
            run_id = os.path.splitext(os.path.basename(data["batch_report"]))[0].replace("batch_", "")
        if run_id:
            run_dir = os.path.join(SCREENSHOTS_DIR, str(run_id))
        else:
            return jsonify({"success": False, "error": "未提供 runId"})

        batch_report = os.path.join(run_dir, "batch_report.json")
        if not os.path.exists(batch_report):
            return jsonify({"success": False, "error": f"报告不存在: {batch_report}"})
        with open(batch_report, "r", encoding="utf-8") as f:
            batch = json.load(f)

        package_dir = os.path.join(FAILED_PACKAGE_DIR, str(run_id))
        Path(package_dir).mkdir(parents=True, exist_ok=True)
        zippath = os.path.join(package_dir, f"{_safe_filename(run_id)}_fail_package.zip")

        failed_case_ids = [c.get("case_id") for c in batch.get("case_results", []) if c.get("result") != "PASS"]
        to_copy = []
        if os.path.exists(run_dir):
            for n in os.listdir(run_dir):
                if not n.lower().endswith(".png"):
                    continue
                lower = n.lower()
                if "before" in lower or "after" in lower or "diff" in lower:
                    to_copy.append(os.path.join(run_dir, n))
            for c in batch.get("case_results", []):
                case_id = c.get("case_id", "")
                if c.get("result") == "PASS" and failed_case_ids:
                    continue
                rid = c.get("result_path")
                if rid and os.path.exists(rid):
                    to_copy.append(rid)
        to_copy.append(batch_report)

        with zipfile.ZipFile(zippath, "w", compression=zipfile.ZIP_DEFLATED) as zf:
            for item in to_copy:
                if not item or not os.path.exists(item):
                    continue
                arc = os.path.relpath(item, run_dir)
                zf.write(item, arcname=arc)
        return jsonify({"success": True, "path": zippath, "download": _report_download_link(zippath), "count": len(to_copy)})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


