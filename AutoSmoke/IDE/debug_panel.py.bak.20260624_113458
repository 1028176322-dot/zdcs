        runtime_path = m.get("runtimePath", "") or m.get("lastRuntimePath", "")
        instance_id = m.get("instanceId", 0) or m.get("lastInstanceId", 0)
        click_target = m.get("clickTargetNode", "") or m.get("path", "")
        screen_rect = m.get("screenRect", [])

        result_data = {}
        click_method = "unknown"

        # 优先使用 Bridge runtimePath 点击
        if runtime_path:
            bridge_dir = os.path.join(_CONF_DIR, "runtime", "bridge")
            for stale_dir, patterns in (
                ("requests", ("test_click_click_*.json",)),
                ("responses", ("click_*.json", "click_*.done")),
            ):
                cleanup_dir = Path(bridge_dir) / stale_dir
                if cleanup_dir.exists():
                    for pattern in patterns:
                        for stale_file in cleanup_dir.glob(pattern):
                            try:
                                stale_file.unlink()
                            except Exception:
                                pass
            request_id = "click_" + datetime.now().strftime("%Y%m%d_%H%M%S_%f")
            req_path = os.path.join(bridge_dir, "requests", f"test_click_{request_id}.json")

            req_data = {
                "requestId": request_id,
                "type": "test_click_element",
                "createdAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                "payload": {
                    "semanticId": m.get("suggestedSemanticId", ""),
                    "runtimePath": runtime_path,
                    "instanceId": instance_id,
                    "method": "unity_event_system",
                    "verifyAfterClick": True,
                }
            }
            os.makedirs(os.path.dirname(req_path), exist_ok=True)
            with open(req_path, "w", encoding="utf-8") as f:
                json.dump(req_data, f, ensure_ascii=False)

            # 等待结果
            resp_id = request_id
            resp_path = os.path.join(bridge_dir, "responses", resp_id + ".json")
            done_path = os.path.join(bridge_dir, "responses", resp_id + ".done")

            poll_count = max(1, int(click_timeout_sec / click_poll_sec))
            for _ in range(poll_count):
                if os.path.exists(done_path):
                    try:
                        with open(resp_path, "r", encoding="utf-8") as f:
                            resp_data = json.load(f)
                        payload = resp_data.get("payload", {})
                        if payload.get("clickResult") == "CLICK_TIMEOUT":
                            injector_result = Path.home() / ".autosmoke" / "click_result.json"
                            for _fallback_wait in range(10):
                                if injector_result.exists():
                                    try:
                                        with open(injector_result, "r", encoding="utf-8") as rf:
                                            injector_data = json.load(rf)
                                        if injector_data.get("requestId") == request_id:
                                            payload = {
                                                **payload,
                                                "clickResult": injector_data.get("status") or payload.get("clickResult"),
                                                "message": injector_data.get("message", ""),
                                                "eventReceiverMatched": (injector_data.get("click") or {}).get("receiverMatchTarget", False),
                                                "hitRuntimePath": (injector_data.get("click") or {}).get("eventReceiver", ""),
                                                "targetGameObject": (injector_data.get("click") or {}).get("targetGameObject", ""),
                                                "screenPoint": (injector_data.get("click") or {}).get("screenPoint", []),
                                                "injectorResultRecovered": True,
                                            }
                                            resp_data["success"] = injector_data.get("status") == "OK"
                                            resp_data["payload"] = payload
                                            break
                                    except Exception:
                                        pass
                                time.sleep(0.05)
                        result_data = payload
                        click_method = "unity_event_system"
                    except Exception:
                        pass
                    break
                time.sleep(click_poll_sec)

        if runtime_path and click_method == "unknown" and disable_coordinate_fallback:
            return jsonify({
                "success": False,
                "error": "unity_bridge_no_click_response",
                "runtimePath": runtime_path,
                "instanceId": instance_id,
                "detail": {
                    "reason": "Bridge did not write a test_click response before timeout",
                    "coordinateFallbackDisabled": True,
                },
            })

        # 如果 Bridge 方式没成功，尝试鼠标点击（用 screenRect）
        if click_method == "unknown" and screen_rect:
            try:
                mapper = CoordinateMapper.from_config()
                handler = ClickMode.create("unity_inject", mapper=mapper)
                if isinstance(screen_rect, dict):
                    cx = screen_rect.get("x", 0) + screen_rect.get("width", 0) / 2
                    cy = screen_rect.get("y", 0) + screen_rect.get("height", 0) / 2
                elif len(screen_rect) >= 4:
                    cx = (screen_rect[0] + screen_rect[2]) / 2
                    cy = (screen_rect[1] + screen_rect[3]) / 2
                else:
                    cx, cy = 0, 0
                if cx > 0 and cy > 0:
                    click_result = handler.click(cx, cy, "design", description="review_test")
                    result_data = click_result
                    click_method = "mouse_inject"
            except Exception:
                pass

        # 判断结果
        success = False
        click_result_str = result_data.get("clickResult", "")
        if click_result_str in ("OK", "CLICK_CONFIRMED", "CLICK_OK", "CLICK_CHANGED"):
            success = True
        elif result_data.get("success") or result_data.get("result") in ("CLICK_OK", "CLICK_CHANGED"):
            success = True

        # 如果成功，更新映射状态为 click_confirmed
        if success:
            mgr = ElementMappingManager()
            mgr.load()
            m2 = mgr.get(draft_path)
            if m2:
                m2["reviewStatus"] = "click_confirmed"
                m2["sourceLevel"] = "L4"
                m2["clickVerification"] = {
                    "status": "passed",
                    "method": click_method,
                    "eventReceiverMatched": result_data.get("eventReceiverMatched", False),
                    "verifiedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                    "hitRuntimePath": result_data.get("hitRuntimePath", runtime_path),
                }
                mgr.upsert(draft_path, m2)
                mgr.save()

        return jsonify({
            "success": success,
            "clickMethod": click_method,
            "detail": result_data,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


