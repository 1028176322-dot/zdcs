@app.route("/api/unity/bridge/status", methods=["GET"])
def api_unity_bridge_status():
    """检测 Unity 运行态 Bridge 连接状态"""
    try:
        heartbeat_path = os.path.join(_RUNTIME_BRIDGE_DIR, "unity_heartbeat.json")
        connected = False
        play_mode = False
        scene_id = ""
        page_id = ""
        node_count = 0
        clickable_count = 0
        state_path = os.path.join(_RUNTIME_METADATA_DIR, "current_runtime_state.json")

        hb_exists = os.path.exists(heartbeat_path)
        if hb_exists:
            try:
                with open(heartbeat_path, "r", encoding="utf-8") as f:
                    hb = json.load(f)
                hb_time_str = hb.get("updatedAt", "")
                if hb_time_str:
                    hb_time = datetime.strptime(hb_time_str, "%Y-%m-%dT%H:%M:%S")
                    elapsed = (datetime.now() - hb_time).total_seconds()
                    connected = elapsed < 5.0 and hb.get("alive", False)
                    play_mode = hb.get("playMode", False)
                    scene_id = hb.get("sceneId", "")
                    page_id = hb.get("pageId", "")
            except Exception:
                pass

        if os.path.exists(state_path):
            try:
                with open(state_path, "r", encoding="utf-8") as f:
                    st = json.load(f)
                node_count = st.get("nodeCount", 0)
                clickable_count = st.get("clickableCount", 0)
                comp_count = st.get("componentClickableCount", node_count)
                icon_count = st.get("interactiveIconCount", 0)
                cell_count = st.get("interactiveCellCount", 0)
                blank_count = st.get("blankCloseAreaCount", 0)
                drag_count = st.get("dragAreaCount", 0)
                eff_count = st.get("effectiveClickableCount", clickable_count)
            except Exception:
                comp_count = node_count
                icon_count = 0
                cell_count = 0
                blank_count = 0
                drag_count = 0
                eff_count = clickable_count
                pass

        # 读取场景交互对象
        scene_obj_count = 0
        scene_obj_path = os.path.join(_RUNTIME_METADATA_DIR, "scene_interaction_tree.json")
        if os.path.exists(scene_obj_path):
            try:
                with open(scene_obj_path, "r", encoding="utf-8") as f:
                    so = json.load(f)
                scene_obj_count = so.get("objectCount", 0)
            except Exception:
                pass

        return jsonify({
            "success": True,
            "connected": connected,
            "playMode": play_mode,
            "sceneId": scene_id,
            "pageId": page_id,
            "nodeCount": node_count,
            "clickableCount": clickable_count,
            "componentClickableCount": comp_count,
            "interactiveIconCount": icon_count,
            "interactiveCellCount": cell_count,
            "blankCloseAreaCount": blank_count,
            "dragAreaCount": drag_count,
            "sceneObjectCount": scene_obj_count,
            "effectiveClickableCount": eff_count + scene_obj_count,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


@app.route("/api/runtime_ui/refresh", methods=["POST"])
def api_runtime_ui_refresh():
    """请求 Unity 导出当前实时 UI 树"""
    try:
        bridge_dir = _RUNTIME_BRIDGE_DIR

        # 写请求文件
        request_id = "req_" + datetime.now().strftime("%Y%m%d_%H%M%S")
        req_path = os.path.join(bridge_dir, "requests", f"dump_runtime_ui_tree_{request_id}.json")

        req_data = {
            "requestId": request_id,
            "type": "dump_runtime_ui_tree",
            "createdAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
            "payload": {
                "includeInvisible": False,
                "includeComponents": True,
                "includeScreenRect": True,
            }
        }

        os.makedirs(os.path.dirname(req_path), exist_ok=True)
        with open(req_path, "w", encoding="utf-8") as f:
            json.dump(req_data, f, ensure_ascii=False)

        # 等待响应（最多 5 秒）
        # C# Bridge 以 req.requestId 命名响应文件
        resp_path = os.path.join(bridge_dir, "responses", request_id + ".json")
        done_path = os.path.join(bridge_dir, "responses", request_id + ".done")

        nodes = []
        scene_id = ""
        page_id = ""
        for _ in range(25):
            if os.path.exists(done_path):
                try:
                    with open(resp_path, "r", encoding="utf-8") as f:
                        resp_data = json.load(f)
                    if resp_data.get("success"):
                        payload = resp_data.get("payload", {})
                        nodes = payload.get("nodes", [])
                        scene_id = payload.get("sceneId", "")
                        page_id = payload.get("pageId", "")
                except Exception:
                    pass
                break
            time.sleep(0.2)

        # 保存到 metadata
        metadata_dir = _RUNTIME_METADATA_DIR
        os.makedirs(metadata_dir, exist_ok=True)

        raw_page_id = page_id
        try:
            from 元数据.runtime_matcher import enrich_runtime_nodes
            nodes, inferred_page_id = enrich_runtime_nodes(nodes)
            if inferred_page_id:
                page_id = inferred_page_id
        except Exception:
            inferred_page_id = ""

        runtime_tree_path = os.path.join(metadata_dir, "runtime_ui_tree_current.json")
        with open(runtime_tree_path, "w", encoding="utf-8") as f:
            json.dump({
                "schemaVersion": "runtime_ui_tree/v1",
                "capturedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
                "sceneId": scene_id,
                "pageId": page_id,
                "rawPageId": raw_page_id,
                "currentBusinessPageId": inferred_page_id or page_id,
                "nodeCount": len(nodes),
                "nodes": nodes,
            }, f, ensure_ascii=False, indent=2)

        state = {
            "sceneId": scene_id,
            "pageId": page_id,
            "rawPageId": raw_page_id,
            "currentBusinessPageId": inferred_page_id or page_id,
            "capturedAt": datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
            "nodeCount": len(nodes),
            "clickableCount": sum(1 for n in nodes if n.get("clickable")),
            "componentClickableCount": sum(1 for n in nodes if n.get("clickable")),
            "interactiveIconCount": sum(1 for n in nodes if n.get("elementType") == "interactive_icon"),
            "interactiveCellCount": sum(1 for n in nodes if n.get("elementType") in ("item_cell", "reward_cell", "shop_item_cell")),
            "blankCloseAreaCount": sum(1 for n in nodes if n.get("elementType") in ("popup_mask", "blank_close_area")),
            "dragAreaCount": sum(1 for n in nodes if n.get("elementType") in ("drag_area", "scroll_area")),
            "effectiveClickableCount": sum(1 for n in nodes if n.get("effectiveClickable")),
        }

        # 检查场景交互对象
        scene_obj_path = os.path.join(metadata_dir, "scene_interaction_tree.json")
        scene_obj_count = 0
        if os.path.exists(scene_obj_path):
            try:
                with open(scene_obj_path, "r", encoding="utf-8") as f:
                    so_data = json.load(f)
                scene_obj_count = so_data.get("objectCount", 0)
                state["sceneObjectCount"] = scene_obj_count
                state["sceneObjects"] = so_data.get("objects", [])
            except Exception:
                pass
        state_path = os.path.join(metadata_dir, "current_runtime_state.json")
        with open(state_path, "w", encoding="utf-8") as f:
            json.dump(state, f, ensure_ascii=False, indent=2)

        if page_id:
            snap_dir = os.path.join(metadata_dir, "runtime_snapshots")
            os.makedirs(snap_dir, exist_ok=True)
            snap_path = os.path.join(snap_dir, datetime.now().strftime("%Y%m%d_%H%M%S") + "_" + page_id + ".json")
            with open(snap_path, "w", encoding="utf-8") as f:
                json.dump(state, f, ensure_ascii=False, indent=2)

        return jsonify({
            "success": True,
            "sceneId": scene_id,
            "pageId": page_id,
            "rawPageId": raw_page_id,
            "currentBusinessPageId": inferred_page_id or page_id,
            "capturedAt": state["capturedAt"],
            "nodeCount": len(nodes),
            "clickableCount": state["clickableCount"],
            "componentClickableCount": state["componentClickableCount"],
            "interactiveIconCount": state["interactiveIconCount"],
            "interactiveCellCount": state["interactiveCellCount"],
            "blankCloseAreaCount": state["blankCloseAreaCount"],
            "dragAreaCount": state["dragAreaCount"],
            "effectiveClickableCount": state["effectiveClickableCount"],
            "sceneObjectCount": scene_obj_count,
            "runtimeTreePath": runtime_tree_path,
        })
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


