{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manual_test_cases.v1.schema.json",
  "title": "Manual test cases for AutoSmoke conversion",
  "type": "object",
  "required": ["schema_version", "feature_id", "test_cases"],
  "properties": {
    "schema_version": { "const": "manual_test_cases.v1" },
    "feature_id": { "type": "string", "minLength": 1 },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "steps"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "automation_level": { "enum": ["UI_ONLY", "UI_AND_BUSINESS", "MANUAL_ONLY"] },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": { "type": "string", "minLength": 1 },
                "target_id": { "type": "string" },
                "target_name": { "type": "string" },
                "page_name": { "type": "string" },
                "page_id": { "type": "string" },
                "expected": { "type": "string" },
                "assertion_refs": { "type": "array", "items": { "type": "string" } },
                "source_node_ids": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
